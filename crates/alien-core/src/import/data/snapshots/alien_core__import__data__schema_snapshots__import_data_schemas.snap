  "azure_postgres": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "description": "Azure Postgres (Flexible Server + Private Endpoint) registration data: the handles by which a setup-created Flexible Server (with its Private Endpoint, private DNS zone, and the Key Vault secret holding the master password) is registered as a Frozen Postgres resource. Setup owns the server, Alien refreshes and heartbeats it. The raw password is never carried, only the Key Vault secret URI.",
    "properties": {
      "database": {
        "description": "Default database name.",
        "type": "string"
      },
      "host": {
        "description": "Private DNS FQDN host workloads resolve to reach the server (the binding host).",
        "type": "string"
      },
      "keyVaultUrl": {
        "description": "Key Vault base URL holding the password (e.g. `https://<vault>.vault.azure.net`).",
        "type": "string"
      },
      "passwordSecretName": {
        "description": "Key Vault secret name of the master password (never the password).",
        "type": "string"
      },
      "passwordSecretUri": {
        "description": "Key Vault secret URI of the master password; the binding carries this and the workload resolves the value at load time.",
        "type": "string"
      },
      "privateEndpointName": {
        "description": "Private Endpoint name fronting the server in the dedicated PE subnet.",
        "type": "string"
      },
      "region": {
        "description": "Azure region the server lives in.",
        "type": "string"
      },
      "resourceGroup": {
        "description": "Resource group the server lives in.",
        "type": "string"
      },
      "serverName": {
        "description": "Flexible Server name on Azure.",
        "type": "string"
      },
      "serverResourceId": {
        "description": "Full ARM resource id of the Flexible Server (the deletable handle).",
        "type": "string"
      },
      "version": {
        "description": "Engine version the server reports.",
        "type": "string"
      }
    },
    "required": [
      "database",
      "host",
      "keyVaultUrl",
      "passwordSecretName",
      "passwordSecretUri",
      "privateEndpointName",
      "region",
      "resourceGroup",
      "serverName",
      "serverResourceId",
      "version"
    ],
    "title": "AzureFlexibleServerPostgresImportData",
    "type": "object"
  },
  "azure_queue": {
    "$schema": "http://json-schema.org/draft-07/schema#",

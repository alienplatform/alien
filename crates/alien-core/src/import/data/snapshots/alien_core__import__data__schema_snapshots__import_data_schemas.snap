        "description": "Lambda permission statement IDs granted for S3 storage triggers.",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "stageName": {
        "description": "API Gateway stage name, when public ingress is enabled.",
        "type": [
          "string",
          "null"
        ]
      },
      "url": {
        "description": "Public HTTPS URL, when public ingress is enabled.",

        "description": "Elastic IP allocation ID backing the NAT gateway.",
        "type": [
          "string",
          "null"
        ]
      },
      "internetGatewayId": {
        "description": "Internet gateway ID when created by this stack.",
        "type": [
          "string",
          "null"
        ]
      },
      "isByoVpc": {
        "description": "True when the VPC is owned outside this stack.",
        "type": "boolean"
      },
      "natGatewayId": {
        "description": "NAT gateway ID when created by this stack.",
        "type": [
          "string",
          "null"
        ]
      },
      "privateRouteTableId": {
        "description": "Private route table ID.",
        "type": [
          "string",
          "null"
        ]
      },
      "privateSubnetIds": {
        "description": "Private subnet IDs.",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "publicRouteTableId": {
        "description": "Public route table ID.",
        "type": [
          "string",
          "null"
        ]
      },
      "publicSubnetIds": {
        "description": "Public subnet IDs.",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "securityGroupId": {
        "description": "Security group ID for private workloads.",
        "type": [
          "string",
          "null"
        ]
      },
      "subnetsByFailureDomain": {
        "additionalProperties": {
          "$ref": "#/definitions/AwsFailureDomainSubnets"
        },
        "description": "Exact subnet membership keyed by real availability zone.",
        "type": "object"
      },
      "vpcId": {
        "description": "VPC ID. Absent when default-VPC mode defers lookup to AWS at runtime.",
        "type": [
          "string",
          "null"
        ]
      }
    },
    "required": [
      "availabilityZones",
      "isByoVpc",
      "privateSubnetIds",
      "publicSubnetIds"
    ],
    "title": "AwsNetworkImportData",
    "type": "object"
  },
  "aws_postgres": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "description": "AWS Postgres (Aurora Serverless v2) registration data: the handles by which a setup-created Aurora cluster is registered as a Frozen Postgres resource. Setup owns the cluster, Alien refreshes and heartbeats it. Carries the master password's Secrets Manager ARN, never the password.",
    "properties": {
      "clusterEndpoint": {
        "description": "Cluster writer endpoint (the binding host).",
        "type": "string"
      },
      "clusterIdentifier": {
        "description": "Aurora DB cluster identifier.",
        "type": "string"
      },
      "database": {
        "description": "Default database name.",
        "type": "string"
      },
      "engineVersion": {
        "description": "Engine version the cluster reports.",
        "type": "string"
      },
      "instanceIdentifier": {
        "description": "Writer instance identifier within the cluster.",
        "type": "string"
      },
      "passwordSecretArn": {
        "description": "Secrets Manager ARN of the master password (never the password itself).",
        "type": "string"
      },
      "securityGroupId": {
        "description": "Dedicated security group admitting 5432 from the stack security group.",
        "type": "string"
      },
      "subnetGroupName": {
        "description": "DB subnet group spanning the private subnets.",
        "type": "string"
      },
      "username": {
        "description": "Master username.",
        "type": "string"
      }
    },
    "required": [
      "clusterEndpoint",
      "clusterIdentifier",
      "database",
      "engineVersion",
      "instanceIdentifier",
      "passwordSecretArn",
      "securityGroupId",
      "subnetGroupName",
      "username"
    ],
    "title": "AwsPostgresImportData",
    "type": "object"
  },

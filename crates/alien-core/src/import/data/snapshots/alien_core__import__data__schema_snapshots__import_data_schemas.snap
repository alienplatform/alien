{
  "aws_artifact_registry": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "additionalProperties": false,
    "description": "AWS ArtifactRegistry ImportData.",
    "properties": {
      "accountId": {
        "description": "AWS account ID that owns the ECR registry.",
        "type": "string"
      },
      "pullRoleArn": {
        "description": "IAM role ARN with pull-only access.",
        "type": "string"
      },
      "pushRoleArn": {
        "description": "IAM role ARN with push and pull access.",
        "type": "string"
      },
      "region": {
        "description": "AWS region for the registry endpoint.",
        "type": "string"
      },
      "registryEndpoint": {
        "description": "Docker registry endpoint.",
        "type": "string"
      },
      "registryId": {
        "description": "Registry identifier in `account:region` form.",
        "type": "string"
      },
      "repositoryPrefix": {
        "description": "Prefix used for repositories owned by this stack.",
        "type": "string"
      }
    },
    "required": [
      "accountId",
      "pullRoleArn",
      "pushRoleArn",
      "region",
      "registryEndpoint",
      "registryId",
      "repositoryPrefix"
    ],
    "title": "AwsArtifactRegistryImportData",
    "type": "object"
  },

=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = ">= 3.100"
    }
    kubernetes = {
      source  = "hashicorp/kubernetes"
      version = ">= 2.30"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "resource_prefix" {
  type        = string
  description = "Optional stable physical resource prefix. Leave empty to generate one."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || (can(regex("^[a-z][a-z0-9-]{1,38}[a-z0-9]$", var.resource_prefix)) && length(regexall("--", var.resource_prefix)) == 0)
    error_message = "resource_prefix must be 3-40 characters: lowercase letters, numbers, and hyphens; start with a letter; end with a letter or number; and not contain consecutive hyphens."
  }
}

variable "name" {
  type        = string
  description = "Human-readable application name shown in setup and cloud IAM review metadata."
}

variable "token" {
  type        = string
  description = "Install token from the application setup page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "stack_settings_json" {
  type        = string
  description = "Optional JSON-encoded StackSettings override supplied by deployment installers."
  default     = "{}"
  sensitive   = true
}

variable "azure_location" {
  type        = string
  description = "Azure location."
  default     = "eastus"
}

variable "azure_subscription_id" {
  type        = string
  description = "Azure subscription ID hosting the stack."
}

variable "azure_resource_group_name" {
  type        = string
  description = "Azure resource group name."
}

variable "azure_managing_tenant_id" {
  type        = string
  description = "Azure tenant ID the manager uses for cross-tenant access."
}

variable "azure_oidc_issuer" {
  type        = string
  description = "OIDC issuer URL for Azure Federated Identity Credential."
}

variable "azure_oidc_subject" {
  type        = string
  description = "OIDC subject claim for Azure Federated Identity Credential."
}

variable "kubernetes_cluster_mode" {
  type        = string
  description = "Kubernetes cluster mode. Values: create or existing."
  default     = "create"
}

variable "install_metrics_server" {
  type        = bool
  description = "Whether to install metrics-server into Kubernetes clusters created by this module."
  default     = true
}

variable "kubernetes_namespace" {
  type        = string
  description = "Kubernetes namespace for runtime resources."
  default     = "default"
}

variable "aks_cluster_name" {
  type        = string
  description = "Existing AKS cluster name that Helm will install into."
  default     = ""
}

variable "aks_cluster_resource_group_name" {
  type        = string
  description = "Resource group containing the existing AKS cluster."
  default     = ""
}

=== providers.tf ===
provider "azurerm" {
  resource_provider_registrations = "none"

  features {}
}

provider "kubernetes" {
  host                   = data.azurerm_kubernetes_cluster.target.kube_config[0].host
  cluster_ca_certificate = base64decode(data.azurerm_kubernetes_cluster.target.kube_config[0].cluster_ca_certificate)
  client_certificate     = base64decode(data.azurerm_kubernetes_cluster.target.kube_config[0].client_certificate)
  client_key             = base64decode(data.azurerm_kubernetes_cluster.target.kube_config[0].client_key)
}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 4
}

=== locals.tf ===
locals {
  resource_prefix          = var.resource_prefix == "" ? format("a%s", random_id.resource_prefix.hex) : var.resource_prefix
  deployment_name          = var.name
  deployment_platform      = "kubernetes"
  deployment_base_platform = "azure"
  deployment_target        = "aks"
  deployment_region        = var.azure_location
  deployment_management_config = {
    platform         = "azure"
    managingTenantId = var.azure_managing_tenant_id
    oidcIssuer       = var.azure_oidc_issuer
    oidcSubject      = var.azure_oidc_subject
  }
  deployment_kubernetes_settings = merge(try(jsondecode(var.stack_settings_json).kubernetes, {}), { exposure = coalesce(try(jsondecode(var.stack_settings_json).kubernetes.exposure, null), local.kubernetes_exposure) })
  deployment_settings            = merge(jsondecode(var.stack_settings_json), { kubernetes = local.deployment_kubernetes_settings })
  deployment_resources = [
    {
      id   = "kubernetes"
      type = "kubernetes-cluster"
      importData = {
        provider           = "aks"
        ownership          = var.kubernetes_cluster_mode == "create" ? "managed" : "managed"
        namespace          = var.kubernetes_namespace
        clusterName        = local.kubernetes_cluster_name
        clusterId          = local.kubernetes_cluster_name
        cloudMetadataReady = true
      }
    }
  ]
  kubernetes_cluster_name = var.kubernetes_cluster_mode == "create" ? azurerm_kubernetes_cluster.kubernetes[0].name : var.aks_cluster_name
  kubernetes_kube_context = local.kubernetes_cluster_name
  kubernetes_kubeconfig   = var.kubernetes_cluster_mode == "create" ? azurerm_kubernetes_cluster.kubernetes[0].kube_config_raw : ""
  kubernetes_exposure = {
    mode = "generated"
    route = {
      routeApi         = "gateway"
      controller       = "alb.networking.azure.io/alb-controller"
      gatewayClassName = "azure-alb-external"
      listenerPort     = 443
      labels           = {}
      annotations      = {}
      provider = {
        provider = "azureApplicationGatewayForContainers"
        frontend = "public"
      }
    }
    certificate = {
      mode               = "managedTlsSecret"
      secretNameTemplate = "alien-{{ resourceId }}-tls"
    }
  }
  helm_service_accounts = {}
  helm_manager_service_account = {
    annotations = {}
    labels      = {}
  }
  helm_values = {
    serviceAccounts       = local.helm_service_accounts
    managerServiceAccount = local.helm_manager_service_account
    stackSettings         = local.deployment_settings
    basePlatform          = local.deployment_base_platform
    serviceAccountPrefix  = local.resource_prefix
    heartbeat = {
      collection = {
        nodes = {
          enabled = true
        }
      }
    }
  }
}

=== kubernetes.tf ===
data "azurerm_kubernetes_cluster" "target" {
  name                = local.kubernetes_cluster_name
  resource_group_name = var.kubernetes_cluster_mode == "create" ? var.azure_resource_group_name : var.aks_cluster_resource_group_name
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes
  ]
}

data "azurerm_kubernetes_cluster" "kubernetes_existing" {
  count               = var.kubernetes_cluster_mode == "existing" ? 1 : 0
  name                = var.aks_cluster_name
  resource_group_name = var.aks_cluster_resource_group_name
}

resource "azurerm_kubernetes_cluster" "kubernetes" {
  count                     = var.kubernetes_cluster_mode == "create" ? 1 : 0
  name                      = "${local.resource_prefix}-k8s"
  location                  = var.azure_location
  resource_group_name       = var.azure_resource_group_name
  dns_prefix                = "${local.resource_prefix}-k8s"
  oidc_issuer_enabled       = true
  workload_identity_enabled = true

  default_node_pool {
    name       = "default"
    node_count = 3
    vm_size    = "Standard_D2s_v3"
  }

  identity {
    type = "SystemAssigned"
  }

  azure_active_directory_role_based_access_control {
    azure_rbac_enabled = true
    tenant_id          = var.azure_managing_tenant_id
  }

  network_profile {
    network_plugin    = "azure"
    load_balancer_sku = "standard"
  }

  sku_tier = "Standard"
}

resource "kubernetes_manifest" "kubernetes_metrics_server_service_account" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "v1"
    kind       = "ServiceAccount"
    metadata = {
      name      = "metrics-server"
      namespace = "kube-system"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
  }
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_aggregated_metrics_reader" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "rbac.authorization.k8s.io/v1"
    kind       = "ClusterRole"
    metadata = {
      name = "system:aggregated-metrics-reader"
      labels = {
        "rbac.authorization.k8s.io/aggregate-to-admin" = "true"
        "rbac.authorization.k8s.io/aggregate-to-edit"  = "true"
        "rbac.authorization.k8s.io/aggregate-to-view"  = "true"
      }
    }
    rules = [
      {
        apiGroups = [
          "metrics.k8s.io"
        ]
        resources = [
          "pods",
          "nodes"
        ]
        verbs = [
          "get",
          "list",
          "watch"
        ]
      }
    ]
  }
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_cluster_role" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "rbac.authorization.k8s.io/v1"
    kind       = "ClusterRole"
    metadata = {
      name = "system:metrics-server"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    rules = [
      {
        apiGroups = [
          ""
        ]
        resources = [
          "nodes/metrics"
        ]
        verbs = [
          "get"
        ]
      },
      {
        apiGroups = [
          ""
        ]
        resources = [
          "pods",
          "nodes"
        ]
        verbs = [
          "get",
          "list",
          "watch"
        ]
      }
    ]
  }
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_auth_reader_role_binding" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "rbac.authorization.k8s.io/v1"
    kind       = "RoleBinding"
    metadata = {
      name      = "metrics-server-auth-reader"
      namespace = "kube-system"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    roleRef = {
      apiGroup = "rbac.authorization.k8s.io"
      kind     = "Role"
      name     = "extension-apiserver-authentication-reader"
    }
    subjects = [
      {
        kind      = "ServiceAccount"
        name      = "metrics-server"
        namespace = "kube-system"
      }
    ]
  }
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_auth_delegator_binding" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "rbac.authorization.k8s.io/v1"
    kind       = "ClusterRoleBinding"
    metadata = {
      name = "metrics-server:system:auth-delegator"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    roleRef = {
      apiGroup = "rbac.authorization.k8s.io"
      kind     = "ClusterRole"
      name     = "system:auth-delegator"
    }
    subjects = [
      {
        kind      = "ServiceAccount"
        name      = "metrics-server"
        namespace = "kube-system"
      }
    ]
  }
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_cluster_role_binding" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "rbac.authorization.k8s.io/v1"
    kind       = "ClusterRoleBinding"
    metadata = {
      name = "system:metrics-server"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    roleRef = {
      apiGroup = "rbac.authorization.k8s.io"
      kind     = "ClusterRole"
      name     = "system:metrics-server"
    }
    subjects = [
      {
        kind      = "ServiceAccount"
        name      = "metrics-server"
        namespace = "kube-system"
      }
    ]
  }
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_service" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "v1"
    kind       = "Service"
    metadata = {
      name      = "metrics-server"
      namespace = "kube-system"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    spec = {
      selector = {
        "k8s-app" = "metrics-server"
      }
      ports = [
        {
          name       = "https"
          port       = 443
          protocol   = "TCP"
          targetPort = "https"
        }
      ]
    }
  }
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_deployment" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "apps/v1"
    kind       = "Deployment"
    metadata = {
      name      = "metrics-server"
      namespace = "kube-system"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    spec = {
      selector = {
        matchLabels = {
          "k8s-app" = "metrics-server"
        }
      }
      strategy = {
        rollingUpdate = {
          maxUnavailable = 0
        }
      }
      template = {
        metadata = {
          labels = {
            "k8s-app" = "metrics-server"
          }
        }
        spec = {
          serviceAccountName = "metrics-server"
          priorityClassName  = "system-cluster-critical"
          containers = [
            {
              name  = "metrics-server"
              image = "registry.k8s.io/metrics-server/metrics-server:v0.8.1"
              args = [
                "--cert-dir=/tmp",
                "--secure-port=10250",
                "--kubelet-preferred-address-types=InternalIP,ExternalIP,Hostname",
                "--kubelet-use-node-status-port",
                "--metric-resolution=15s"
              ]
              ports = [
                {
                  name          = "https"
                  containerPort = 10250
                  protocol      = "TCP"
                }
              ]
              resources = {
                requests = {
                  cpu    = "100m"
                  memory = "200Mi"
                }
              }
              volumeMounts = [
                {
                  name      = "tmp-dir"
                  mountPath = "/tmp"
                }
              ]
            }
          ]
          volumes = [
            {
              name     = "tmp-dir"
              emptyDir = {}
            }
          ]
        }
      }
    }
  }
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_api_service" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "apiregistration.k8s.io/v1"
    kind       = "APIService"
    metadata = {
      name = "v1beta1.metrics.k8s.io"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    spec = {
      group                 = "metrics.k8s.io"
      version               = "v1beta1"
      groupPriorityMinimum  = 100
      versionPriority       = 100
      insecureSkipTLSVerify = true
      service = {
        name      = "metrics-server"
        namespace = "kube-system"
      }
    }
  }
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes
  ]
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                    = local.deployment_platform
    token                       = var.token
    name                        = var.name
    resource_prefix             = local.resource_prefix
    setup_target                = ""
    setup_import_format_version = 1
    setup_fingerprint           = ""
    setup_fingerprint_version   = 0
    manager_url                 = var.manager_url
    management_config           = local.deployment_management_config
    stack_settings              = local.deployment_settings
    resources                   = local.deployment_resources
    basePlatform                = local.deployment_base_platform
  }
  depends_on = [
    azurerm_kubernetes_cluster.kubernetes,
    kubernetes_manifest.kubernetes_metrics_server_service_account,
    kubernetes_manifest.kubernetes_metrics_server_aggregated_metrics_reader,
    kubernetes_manifest.kubernetes_metrics_server_cluster_role,
    kubernetes_manifest.kubernetes_metrics_server_auth_reader_role_binding,
    kubernetes_manifest.kubernetes_metrics_server_auth_delegator_binding,
    kubernetes_manifest.kubernetes_metrics_server_cluster_role_binding,
    kubernetes_manifest.kubernetes_metrics_server_service,
    kubernetes_manifest.kubernetes_metrics_server_deployment,
    kubernetes_manifest.kubernetes_metrics_server_api_service
  ]
}


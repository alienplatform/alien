---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 5.0"
    }
  }
}

=== variables.tf ===
variable "stack_name" {
  type        = string
  description = "Stable physical-name prefix for resources created by this module."
}

variable "deployment_group_token" {
  type        = string
  description = "Deployment group token used when registering the resolved stack import."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "gcp_project" {
  type        = string
  description = "GCP project ID."
}

variable "gcp_region" {
  type        = string
  description = "GCP region."
  default     = "us-central1"
}

variable "managing_service_account_email" {
  type        = string
  description = "Email of the manager's service account that may impersonate the management identity. Empty disables the binding."
  default     = ""
}

=== providers.tf ===
provider "google" {
  project = var.gcp_project
  region  = var.gcp_region
}

=== locals.tf ===
locals {
  alien_platform = "gcp"
  alien_target   = "gcp"
  alien_management_config = {
    platform            = "gcp"
    projectId           = var.gcp_project
    serviceAccountEmail = var.managing_service_account_email
  }
  alien_stack_settings = {}
  alien_resources = [
    {
      id   = "management"
      type = "remote-stack-management"
      importData = {
        projectId                    = var.gcp_project
        serviceAccountEmail          = google_service_account.management.email
        serviceAccountUniqueId       = google_service_account.management.unique_id
        managementPermissionsApplied = true
      }
    }
  ]
}

=== management.tf ===
resource "google_service_account" "management" {
  project      = var.gcp_project
  account_id   = format("%s-%s", trim(substr(replace(lower(format("a-%s-management", var.stack_name)), "_", "-"), 0, 21), "-"), substr(sha1(replace(lower(format("%s-management", var.stack_name)), "_", "-")), 0, 8))
  display_name = "Alien stack management identity"
  description  = "${var.stack_name} cross-account management service account"
}

resource "google_project_iam_custom_role" "management_functionmanagement" {
  project     = var.gcp_project
  role_id     = format("%s_management_functionManagement_%s", substr(replace(var.stack_name, "-", "_"), 0, 12), substr(sha1(format("%s-management-functionManagement", var.stack_name)), 0, 8))
  title       = "Function Management"
  description = "Allows managing function configuration, versions, aliases, and monitoring"
  stage       = "GA"
  permissions = [
    "run.services.get",
    "run.services.list",
    "run.services.getIamPolicy",
    "run.revisions.get",
    "run.revisions.list",
    "run.operations.get",
    "run.operations.list",
    "run.locations.list",
    "run.configurations.get",
    "run.configurations.list",
    "run.routes.get",
    "run.routes.list",
    "run.executions.get",
    "run.executions.list",
    "run.tasks.get",
    "run.tasks.list",
    "run.services.listEffectiveTags",
    "run.services.listTagBindings",
    "resourcemanager.projects.get",
    "run.services.update",
    "run.services.setIamPolicy",
    "run.jobs.update",
    "run.jobs.getIamPolicy",
    "run.jobs.setIamPolicy",
    "run.operations.delete",
    "run.revisions.delete",
    "run.executions.delete",
    "run.services.createTagBinding",
    "run.services.deleteTagBinding",
    "run.jobs.createTagBinding",
    "run.jobs.deleteTagBinding",
    "iam.serviceAccounts.actAs",
    "pubsub.subscriptions.get",
    "pubsub.subscriptions.update",
    "iam.serviceAccounts.getIamPolicy",
    "iam.serviceAccounts.setIamPolicy",
    "compute.sslCertificates.create",
    "compute.sslCertificates.delete",
    "compute.sslCertificates.get",
    "compute.networkEndpointGroups.create",
    "compute.networkEndpointGroups.delete",
    "compute.networkEndpointGroups.get",
    "compute.backendServices.create",
    "compute.backendServices.delete",
    "compute.backendServices.get",
    "compute.backendServices.update",
    "compute.urlMaps.create",
    "compute.urlMaps.delete",
    "compute.urlMaps.get",
    "compute.targetHttpsProxies.create",
    "compute.targetHttpsProxies.delete",
    "compute.targetHttpsProxies.get",
    "compute.globalAddresses.create",
    "compute.globalAddresses.delete",
    "compute.globalAddresses.get",
    "compute.globalForwardingRules.create",
    "compute.globalForwardingRules.delete",
    "compute.globalForwardingRules.get"
  ]
}

resource "google_project_iam_member" "management_functionmanagement_binding_0" {
  project = var.gcp_project
  role    = google_project_iam_custom_role.management_functionmanagement.name
  member  = "serviceAccount:${google_service_account.management.email}"
}

resource "google_project_iam_custom_role" "management_storageheartbeat" {
  project     = var.gcp_project
  role_id     = format("%s_management_storageHeartbeat_%s", substr(replace(var.stack_name, "-", "_"), 0, 12), substr(sha1(format("%s-management-storageHeartbeat", var.stack_name)), 0, 8))
  title       = "Storage Heartbeat"
  description = "Allows readonly monitoring and health checks for storage resources"
  stage       = "GA"
  permissions = [
    "storage.buckets.get",
    "storage.buckets.getIamPolicy",
    "storage.managedFolders.get",
    "storage.managedFolders.list",
    "storage.managedFolders.getIamPolicy",
    "storage.bucketOperations.get",
    "storage.bucketOperations.list",
    "storage.hmacKeys.get",
    "storage.hmacKeys.list"
  ]
}

resource "google_project_iam_member" "management_storageheartbeat_binding_0" {
  project = var.gcp_project
  role    = google_project_iam_custom_role.management_storageheartbeat.name
  member  = "serviceAccount:${google_service_account.management.email}"
}

resource "google_service_account_iam_member" "management_manager_token_creator" {
  for_each           = toset(compact([var.managing_service_account_email]))
  service_account_id = google_service_account.management.id
  role               = "roles/iam.serviceAccountTokenCreator"
  member             = "serviceAccount:${each.value}"
}

resource "google_service_account_iam_member" "management_manager_user" {
  for_each           = toset(compact([var.managing_service_account_email]))
  service_account_id = google_service_account.management.id
  role               = "roles/iam.serviceAccountUser"
  member             = "serviceAccount:${each.value}"
}

=== import.tf ===
resource "terraform_data" "alien_stack_import" {
  input = {
    platform               = local.alien_platform
    deployment_group_token = var.deployment_group_token
    manager_url            = var.manager_url
    management_config      = local.alien_management_config
    stack_settings         = local.alien_stack_settings
    resources              = local.alien_resources
  }
}

=== outputs.tf ===
output "alien_target" {
  value       = "gcp"
  description = "Terraform module target."
}

output "alien_platform" {
  value       = local.alien_platform
  description = "Target platform."
}

output "alien_management_config" {
  value       = jsonencode(local.alien_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "alien_stack_settings" {
  value       = jsonencode(local.alien_stack_settings)
  description = "Manager import StackSettings JSON."
}

output "alien_resources" {
  value       = jsonencode(local.alien_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-mgmt

Target: `gcp`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='stack_name=acme-mgmt' -var='deployment_group_token=...'
```

Outputs `alien_management_config` / `alien_stack_settings` / `alien_resources` for registration via `alien_deployment` (T11) or `alien-deploy register`.

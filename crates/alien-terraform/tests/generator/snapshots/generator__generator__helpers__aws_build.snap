---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

=== variables.tf ===
variable "stack_name" {
  type        = string
  description = "Stable physical-name prefix for resources created by this module."
}

variable "deployment_name" {
  type        = string
  description = "Deployment name used when registering the resolved stack import. Defaults to stack_name."
  default     = ""
}

variable "deployment_group_token" {
  type        = string
  description = "Deployment group token used when registering the resolved stack import."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "aws_region" {
  type        = string
  description = "AWS region used by the AWS provider."
  default     = "us-east-1"
}

variable "managing_role_arn" {
  type        = string
  description = "ARN of the manager IAM identity allowed to assume management roles."
  default     = ""
}

variable "managing_account_id" {
  type        = string
  description = "AWS account ID hosting the manager. Referenced by stack-side IAM policies that scope cross-account ECR pulls. Empty disables those grants."
  default     = ""
}

=== providers.tf ===
provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

=== locals.tf ===
locals {
  alien_platform = "aws"
  alien_target   = "aws"
  alien_region   = data.aws_region.current.region
  alien_management_config = {
    platform        = "aws"
    managingRoleArn = data.aws_caller_identity.current.arn
  }
  alien_stack_settings = {}
  alien_resources = [
    {
      id   = "builder"
      type = "build"
      import_data = {
        projectName = aws_codebuild_project.builder.name
        projectArn  = aws_codebuild_project.builder.arn
        buildEnvVars = {
          PROFILE = "release"
        }
      }
    }
  ]
}

=== builder.tf ===
resource "aws_iam_role" "builder_role" {
  name               = "${var.stack_name}-builder-build"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { Service = "codebuild.amazonaws.com" }, Action = "sts:AssumeRole" }] })
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "builder"
    AlienResourceType = "build"
  }

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_iam_role_policy" "builder_role_logs" {
  name   = "alien-managed-policy"
  role   = aws_iam_role.builder_role.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "WriteLogs", Effect = "Allow", Action = ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"], Resource = "*" }] })

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_cloudwatch_log_group" "builder_logs" {
  name              = "/aws/codebuild/${var.stack_name}-builder"
  retention_in_days = 30
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "builder"
    AlienResourceType = "build"
  }

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_codebuild_project" "builder" {
  name         = "${var.stack_name}-builder"
  service_role = aws_iam_role.builder_role.arn

  artifacts {
    type = "NO_ARTIFACTS"
  }

  environment {
    type            = "LINUX_CONTAINER"
    image           = "aws/codebuild/standard:7.0"
    compute_type    = "BUILD_GENERAL1_MEDIUM"
    privileged_mode = true

    environment_variable {
      name  = "PROFILE"
      value = "release"
      type  = "PLAINTEXT"
    }
  }

  source {
    type      = "NO_SOURCE"
    buildspec = "version: 0.2\nphases:\n  build:\n    commands:\n      - echo \"Build project is ready for runtime-provided commands\"\n"
  }

  logs_config {
    cloudwatch_logs {
      status     = "ENABLED"
      group_name = aws_cloudwatch_log_group.builder_logs.name
    }
  }

  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "builder"
    AlienResourceType = "build"
  }

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

=== import.tf ===
resource "terraform_data" "alien_stack_import" {
  input = {
    platform               = local.alien_platform
    deployment_group_token = var.deployment_group_token
    manager_url            = var.manager_url
    management_config      = local.alien_management_config
    stack_settings         = local.alien_stack_settings
    resources              = local.alien_resources
  }
}

=== outputs.tf ===
output "alien_target" {
  value       = "aws"
  description = "Terraform module target."
}

output "alien_platform" {
  value       = local.alien_platform
  description = "Target platform."
}

output "alien_region" {
  value       = local.alien_region
  description = "Target cloud region or location."
}

output "alien_management_config" {
  value       = jsonencode(local.alien_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "alien_stack_settings" {
  value       = jsonencode(local.alien_stack_settings)
  description = "Manager import StackSettings JSON."
}

output "alien_resources" {
  value       = jsonencode(local.alien_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-build

Target: `aws`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='stack_name=acme-build' -var='deployment_group_token=...'
```

Self-registering distributions create `alien_deployment.this`; other renderers can use `alien_management_config` / `alien_stack_settings` / `alien_resources` with their own registration flow.

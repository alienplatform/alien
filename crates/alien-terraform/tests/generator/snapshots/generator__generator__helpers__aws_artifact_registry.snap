---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

=== variables.tf ===
variable "stack_name" {
  type        = string
  description = "Stable physical-name prefix for resources created by this module."
}

variable "deployment_group_token" {
  type        = string
  description = "Deployment group token used when registering the resolved stack import."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "aws_region" {
  type        = string
  description = "AWS region used by the AWS provider."
  default     = "us-east-1"
}

variable "managing_role_arn" {
  type        = string
  description = "ARN of the manager IAM identity allowed to assume management roles."
  default     = ""
}

variable "managing_account_id" {
  type        = string
  description = "AWS account ID hosting the manager. Referenced by stack-side IAM policies that scope cross-account ECR pulls. Empty disables those grants."
  default     = ""
}

=== providers.tf ===
provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

=== locals.tf ===
locals {
  alien_platform = "aws"
  alien_target   = "aws"
  alien_management_config = {
    platform        = "aws"
    managingRoleArn = data.aws_caller_identity.current.arn
  }
  alien_stack_settings = {}
  alien_resources = [
    {
      id   = "registry"
      type = "artifact-registry"
      importData = {
        accountId        = data.aws_caller_identity.current.account_id
        region           = data.aws_region.current.region
        registryId       = "${data.aws_caller_identity.current.account_id}:${data.aws_region.current.region}"
        registryEndpoint = aws_ecr_repository.registry.registry_id
        repositoryPrefix = "${var.stack_name}-registry"
        pullRoleArn      = aws_iam_role.registry_pull.arn
        pushRoleArn      = aws_iam_role.registry_push.arn
      }
    }
  ]
}

=== registry.tf ===
resource "aws_ecr_repository" "registry" {
  name                 = "${var.stack_name}-registry"
  image_tag_mutability = "IMMUTABLE"

  image_scanning_configuration {
    scan_on_push = true
  }

  encryption_configuration {
    encryption_type = "AES256"
  }

  force_delete = false
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "registry"
    AlienResourceType = "artifact-registry"
  }

  lifecycle {
    prevent_destroy = false
  }
}

resource "aws_ecr_lifecycle_policy" "registry" {
  repository = aws_ecr_repository.registry.name
  policy     = jsonencode({ rules = [{ rulePriority = 1, description = "Retain the 100 most recent images", selection = { tagStatus = "any", countType = "imageCountMoreThan", countNumber = 100 }, action = { type = "expire" } }] })
}

resource "aws_iam_role" "registry_pull" {
  name               = "${var.stack_name}-registry-pull"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { AWS = var.managing_role_arn }, Action = "sts:AssumeRole" }] })
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "registry"
    AlienResourceType = "artifact-registry"
  }
}

resource "aws_iam_role" "registry_push" {
  name               = "${var.stack_name}-registry-push"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { AWS = var.managing_role_arn }, Action = "sts:AssumeRole" }] })
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "registry"
    AlienResourceType = "artifact-registry"
  }
}

resource "aws_iam_role_policy" "registry_pull_policy" {
  name   = "ecr-pull"
  role   = aws_iam_role.registry_pull.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "GetAuthorizationToken", Effect = "Allow", Action = "ecr:GetAuthorizationToken", Resource = "*" }, { Sid = "RepositoryAccess", Effect = "Allow", Action = ["ecr:BatchCheckLayerAvailability", "ecr:BatchGetImage", "ecr:DescribeImages", "ecr:DescribeRepositories", "ecr:GetDownloadUrlForLayer", "ecr:ListImages"], Resource = aws_ecr_repository.registry.arn }] })
}

resource "aws_iam_role_policy" "registry_push_policy" {
  name   = "ecr-push-pull"
  role   = aws_iam_role.registry_push.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "GetAuthorizationToken", Effect = "Allow", Action = "ecr:GetAuthorizationToken", Resource = "*" }, { Sid = "RepositoryAccess", Effect = "Allow", Action = ["ecr:BatchCheckLayerAvailability", "ecr:BatchGetImage", "ecr:DescribeImages", "ecr:DescribeRepositories", "ecr:GetDownloadUrlForLayer", "ecr:ListImages", "ecr:CompleteLayerUpload", "ecr:InitiateLayerUpload", "ecr:PutImage", "ecr:UploadLayerPart"], Resource = aws_ecr_repository.registry.arn }] })
}

=== import.tf ===
resource "terraform_data" "alien_stack_import" {
  input = {
    platform               = local.alien_platform
    deployment_group_token = var.deployment_group_token
    manager_url            = var.manager_url
    management_config      = local.alien_management_config
    stack_settings         = local.alien_stack_settings
    resources              = local.alien_resources
  }
}

=== outputs.tf ===
output "alien_target" {
  value       = "aws"
  description = "Terraform module target."
}

output "alien_platform" {
  value       = local.alien_platform
  description = "Target platform."
}

output "alien_management_config" {
  value       = jsonencode(local.alien_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "alien_stack_settings" {
  value       = jsonencode(local.alien_stack_settings)
  description = "Manager import StackSettings JSON."
}

output "alien_resources" {
  value       = jsonencode(local.alien_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-ecr

Target: `aws`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='stack_name=acme-ecr' -var='deployment_group_token=...'
```

Outputs `alien_management_config` / `alien_stack_settings` / `alien_resources` for registration via `alien_deployment` (T11) or `alien-deploy register`.

---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 5.0"
    }
    time = {
      source  = "hashicorp/time"
      version = ">= 0.9"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "resource_prefix" {
  type        = string
  description = "Optional stable physical resource prefix. Leave empty to generate one."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || (can(regex("^[a-z][a-z0-9-]{1,38}[a-z0-9]$", var.resource_prefix)) && length(regexall("--", var.resource_prefix)) == 0)
    error_message = "resource_prefix must be 3-40 characters: lowercase letters, numbers, and hyphens; start with a letter; end with a letter or number; and not contain consecutive hyphens."
  }
}

variable "name" {
  type        = string
  description = "Human-readable deployment name shown in the deployment portal."
}

variable "token" {
  type        = string
  description = "Deployment token from the deployment page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "stack_settings_json" {
  type        = string
  description = "Optional JSON-encoded StackSettings override supplied by deployment installers."
  default     = "{}"
  sensitive   = true
}

variable "gcp_project" {
  type        = string
  description = "GCP project ID."
}

variable "gcp_region" {
  type        = string
  description = "GCP region."
  default     = "us-central1"
}

variable "managing_service_account_email" {
  type        = string
  description = "Email of the manager's service account that may impersonate the management identity. Empty disables the binding."
  default     = ""
}

variable "kubernetes_namespace" {
  type        = string
  description = "Kubernetes namespace for runtime resources."
  default     = "default"
}

variable "gke_cluster_name" {
  type        = string
  description = "Existing GKE cluster name that Helm will install into."
}

variable "gke_cluster_location" {
  type        = string
  description = "Existing GKE cluster location (region or zone)."
}

=== providers.tf ===
provider "google" {
  project = var.gcp_project
  region  = var.gcp_region
}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 4
}

=== locals.tf ===
locals {
  resource_prefix          = var.resource_prefix == "" ? format("a%s", random_id.resource_prefix.hex) : var.resource_prefix
  deployment_platform      = "kubernetes"
  deployment_base_platform = "gcp"
  deployment_target        = "gke"
  deployment_region        = var.gcp_region
  deployment_management_config = {
    platform            = "gcp"
    projectId           = var.gcp_project
    serviceAccountEmail = var.managing_service_account_email
  }
  deployment_settings = jsondecode(var.stack_settings_json)
  deployment_resources = [
    {
      id   = "data"
      type = "storage"
      importData = {
        bucketName     = google_storage_bucket.data.name
        bucketSelfLink = google_storage_bucket.data.self_link
        projectId      = var.gcp_project
        location       = google_storage_bucket.data.location
      }
    },
    {
      id   = "execution-sa"
      type = "service-account"
      importData = {
        projectId               = var.gcp_project
        serviceAccountEmail     = google_service_account.execution_sa.email
        serviceAccountUniqueId  = google_service_account.execution_sa.unique_id
        stackPermissionsApplied = true
      }
    }
  ]
  alien_kubernetes_namespace = var.kubernetes_namespace
  helm_service_accounts = {
    execution_sa = {
      annotations = {
        "iam.gke.io/gcp-service-account" = google_service_account.execution_sa.email
      }
      labels = {}
    }
  }
  helm_values = {
    serviceAccounts      = local.helm_service_accounts
    stackSettings        = local.deployment_settings
    basePlatform         = local.deployment_base_platform
    serviceAccountPrefix = local.resource_prefix
  }
}

=== data.tf ===
resource "google_storage_bucket" "data" {
  name                        = "${local.resource_prefix}-data"
  project                     = var.gcp_project
  location                    = upper(var.gcp_region)
  storage_class               = "STANDARD"
  uniform_bucket_level_access = true
  force_destroy               = true
  public_access_prevention    = "enforced"
  labels = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "data"
    "resource-type" = "storage"
  }
}

=== execution_sa.tf ===
data "google_container_cluster" "target" {
  name     = var.gke_cluster_name
  location = var.gke_cluster_location
}

resource "google_service_account" "execution_sa" {
  project      = var.gcp_project
  account_id   = format("%s-%s", trim(substr(replace(lower(format("a-%s-execution_sa", local.resource_prefix)), "_", "-"), 0, 21), "-"), substr(sha1(replace(lower(format("%s-execution_sa", local.resource_prefix)), "_", "-")), 0, 8))
  display_name = "Deployment execution-sa service account"
  description  = "${local.resource_prefix} deployment service account for permission profile 'execution_sa'"
}

resource "google_project_iam_custom_role" "gcp_role_storage_data_read_part1" {
  project     = var.gcp_project
  role_id     = format("role_%s_storage_data_read_part1", substr(replace(lower(local.resource_prefix), "-", "_"), 0, 18))
  title       = "gke-overlay: Storage data read (part 1)"
  description = "Allows reading data from storage buckets and containers. Stack: gke-overlay. Deployment prefix: ${local.resource_prefix}. Permission set: storage/data-read."
  stage       = "GA"
  permissions = [
    "storage.buckets.get",
    "storage.buckets.list",
    "storage.multipartUploads.list",
    "storage.multipartUploads.listParts",
    "storage.objects.get",
    "storage.objects.getIamPolicy",
    "storage.objects.list"
  ]
}

resource "google_project_iam_custom_role" "gcp_role_storage_data_read_part2" {
  project     = var.gcp_project
  role_id     = format("role_%s_storage_data_read_part2", substr(replace(lower(local.resource_prefix), "-", "_"), 0, 18))
  title       = "gke-overlay: Storage data read (part 2)"
  description = "Allows reading data from storage buckets and containers. Stack: gke-overlay. Deployment prefix: ${local.resource_prefix}. Permission set: storage/data-read."
  stage       = "GA"
  permissions = [
    "iam.serviceAccounts.signBlob"
  ]
}

resource "google_project_iam_member" "gcp_role_storage_data_read_part1_execution_sa_binding_0" {
  project = var.gcp_project
  role    = google_project_iam_custom_role.gcp_role_storage_data_read_part1.name
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

resource "google_project_iam_member" "gcp_role_storage_data_read_part2_execution_sa_binding_1" {
  project = var.gcp_project
  role    = google_project_iam_custom_role.gcp_role_storage_data_read_part2.name
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

resource "google_service_account_iam_binding" "execution_sa_workload_identity" {
  service_account_id = google_service_account.execution_sa.name
  role               = "roles/iam.workloadIdentityUser"
  members = [
    "serviceAccount:${data.google_container_cluster.target.workload_identity_config[0].workload_pool}[${var.kubernetes_namespace}/execution_sa]"
  ]
}

=== iam_propagation.tf ===
resource "time_sleep" "gcp_iam_propagation" {
  create_duration = "120s"
  depends_on = [
    google_project_iam_member.gcp_role_storage_data_read_part1_execution_sa_binding_0,
    google_project_iam_member.gcp_role_storage_data_read_part2_execution_sa_binding_1
  ]
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                  = local.deployment_platform
    token                     = var.token
    name                      = var.name
    resource_prefix           = local.resource_prefix
    setup_target              = ""
    setup_fingerprint         = ""
    setup_fingerprint_version = 0
    manager_url               = var.manager_url
    management_config         = local.deployment_management_config
    stack_settings            = local.deployment_settings
    resources                 = local.deployment_resources
  }
  depends_on = [
    google_storage_bucket.data,
    google_service_account.execution_sa,
    google_project_iam_custom_role.gcp_role_storage_data_read_part1,
    google_project_iam_custom_role.gcp_role_storage_data_read_part2,
    google_project_iam_member.gcp_role_storage_data_read_part1_execution_sa_binding_0,
    google_project_iam_member.gcp_role_storage_data_read_part2_execution_sa_binding_1,
    google_service_account_iam_binding.execution_sa_workload_identity,
    time_sleep.gcp_iam_propagation
  ]
}

=== outputs.tf ===
output "deployment_target" {
  value       = "gke"
  description = "Terraform module target."
}

output "deployment_resource_prefix" {
  value       = local.resource_prefix
  description = "Physical resource prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_setup_target" {
  value       = ""
  description = "Setup target."
}

output "deployment_setup_fingerprint" {
  value       = ""
  description = "Setup compatibility fingerprint."
}

output "deployment_setup_fingerprint_version" {
  value       = 0
  description = "Setup fingerprint algorithm version."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_stack_settings" {
  value       = jsonencode(local.deployment_settings)
  description = "Manager import StackSettings JSON."
  sensitive   = true
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

output "deployment_base_platform" {
  value       = local.deployment_base_platform
  description = "Base cloud platform for Kubernetes targets."
}

output "helm_values" {
  value       = jsonencode(local.helm_values)
  description = "Helm values JSON for the manager-fetch Kubernetes install."
  sensitive   = true
}

=== README.md ===
# Terraform module - gke-overlay

Target: `gke`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='name=gke-overlay' -var='token=...'
```

This module exposes `deployment_management_config` / `deployment_stack_settings` / `deployment_resources` for external registration flows.

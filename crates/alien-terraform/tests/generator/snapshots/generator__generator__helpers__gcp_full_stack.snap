---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 5.0"
    }
    time = {
      source  = "hashicorp/time"
      version = ">= 0.9"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "resource_prefix" {
  type        = string
  description = "Optional stable physical resource prefix. Leave empty to generate one."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || (can(regex("^[a-z][a-z0-9-]{1,38}[a-z0-9]$", var.resource_prefix)) && length(regexall("--", var.resource_prefix)) == 0)
    error_message = "resource_prefix must be 3-40 characters: lowercase letters, numbers, and hyphens; start with a letter; end with a letter or number; and not contain consecutive hyphens."
  }
}

variable "name" {
  type        = string
  description = "Human-readable application name shown in setup and cloud IAM review metadata."
}

variable "token" {
  type        = string
  description = "Install token from the application setup page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "management_url" {
  type        = string
  description = "Optional management endpoint used by pull-style runtimes."
  default     = ""
}

variable "deployment_model" {
  type        = string
  description = "How runtime updates are delivered after setup."
  default     = "push"

  validation {
    condition     = contains(["push", "pull"], var.deployment_model)
    error_message = "deployment_model must be one of: push, pull."
  }
}

variable "advanced_settings_json" {
  type        = string
  description = "Advanced JSON-encoded deployment settings. Most installations should use the typed variables in this module instead."
  default     = "{}"
  sensitive   = true
}

variable "updates_mode" {
  type        = string
  description = "How application updates are delivered after setup."
  default     = "approval-required"

  validation {
    condition     = contains(["auto", "approval-required"], var.updates_mode)
    error_message = "updates_mode must be one of: auto, approval-required."
  }
}

variable "telemetry_mode" {
  type        = string
  description = "How logs, metrics, and traces are collected."
  default     = "auto"

  validation {
    condition     = contains(["off", "auto", "approval-required"], var.telemetry_mode)
    error_message = "telemetry_mode must be one of: off, auto, approval-required."
  }
}

variable "heartbeats_mode" {
  type        = string
  description = "Whether runtime health checks are enabled."
  default     = "on"

  validation {
    condition     = contains(["off", "on"], var.heartbeats_mode)
    error_message = "heartbeats_mode must be one of: off, on."
  }
}

variable "gcp_project" {
  type        = string
  description = "GCP project ID."
}

variable "gcp_region" {
  type        = string
  description = "GCP region."
  default     = "us-central1"
}

variable "managing_service_account_email" {
  type        = string
  description = "Email of the management service account allowed to impersonate setup-created identities. Empty disables the binding."
  default     = ""
}

variable "gcp_manage_custom_roles" {
  type        = bool
  description = "Whether this module creates the GCP project custom roles it binds. Set to false when those roles are managed outside this stack."
  default     = true
}

variable "gcp_custom_role_prefix" {
  type        = string
  description = "Prefix used for GCP project custom role IDs when gcp_manage_custom_roles is false. Empty uses resource_prefix."
  default     = ""
}

variable "network_mode" {
  type        = string
  description = "Choose whether this setup creates a new network, uses an existing network, or uses the default network. Values: create-new, use-existing, use-default."
  default     = "create-new"
}

variable "network_cidr" {
  type        = string
  description = "CIDR for a newly-created network. Empty uses 10.44.0.0/16."
  default     = ""
}

variable "availability_zones" {
  type        = number
  description = "Reserved for cross-cloud network-mode parity. GCP creates one regional subnet."
  default     = 2
}

variable "network_name" {
  type        = string
  description = "Existing VPC network name. Required when network is use-existing."
  default     = ""
}

variable "subnet_name" {
  type        = string
  description = "Existing subnet name. Required when network is use-existing."
  default     = ""
}

variable "network_region" {
  type        = string
  description = "Existing subnet region. Empty uses gcp_region."
  default     = ""
}

=== providers.tf ===
provider "google" {
  project = var.gcp_project
  region  = var.gcp_region
}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 4
}

=== locals.tf ===
locals {
  resource_prefix              = var.resource_prefix == "" ? format("a%s", random_id.resource_prefix.hex) : var.resource_prefix
  deployment_name              = var.name
  gcp_custom_role_prefix       = substr(replace(lower(var.gcp_custom_role_prefix == "" ? local.resource_prefix : var.gcp_custom_role_prefix), "-", "_"), 0, 18)
  deployment_platform          = "gcp"
  deployment_target            = "gcp"
  deployment_region            = var.gcp_region
  deployment_management_config = var.deployment_model == "push" ? { platform = "gcp", projectId = var.gcp_project, serviceAccountEmail = var.managing_service_account_email } : null
  deployment_settings          = merge(jsondecode(var.advanced_settings_json), { deploymentModel = var.deployment_model, updates = var.updates_mode, telemetry = var.telemetry_mode, heartbeats = var.heartbeats_mode, network = jsondecode(var.network_mode == "create-new" ? jsonencode({ type = "create", cidr = var.network_cidr == "" ? null : var.network_cidr, availabilityZones = var.availability_zones }) : var.network_mode == "use-existing" ? jsonencode({ type = "byo-vpc-gcp", networkName = var.network_name, subnetName = var.subnet_name, region = var.network_region == "" ? var.gcp_region : var.network_region }) : jsonencode({ type = "use-default" })) })
  deployment_resources = [
    {
      id   = "default-network"
      type = "network"
      importData = {
        projectId       = var.gcp_project
        vpcSelfLink     = var.network_mode == "create-new" ? google_compute_network.default_network[0].self_link : var.network_mode == "use-existing" ? data.google_compute_network.default_network[0].self_link : null
        vpcName         = var.network_mode == "create-new" ? google_compute_network.default_network[0].name : var.network_mode == "use-existing" ? data.google_compute_network.default_network[0].name : null
        subnetSelfLinks = var.network_mode == "create-new" ? [google_compute_subnetwork.default_network_workload[0].self_link] : var.network_mode == "use-existing" ? [data.google_compute_subnetwork.default_network_existing_subnet[0].self_link] : []
        cidrBlock       = var.network_mode == "create-new" ? google_compute_subnetwork.default_network_workload[0].ip_cidr_range : var.network_mode == "use-existing" ? data.google_compute_subnetwork.default_network_existing_subnet[0].ip_cidr_range : null
        routerSelfLink  = var.network_mode == "create-new" ? google_compute_router.default_network_router[0].self_link : null
        natName         = var.network_mode == "create-new" ? google_compute_router_nat.default_network_nat[0].name : null
        isByoVpc        = var.network_mode != "create-new"
      }
    },
    {
      id   = "execution-sa"
      type = "service-account"
      importData = {
        projectId               = var.gcp_project
        serviceAccountEmail     = google_service_account.execution_sa.email
        serviceAccountUniqueId  = google_service_account.execution_sa.unique_id
        stackPermissionsApplied = true
      }
    },
    {
      id   = "management"
      type = "remote-stack-management"
      importData = {
        projectId                    = var.gcp_project
        projectNumber                = data.google_project.current.number
        serviceAccountEmail          = google_service_account.management.email
        serviceAccountUniqueId       = google_service_account.management.unique_id
        managementPermissionsApplied = true
      }
    },
    {
      id   = "assets"
      type = "storage"
      importData = {
        bucketName     = google_storage_bucket.assets.name
        bucketSelfLink = google_storage_bucket.assets.self_link
        projectId      = var.gcp_project
        location       = google_storage_bucket.assets.location
      }
    },
    {
      id   = "jobs"
      type = "queue"
      importData = {
        projectId        = var.gcp_project
        topicId          = google_pubsub_topic.jobs.name
        topicName        = google_pubsub_topic.jobs.id
        subscriptionId   = google_pubsub_subscription.jobs.name
        subscriptionName = google_pubsub_subscription.jobs.id
      }
    },
    {
      id   = "metadata"
      type = "kv"
      importData = {
        projectId  = var.gcp_project
        databaseId = google_firestore_database.metadata.name
        location   = google_firestore_database.metadata.location_id
      }
    },
    {
      id   = "secrets"
      type = "vault"
      importData = {
        projectId    = var.gcp_project
        secretPrefix = "${local.resource_prefix}-secrets"
      }
    },
    {
      id   = "registry"
      type = "artifact-registry"
      importData = {
        projectId               = var.gcp_project
        region                  = var.gcp_region
        repositoryId            = google_artifact_registry_repository.registry.name
        repositoryName          = google_artifact_registry_repository.registry.id
        registryEndpoint        = "${var.gcp_region}-docker.pkg.dev/${var.gcp_project}/${google_artifact_registry_repository.registry.name}"
        pullServiceAccountEmail = google_service_account.registry_pull.email
        pushServiceAccountEmail = google_service_account.registry_push.email
      }
    }
  ]
  registry_repository_id_full = replace(lower(format("%s-registry", local.resource_prefix)), "_", "-")
}

=== default_network.tf ===
data "google_compute_network" "default_network" {
  count   = var.network_mode == "use-existing" ? 1 : 0
  name    = var.network_name
  project = var.gcp_project
}

data "google_compute_subnetwork" "default_network_existing_subnet" {
  count   = var.network_mode == "use-existing" ? 1 : 0
  name    = var.subnet_name
  project = var.gcp_project
  region  = var.network_region == "" ? var.gcp_region : var.network_region
}

resource "google_compute_network" "default_network" {
  count                   = var.network_mode == "create-new" ? 1 : 0
  name                    = trim(substr("${local.resource_prefix}-default-network", 0, 63), "-")
  project                 = var.gcp_project
  auto_create_subnetworks = false
  routing_mode            = "REGIONAL"
}

resource "google_compute_subnetwork" "default_network_workload" {
  count                    = var.network_mode == "create-new" ? 1 : 0
  name                     = trim(substr("${local.resource_prefix}-default-network-workload", 0, 63), "-")
  project                  = var.gcp_project
  region                   = var.gcp_region
  ip_cidr_range            = "10.44.0.0/16"
  network                  = google_compute_network.default_network[0].id
  private_ip_google_access = true
}

resource "google_compute_router" "default_network_router" {
  count   = var.network_mode == "create-new" ? 1 : 0
  name    = trim(substr("${local.resource_prefix}-default-network-router", 0, 63), "-")
  project = var.gcp_project
  region  = var.gcp_region
  network = google_compute_network.default_network[0].id
}

resource "google_compute_router_nat" "default_network_nat" {
  count                              = var.network_mode == "create-new" ? 1 : 0
  name                               = trim(substr("${local.resource_prefix}-default-network-nat", 0, 63), "-")
  project                            = var.gcp_project
  region                             = var.gcp_region
  router                             = google_compute_router.default_network_router[0].name
  nat_ip_allocate_option             = "AUTO_ONLY"
  source_subnetwork_ip_ranges_to_nat = "ALL_SUBNETWORKS_ALL_IP_RANGES"

  log_config {
    enable = true
    filter = "ERRORS_ONLY"
  }
}

resource "google_compute_firewall" "default_network_internal" {
  count     = var.network_mode == "create-new" ? 1 : 0
  name      = trim(substr("${local.resource_prefix}-default-network-internal", 0, 63), "-")
  project   = var.gcp_project
  network   = google_compute_network.default_network[0].id
  direction = "INGRESS"
  source_ranges = [
    "10.44.0.0/16"
  ]

  allow {
    protocol = "all"
  }
}

=== execution_sa.tf ===
resource "google_service_account" "execution_sa" {
  project      = var.gcp_project
  account_id   = format("%s-%s", trim(substr(replace(lower(format("a-%s-execution_sa", local.resource_prefix)), "_", "-"), 0, 21), "-"), substr(sha1(replace(lower(format("%s-execution_sa", local.resource_prefix)), "_", "-")), 0, 8))
  display_name = "${local.deployment_name}: Runtime service account (execution-sa)"
  description  = "Runtime cloud identity for ${local.deployment_name}. Resource prefix: ${local.resource_prefix}. Resource: execution_sa."
}

resource "google_project_iam_custom_role" "gcp_role_read_cloud_storage_objects" {
  count       = var.gcp_manage_custom_roles ? 1 : 0
  project     = var.gcp_project
  role_id     = format("role_%s_read_cloud_storage_objects", local.gcp_custom_role_prefix)
  title       = "${local.deployment_name}: Read Cloud Storage Objects"
  description = "Used by ${local.deployment_name}. Read objects and object metadata from application-owned Cloud Storage buckets. Resource prefix: ${local.resource_prefix}."
  stage       = "GA"
  permissions = [
    "storage.buckets.get",
    "storage.buckets.list",
    "storage.multipartUploads.list",
    "storage.multipartUploads.listParts",
    "storage.objects.get",
    "storage.objects.getIamPolicy",
    "storage.objects.list"
  ]
}

resource "google_project_iam_custom_role" "gcp_role_sign_cloud_storage_download_urls" {
  count       = var.gcp_manage_custom_roles ? 1 : 0
  project     = var.gcp_project
  role_id     = format("role_%s_sign_cloud_storage_download_urls", local.gcp_custom_role_prefix)
  title       = "${local.deployment_name}: Sign Cloud Storage Download URLs"
  description = "Used by ${local.deployment_name}. Sign Cloud Storage download URLs on behalf of this application's service account. Resource prefix: ${local.resource_prefix}."
  stage       = "GA"
  permissions = [
    "iam.serviceAccounts.signBlob"
  ]
}

resource "google_project_iam_member" "gcp_role_read_cloud_storage_objects_execution_sa_binding_0" {
  project = var.gcp_project
  role    = var.gcp_manage_custom_roles ? google_project_iam_custom_role.gcp_role_read_cloud_storage_objects[0].name : format("projects/%s/roles/role_%s_read_cloud_storage_objects", var.gcp_project, local.gcp_custom_role_prefix)
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

resource "google_project_iam_member" "gcp_role_sign_cloud_storage_download_urls_execution_sa_binding_1" {
  project = var.gcp_project
  role    = var.gcp_manage_custom_roles ? google_project_iam_custom_role.gcp_role_sign_cloud_storage_download_urls[0].name : format("projects/%s/roles/role_%s_sign_cloud_storage_download_urls", var.gcp_project, local.gcp_custom_role_prefix)
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

resource "google_project_iam_member" "pubsub_publisher_execution_sa_binding_0" {
  project = var.gcp_project
  role    = "roles/pubsub.publisher"
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

resource "google_project_iam_member" "pubsub_subscriber_execution_sa_binding_1" {
  project = var.gcp_project
  role    = "roles/pubsub.subscriber"
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

resource "google_project_iam_member" "pubsub_viewer_execution_sa_binding_2" {
  project = var.gcp_project
  role    = "roles/pubsub.viewer"
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

=== management.tf ===
data "google_project" "current" {
  project_id = var.gcp_project
}

resource "google_service_account" "management" {
  project      = var.gcp_project
  account_id   = format("%s-%s", trim(substr(replace(lower(format("a-%s-management", local.resource_prefix)), "_", "-"), 0, 21), "-"), substr(sha1(replace(lower(format("%s-management", local.resource_prefix)), "_", "-")), 0, 8))
  display_name = "${local.deployment_name}: Management service account"
  description  = "Management cloud identity for ${local.deployment_name}. Resource prefix: ${local.resource_prefix}."
}

resource "google_project_iam_custom_role" "gcp_role_manage_cloud_run_services" {
  count       = var.gcp_manage_custom_roles ? 1 : 0
  project     = var.gcp_project
  role_id     = format("role_%s_manage_cloud_run_services", local.gcp_custom_role_prefix)
  title       = "${local.deployment_name}: Manage Cloud Run Services"
  description = "Used by ${local.deployment_name}. Update Cloud Run services, jobs, schedulers, Pub/Sub triggers, and IAM bindings owned by this application. Resource prefix: ${local.resource_prefix}."
  stage       = "GA"
  permissions = [
    "iam.serviceAccounts.actAs",
    "iam.serviceAccounts.getIamPolicy",
    "iam.serviceAccounts.setIamPolicy",
    "pubsub.subscriptions.create",
    "pubsub.subscriptions.delete",
    "pubsub.subscriptions.get",
    "pubsub.subscriptions.update",
    "pubsub.topics.attachSubscription",
    "pubsub.topics.create",
    "pubsub.topics.delete",
    "pubsub.topics.get",
    "pubsub.topics.update",
    "resourcemanager.projects.get",
    "run.configurations.get",
    "run.configurations.list",
    "run.executions.delete",
    "run.executions.get",
    "run.executions.list",
    "run.jobs.createTagBinding",
    "run.jobs.deleteTagBinding",
    "run.jobs.getIamPolicy",
    "run.jobs.setIamPolicy",
    "run.jobs.update",
    "run.locations.list",
    "run.operations.delete",
    "run.operations.get",
    "run.operations.list",
    "run.revisions.delete",
    "run.revisions.get",
    "run.revisions.list",
    "run.routes.get",
    "run.routes.list",
    "run.services.createTagBinding",
    "run.services.deleteTagBinding",
    "run.services.get",
    "run.services.getIamPolicy",
    "run.services.list",
    "run.services.listEffectiveTags",
    "run.services.listTagBindings",
    "run.services.setIamPolicy",
    "run.services.update",
    "run.tasks.get",
    "run.tasks.list"
  ]
}

resource "google_project_iam_custom_role" "gcp_role_manage_cloud_run_https_endpoints" {
  count       = var.gcp_manage_custom_roles ? 1 : 0
  project     = var.gcp_project
  role_id     = format("role_%s_manage_cloud_run_https_endpoints", local.gcp_custom_role_prefix)
  title       = "${local.deployment_name}: Manage Cloud Run HTTPS Endpoints"
  description = "Used by ${local.deployment_name}. Create, update, and delete Google Cloud HTTPS load-balancer resources used by Cloud Run public endpoints. Resource prefix: ${local.resource_prefix}."
  stage       = "GA"
  permissions = [
    "compute.backendServices.create",
    "compute.backendServices.delete",
    "compute.backendServices.get",
    "compute.backendServices.update",
    "compute.backendServices.use",
    "compute.globalAddresses.create",
    "compute.globalAddresses.delete",
    "compute.globalAddresses.get",
    "compute.globalForwardingRules.create",
    "compute.globalForwardingRules.delete",
    "compute.globalForwardingRules.get",
    "compute.regionNetworkEndpointGroups.create",
    "compute.regionNetworkEndpointGroups.delete",
    "compute.regionNetworkEndpointGroups.get",
    "compute.regionNetworkEndpointGroups.use",
    "compute.sslCertificates.create",
    "compute.sslCertificates.delete",
    "compute.sslCertificates.get",
    "compute.targetHttpsProxies.create",
    "compute.targetHttpsProxies.delete",
    "compute.targetHttpsProxies.get",
    "compute.targetHttpsProxies.use",
    "compute.urlMaps.create",
    "compute.urlMaps.delete",
    "compute.urlMaps.get",
    "compute.urlMaps.use"
  ]
}

resource "google_project_iam_member" "gcp_role_manage_cloud_run_services_management_binding_0" {
  project = var.gcp_project
  role    = var.gcp_manage_custom_roles ? google_project_iam_custom_role.gcp_role_manage_cloud_run_services[0].name : format("projects/%s/roles/role_%s_manage_cloud_run_services", var.gcp_project, local.gcp_custom_role_prefix)
  member  = "serviceAccount:${google_service_account.management.email}"
}

resource "google_project_iam_member" "gcp_role_manage_cloud_run_https_endpoints_management_binding_1" {
  project = var.gcp_project
  role    = var.gcp_manage_custom_roles ? google_project_iam_custom_role.gcp_role_manage_cloud_run_https_endpoints[0].name : format("projects/%s/roles/role_%s_manage_cloud_run_https_endpoints", var.gcp_project, local.gcp_custom_role_prefix)
  member  = "serviceAccount:${google_service_account.management.email}"
}

resource "google_project_iam_custom_role" "gcp_role_check_cloud_storage_health" {
  count       = var.gcp_manage_custom_roles ? 1 : 0
  project     = var.gcp_project
  role_id     = format("role_%s_check_cloud_storage_health", local.gcp_custom_role_prefix)
  title       = "${local.deployment_name}: Check Cloud Storage Health"
  description = "Used by ${local.deployment_name}. Read Cloud Storage bucket configuration needed for application health checks. Resource prefix: ${local.resource_prefix}."
  stage       = "GA"
  permissions = [
    "storage.bucketOperations.get",
    "storage.bucketOperations.list",
    "storage.buckets.get",
    "storage.buckets.getIamPolicy",
    "storage.hmacKeys.get",
    "storage.hmacKeys.list",
    "storage.managedFolders.get",
    "storage.managedFolders.getIamPolicy",
    "storage.managedFolders.list"
  ]
}

resource "google_project_iam_member" "gcp_role_check_cloud_storage_health_management_binding_0" {
  project = var.gcp_project
  role    = var.gcp_manage_custom_roles ? google_project_iam_custom_role.gcp_role_check_cloud_storage_health[0].name : format("projects/%s/roles/role_%s_check_cloud_storage_health", var.gcp_project, local.gcp_custom_role_prefix)
  member  = "serviceAccount:${google_service_account.management.email}"
}

resource "google_project_iam_member" "pubsub_viewer_management_binding_0" {
  project = var.gcp_project
  role    = "roles/pubsub.viewer"
  member  = "serviceAccount:${google_service_account.management.email}"
}

resource "google_service_account_iam_member" "management_manager_token_creator" {
  for_each           = toset(compact([var.managing_service_account_email]))
  service_account_id = google_service_account.management.id
  role               = "roles/iam.serviceAccountTokenCreator"
  member             = "serviceAccount:${each.value}"
}

resource "google_service_account_iam_member" "management_manager_user" {
  for_each           = toset(compact([var.managing_service_account_email]))
  service_account_id = google_service_account.management.id
  role               = "roles/iam.serviceAccountUser"
  member             = "serviceAccount:${each.value}"
}

=== assets.tf ===
resource "google_storage_bucket" "assets" {
  name                        = "${local.resource_prefix}-assets"
  project                     = var.gcp_project
  location                    = upper(var.gcp_region)
  storage_class               = "STANDARD"
  uniform_bucket_level_access = true
  force_destroy               = true
  public_access_prevention    = "enforced"
  labels = {
    "managed-by"    = "setup"
    deployment      = local.resource_prefix
    resource        = "assets"
    "resource-type" = "storage"
  }

  versioning {
    enabled = true
  }
}

resource "google_storage_bucket_iam_member" "gcp_role_check_cloud_storage_health_assets_management_storage_0" {
  bucket = google_storage_bucket.assets.name
  role   = var.gcp_manage_custom_roles ? google_project_iam_custom_role.gcp_role_check_cloud_storage_health[0].name : format("projects/%s/roles/role_%s_check_cloud_storage_health", var.gcp_project, local.gcp_custom_role_prefix)
  member = "serviceAccount:${google_service_account.management.email}"
}

=== jobs.tf ===
resource "google_pubsub_topic" "jobs" {
  name    = "${local.resource_prefix}-jobs"
  project = var.gcp_project
  labels = {
    "managed-by"    = "setup"
    deployment      = local.resource_prefix
    resource        = "jobs"
    "resource-type" = "queue"
  }
}

resource "google_pubsub_subscription" "jobs" {
  name                       = "${local.resource_prefix}-jobs-default"
  project                    = var.gcp_project
  topic                      = google_pubsub_topic.jobs.id
  ack_deadline_seconds       = 360
  message_retention_duration = "604800s"
  enable_message_ordering    = false

  expiration_policy {
    ttl = ""
  }

  labels = {
    "managed-by"    = "setup"
    deployment      = local.resource_prefix
    resource        = "jobs"
    "resource-type" = "queue"
  }
}

resource "google_pubsub_topic_iam_member" "pubsub_viewer_jobs_management_topic_0" {
  project = var.gcp_project
  topic   = google_pubsub_topic.jobs.name
  role    = "roles/pubsub.viewer"
  member  = "serviceAccount:${google_service_account.management.email}"
}

resource "google_pubsub_subscription_iam_member" "pubsub_viewer_jobs_management_subscription_1" {
  project      = var.gcp_project
  subscription = google_pubsub_subscription.jobs.name
  role         = "roles/pubsub.viewer"
  member       = "serviceAccount:${google_service_account.management.email}"
}

=== metadata.tf ===
resource "google_firestore_database" "metadata" {
  name                        = "${local.resource_prefix}-metadata"
  project                     = var.gcp_project
  location_id                 = var.gcp_region
  type                        = "FIRESTORE_NATIVE"
  concurrency_mode            = "OPTIMISTIC"
  app_engine_integration_mode = "DISABLED"
  delete_protection_state     = "DELETE_PROTECTION_DISABLED"
  deletion_policy             = "DELETE"
}

=== secrets.tf ===
resource "google_project_iam_custom_role" "gcp_role_create_secret_manager_secrets" {
  count       = var.gcp_manage_custom_roles ? 1 : 0
  project     = var.gcp_project
  role_id     = format("role_%s_create_secret_manager_secrets", local.gcp_custom_role_prefix)
  title       = "${local.deployment_name}: Create Secret Manager Secrets"
  description = "Used by ${local.deployment_name}. Create application-owned Secret Manager secrets. Resource prefix: ${local.resource_prefix}."
  stage       = "GA"
  permissions = [
    "secretmanager.secrets.create"
  ]
}

resource "google_project_iam_custom_role" "gcp_role_write_secret_manager_values" {
  count       = var.gcp_manage_custom_roles ? 1 : 0
  project     = var.gcp_project
  role_id     = format("role_%s_write_secret_manager_values", local.gcp_custom_role_prefix)
  title       = "${local.deployment_name}: Write Secret Manager Values"
  description = "Used by ${local.deployment_name}. Add values to application-owned Secret Manager secrets and delete those secrets during cleanup. Resource prefix: ${local.resource_prefix}."
  stage       = "GA"
  permissions = [
    "secretmanager.secrets.delete",
    "secretmanager.secrets.get"
  ]
}

resource "google_project_iam_member" "gcp_role_create_secret_manager_secrets_management_secrets_vault_data_write_binding_0" {
  project = var.gcp_project
  role    = var.gcp_manage_custom_roles ? google_project_iam_custom_role.gcp_role_create_secret_manager_secrets[0].name : format("projects/%s/roles/role_%s_create_secret_manager_secrets", var.gcp_project, local.gcp_custom_role_prefix)
  member  = "serviceAccount:${google_service_account.management.email}"
}

resource "google_project_iam_member" "secretmanager_secretversionadder_management_secrets_vault_data_write_binding_1" {
  project = var.gcp_project
  role    = "roles/secretmanager.secretVersionAdder"
  member  = "serviceAccount:${google_service_account.management.email}"

  condition {
    title       = "ResourceVaultSecrets"
    description = "Limit to ResourceVaultSecrets"
    expression  = "(resource.type == \"secretmanager.googleapis.com/Secret\" || resource.type == \"secretmanager.googleapis.com/SecretVersion\") && resource.name.startsWith(\"projects/${data.google_project.current.number}/secrets/${local.resource_prefix}-secrets-\")"
  }
}

resource "google_project_iam_member" "gcp_role_write_secret_manager_values_management_secrets_vault_data_write_binding_2" {
  project = var.gcp_project
  role    = var.gcp_manage_custom_roles ? google_project_iam_custom_role.gcp_role_write_secret_manager_values[0].name : format("projects/%s/roles/role_%s_write_secret_manager_values", var.gcp_project, local.gcp_custom_role_prefix)
  member  = "serviceAccount:${google_service_account.management.email}"

  condition {
    title       = "ResourceVaultSecrets"
    description = "Limit to ResourceVaultSecrets"
    expression  = "(resource.type == \"secretmanager.googleapis.com/Secret\" || resource.type == \"secretmanager.googleapis.com/SecretVersion\") && resource.name.startsWith(\"projects/${data.google_project.current.number}/secrets/${local.resource_prefix}-secrets-\")"
  }
}

=== registry.tf ===
resource "google_artifact_registry_repository" "registry" {
  project       = var.gcp_project
  location      = var.gcp_region
  repository_id = length(local.registry_repository_id_full) <= 63 ? local.registry_repository_id_full : format("%s-%s", trim(substr(local.registry_repository_id_full, 0, 54), "-"), substr(sha1(local.registry_repository_id_full), 0, 8))
  format        = "DOCKER"
  description   = "Application container artifact registry (registry)"
  labels = {
    "managed-by"    = "setup"
    deployment      = local.resource_prefix
    resource        = "registry"
    "resource-type" = "artifact-registry"
  }
}

resource "google_service_account" "registry_pull" {
  project      = var.gcp_project
  account_id   = format("%s-%s", trim(substr(replace(lower(format("a-%s-registry-pull", local.resource_prefix)), "_", "-"), 0, 21), "-"), substr(sha1(replace(lower(format("%s-registry-pull", local.resource_prefix)), "_", "-")), 0, 8))
  display_name = "Application artifact registry identity (registry pull)"
}

resource "google_artifact_registry_repository_iam_member" "registry_pull_iam" {
  project    = var.gcp_project
  location   = google_artifact_registry_repository.registry.location
  repository = google_artifact_registry_repository.registry.name
  role       = "roles/artifactregistry.reader"
  member     = "serviceAccount:${google_service_account.registry_pull.email}"
}

resource "google_service_account" "registry_push" {
  project      = var.gcp_project
  account_id   = format("%s-%s", trim(substr(replace(lower(format("a-%s-registry-push", local.resource_prefix)), "_", "-"), 0, 21), "-"), substr(sha1(replace(lower(format("%s-registry-push", local.resource_prefix)), "_", "-")), 0, 8))
  display_name = "Application artifact registry identity (registry push)"
}

resource "google_artifact_registry_repository_iam_member" "registry_push_iam" {
  project    = var.gcp_project
  location   = google_artifact_registry_repository.registry.location
  repository = google_artifact_registry_repository.registry.name
  role       = "roles/artifactregistry.writer"
  member     = "serviceAccount:${google_service_account.registry_push.email}"
}

=== iam_propagation.tf ===
resource "time_sleep" "gcp_iam_propagation" {
  create_duration = "120s"
  depends_on = [
    google_project_iam_member.gcp_role_read_cloud_storage_objects_execution_sa_binding_0,
    google_project_iam_member.gcp_role_sign_cloud_storage_download_urls_execution_sa_binding_1,
    google_project_iam_member.pubsub_publisher_execution_sa_binding_0,
    google_project_iam_member.pubsub_subscriber_execution_sa_binding_1,
    google_project_iam_member.pubsub_viewer_execution_sa_binding_2,
    google_project_iam_member.gcp_role_manage_cloud_run_services_management_binding_0,
    google_project_iam_member.gcp_role_manage_cloud_run_https_endpoints_management_binding_1,
    google_project_iam_member.gcp_role_check_cloud_storage_health_management_binding_0,
    google_project_iam_member.pubsub_viewer_management_binding_0,
    google_service_account_iam_member.management_manager_token_creator,
    google_service_account_iam_member.management_manager_user,
    google_project_iam_member.gcp_role_create_secret_manager_secrets_management_secrets_vault_data_write_binding_0,
    google_project_iam_member.secretmanager_secretversionadder_management_secrets_vault_data_write_binding_1,
    google_project_iam_member.gcp_role_write_secret_manager_values_management_secrets_vault_data_write_binding_2
  ]
}

=== registration.tf ===
resource "terraform_data" "deployment_registration" {
  input = {
    platform                    = local.deployment_platform
    token                       = var.token
    name                        = var.name
    resource_prefix             = local.resource_prefix
    setup_target                = ""
    setup_import_format_version = 1
    setup_fingerprint           = ""
    setup_fingerprint_version   = 0
    management_url              = var.management_url
    management_config           = local.deployment_management_config
    stack_settings              = local.deployment_settings
    resources                   = local.deployment_resources
  }
  depends_on = [
    google_compute_network.default_network,
    google_compute_subnetwork.default_network_workload,
    google_compute_router.default_network_router,
    google_compute_router_nat.default_network_nat,
    google_compute_firewall.default_network_internal,
    google_service_account.execution_sa,
    google_project_iam_custom_role.gcp_role_read_cloud_storage_objects,
    google_project_iam_custom_role.gcp_role_sign_cloud_storage_download_urls,
    google_project_iam_member.gcp_role_read_cloud_storage_objects_execution_sa_binding_0,
    google_project_iam_member.gcp_role_sign_cloud_storage_download_urls_execution_sa_binding_1,
    google_project_iam_member.pubsub_publisher_execution_sa_binding_0,
    google_project_iam_member.pubsub_subscriber_execution_sa_binding_1,
    google_project_iam_member.pubsub_viewer_execution_sa_binding_2,
    google_service_account.management,
    google_project_iam_custom_role.gcp_role_manage_cloud_run_services,
    google_project_iam_custom_role.gcp_role_manage_cloud_run_https_endpoints,
    google_project_iam_member.gcp_role_manage_cloud_run_services_management_binding_0,
    google_project_iam_member.gcp_role_manage_cloud_run_https_endpoints_management_binding_1,
    google_project_iam_custom_role.gcp_role_check_cloud_storage_health,
    google_project_iam_member.gcp_role_check_cloud_storage_health_management_binding_0,
    google_project_iam_member.pubsub_viewer_management_binding_0,
    google_service_account_iam_member.management_manager_token_creator,
    google_service_account_iam_member.management_manager_user,
    google_storage_bucket.assets,
    google_storage_bucket_iam_member.gcp_role_check_cloud_storage_health_assets_management_storage_0,
    google_pubsub_topic.jobs,
    google_pubsub_subscription.jobs,
    google_pubsub_topic_iam_member.pubsub_viewer_jobs_management_topic_0,
    google_pubsub_subscription_iam_member.pubsub_viewer_jobs_management_subscription_1,
    google_firestore_database.metadata,
    google_project_iam_custom_role.gcp_role_create_secret_manager_secrets,
    google_project_iam_custom_role.gcp_role_write_secret_manager_values,
    google_project_iam_member.gcp_role_create_secret_manager_secrets_management_secrets_vault_data_write_binding_0,
    google_project_iam_member.secretmanager_secretversionadder_management_secrets_vault_data_write_binding_1,
    google_project_iam_member.gcp_role_write_secret_manager_values_management_secrets_vault_data_write_binding_2,
    google_artifact_registry_repository.registry,
    google_service_account.registry_pull,
    google_artifact_registry_repository_iam_member.registry_pull_iam,
    google_service_account.registry_push,
    google_artifact_registry_repository_iam_member.registry_push_iam,
    time_sleep.gcp_iam_propagation
  ]
}

=== outputs.tf ===
output "deployment_target" {
  value       = "gcp"
  description = "Terraform module target."
}

output "deployment_resource_prefix" {
  value       = local.resource_prefix
  description = "Physical resource prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_setup_target" {
  value       = ""
  description = "Setup target."
}

output "deployment_setup_import_format_version" {
  value       = 1
  description = "Setup registration payload format version."
}

output "deployment_setup_fingerprint" {
  value       = ""
  description = "Setup compatibility fingerprint."
}

output "deployment_setup_fingerprint_version" {
  value       = 0
  description = "Setup fingerprint algorithm version."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Deployment registration management configuration JSON."
}

output "deployment_stack_settings" {
  value       = jsonencode(local.deployment_settings)
  description = "Deployment registration settings JSON."
  sensitive   = true
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Deployment registration resource metadata JSON."
}

=== README.md ===
# Deployment setup - full-gcp

Target: `gcp`.

This module creates setup-owned infrastructure, grants the management access needed after setup, and prepares deployment registration metadata. Review the generated `.tf` files before applying; each resource file maps to one setup resource.

## Inputs

Required:

- `token`: install token from the setup page.
- `name`: deployment name to include in the registration metadata.

Common optional settings:

- `resource_prefix`: stable physical-name prefix. Leave empty to generate one.
- `management_url`: optional management endpoint used by pull-style runtimes.
- `deployment_model`: `push` or `pull`.
- `updates_mode`: `auto` or `approval-required`.
- `telemetry_mode`: `off`, `auto`, or `approval-required`.
- `heartbeats_mode`: `off` or `on`.
- `advanced_settings_json`: advanced deployment settings JSON. Most installs should use typed variables instead.

GCP settings:

- `gcp_project`: target GCP project ID.
- `gcp_region`: target GCP region.
- `managing_service_account_email`: management service account allowed to impersonate setup-created identities.
- `gcp_manage_custom_roles`: whether this module creates project custom roles.
- `gcp_custom_role_prefix`: custom role ID prefix when roles are managed outside this module.

Network settings:

- `network_mode`: `create-new`, `use-existing`, or `use-default`.
- `network_cidr`, `availability_zones`: used with `create-new`.
- `network_name`, `subnet_name`, `network_region`: required with `use-existing`.

## Run

Use your organization's normal backend and approval workflow. A typical local review looks like:

```bash
export TF_VAR_name="full-gcp"
export TF_VAR_token="..."
terraform init
terraform validate
terraform plan -out=tfplan
terraform apply tfplan
```

## Registration

This module exposes `deployment_management_config`, `deployment_stack_settings`, and `deployment_resources` outputs for registration flows managed outside Terraform.

## Outputs

- `deployment_management_config`: management endpoint and credential-boundary metadata.
- `deployment_stack_settings`: deployment settings JSON assembled from typed variables and `advanced_settings_json`.
- `deployment_resources`: setup-owned resource metadata handed to the deployment runtime.
- `deployment_id` and `deployment_token`: emitted only when Terraform performs registration.

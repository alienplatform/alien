resource "google_project_iam_member" "gcp_role_worker_management_part2_management_binding_1" {
  project = var.gcp_project
  role    = google_project_iam_custom_role.gcp_role_worker_management_part2.name
  member  = "serviceAccount:${google_service_account.management.email}"

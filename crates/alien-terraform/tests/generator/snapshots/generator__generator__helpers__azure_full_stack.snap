=== management.tf ===
data "azurerm_client_config" "management_current" {}

resource "azurerm_user_assigned_identity" "management" {
  name                = "${local.resource_prefix}-management-identity"
  resource_group_name = var.azure_resource_group_name
  location            = var.azure_location
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "management"
    "resource-type" = "remote-stack-management"
  }
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

resource "azurerm_role_assignment" "management_existing_vnet_reader_uami" {
  count              = try(local.deployment_settings.network.type, "") == "byo-vnet-azure" ? 1 : 0
  name               = uuidv5("oid", "deployment:azure:existing-vnet-reader:${local.resource_prefix}:uami:${azurerm_user_assigned_identity.management.principal_id}:${try(local.deployment_settings.network.vnet_resource_id, "")}")
  scope              = try(local.deployment_settings.network.vnet_resource_id, "")
  role_definition_id = "/subscriptions/${var.azure_subscription_id}/providers/Microsoft.Authorization/roleDefinitions/acdd72a7-3385-48ef-bd42-f606fba81ae7"
  principal_id       = azurerm_user_assigned_identity.management.principal_id
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

resource "azurerm_federated_identity_credential" "management_fic" {
  name                = "${local.resource_prefix}-federated-credential"
  resource_group_name = var.azure_resource_group_name
  parent_id           = azurerm_user_assigned_identity.management.id
  audience = [
    "api://AzureADTokenExchange"
  ]
  issuer  = var.azure_oidc_issuer
  subject = var.azure_oidc_subject
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}


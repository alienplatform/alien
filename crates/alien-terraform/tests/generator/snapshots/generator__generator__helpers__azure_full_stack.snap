resource "azurerm_storage_container" "assets" {
  name                  = replace(lower("${local.resource_prefix}-assets"), "_", "-")
  storage_account_name  = azurerm_storage_account.default_storage_account.name
  container_access_type = "private"
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

=== jobs.tf ===
resource "azurerm_servicebus_queue" "jobs" {
  name                                 = "${local.resource_prefix}-jobs"
  namespace_id                         = azurerm_servicebus_namespace.default_service_bus_namespace.id
  partitioning_enabled                 = false
  lock_duration                        = "PT30S"
  default_message_ttl                  = "P14D"
  max_delivery_count                   = 10
  dead_lettering_on_message_expiration = true
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

=== metadata.tf ===
resource "azurerm_storage_table" "metadata" {
  name                 = substr(lower(replace("kv${local.resource_prefix}metadata", "/[^A-Za-z0-9]/", "")), 0, 63)
  storage_account_name = azurerm_storage_account.default_storage_account.name
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

=== secrets.tf ===
data "azurerm_client_config" "secrets_current" {}

resource "azurerm_key_vault" "secrets" {
  name                          = substr(lower("${local.resource_prefix}-secrets"), 0, 24)
  resource_group_name           = var.azure_resource_group_name
  location                      = var.azure_location
  tenant_id                     = data.azurerm_client_config.secrets_current.tenant_id
  sku_name                      = "standard"
  rbac_authorization_enabled    = true
  purge_protection_enabled      = true
  soft_delete_retention_days    = 90
  public_network_access_enabled = true
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "secrets"
    "resource-type" = "vault"
  }
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

resource "azurerm_role_assignment" "secrets_write_key_vault_secrets_management_assignment_0" {
  name               = uuidv5("oid", "deployment:azure:mgmt-res-role-assign:${local.resource_prefix}:secrets:write_key_vault_secrets:0")
  scope              = azurerm_key_vault.secrets.id
  role_definition_id = azurerm_role_definition.setup_management_write_key_vault_secrets_0.role_definition_resource_id
  principal_id       = azurerm_user_assigned_identity.management.principal_id
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

=== registry.tf ===
resource "azurerm_container_registry" "registry" {
  name                = substr(replace(lower("${local.resource_prefix}registry"), "-", ""), 0, 50)
  resource_group_name = var.azure_resource_group_name
  location            = var.azure_location
  sku                 = "Premium"
  admin_enabled       = false
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "registry"
    "resource-type" = "artifact-registry"
  }
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

resource "azurerm_user_assigned_identity" "registry_pull" {
  name                = "${local.resource_prefix}-registry-pull"
  resource_group_name = var.azure_resource_group_name
  location            = var.azure_location
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "registry"
    "resource-type" = "artifact-registry"
  }
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

resource "azurerm_role_assignment" "registry_pull_role" {
  name                 = uuidv5("dns", "${local.resource_prefix}-registry-pull-${azurerm_user_assigned_identity.registry_pull.principal_id}")
  scope                = azurerm_container_registry.registry.id
  role_definition_name = "AcrPull"
  principal_id         = azurerm_user_assigned_identity.registry_pull.principal_id
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

resource "azurerm_user_assigned_identity" "registry_push" {
  name                = "${local.resource_prefix}-registry-push"
  resource_group_name = var.azure_resource_group_name
  location            = var.azure_location
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "registry"
    "resource-type" = "artifact-registry"
  }
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

resource "azurerm_role_assignment" "registry_push_role" {
  name                 = uuidv5("dns", "${local.resource_prefix}-registry-push-${azurerm_user_assigned_identity.registry_push.principal_id}")
  scope                = azurerm_container_registry.registry.id
  role_definition_name = "AcrPush"
  principal_id         = azurerm_user_assigned_identity.registry_push.principal_id
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                  = local.deployment_platform
    token                     = var.token
    name                      = var.name
    resource_prefix           = local.resource_prefix
    setup_target              = ""
    setup_fingerprint         = ""
    setup_fingerprint_version = 0
    manager_url               = var.manager_url
    management_config         = local.deployment_management_config
    stack_settings            = local.deployment_settings
    resources                 = local.deployment_resources
  }
  depends_on = [
    azurerm_resource_group.default_resource_group,
    azurerm_role_definition.setup_management_write_key_vault_secrets_0,
    azurerm_role_definition.setup_management_manage_container_apps_0,
    azurerm_storage_account.default_storage_account,
    azurerm_servicebus_namespace.default_service_bus_namespace,
    azurerm_log_analytics_workspace.default_container_apps_environment_logs,
    azurerm_container_app_environment.default_container_apps_environment,
    azurerm_virtual_network.default_network,
    azurerm_subnet.default_network_public,
    azurerm_subnet.default_network_private,
    azurerm_public_ip.default_network_nat_pip,
    azurerm_nat_gateway.default_network_nat,
    azurerm_nat_gateway_public_ip_association.default_network_nat,
    azurerm_subnet_nat_gateway_association.default_network_private,
    azurerm_network_security_group.default_network_workload,
    azurerm_subnet_network_security_group_association.default_network_private,
    azurerm_user_assigned_identity.execution_sa,
    azurerm_role_assignment.execution_sa_storage_blob_data_reader___var_azure_resource_group_name__assignment,
    azurerm_role_assignment.execution_sa_azure_service_bus_data_sender___var_azure_resource_group_name__assignment,
    azurerm_user_assigned_identity.management,
    azurerm_role_assignment.management_existing_vnet_reader_uami,
    azurerm_federated_identity_credential.management_fic,
    azurerm_storage_container.assets,
    azurerm_servicebus_queue.jobs,
    azurerm_storage_table.metadata,
    azurerm_key_vault.secrets,
    azurerm_role_assignment.secrets_write_key_vault_secrets_management_assignment_0,
    azurerm_container_registry.registry,
    azurerm_user_assigned_identity.registry_pull,
    azurerm_role_assignment.registry_pull_role,
    azurerm_user_assigned_identity.registry_push,
    azurerm_role_assignment.registry_push_role
  ]
}

=== outputs.tf ===
output "deployment_target" {
  value       = "azure"
  description = "Terraform module target."
}

output "deployment_resource_prefix" {
  value       = local.resource_prefix
  description = "Physical resource prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_setup_target" {
  value       = ""
  description = "Setup target."
}

output "deployment_setup_fingerprint" {
  value       = ""
  description = "Setup compatibility fingerprint."
}

output "deployment_setup_fingerprint_version" {
  value       = 0
  description = "Setup fingerprint algorithm version."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_stack_settings" {
  value       = jsonencode(local.deployment_settings)
  description = "Manager import StackSettings JSON."
  sensitive   = true
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - full-azure

Target: `azure`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='name=full-azure' -var='token=...'
```

This module exposes `deployment_management_config` / `deployment_stack_settings` / `deployment_resources` for external registration flows.

---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = ">= 3.100"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "resource_prefix" {
  type        = string
  description = "Optional stable physical resource prefix. Leave empty to generate one."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || (can(regex("^[a-z][a-z0-9-]{1,38}[a-z0-9]$", var.resource_prefix)) && length(regexall("--", var.resource_prefix)) == 0)
    error_message = "resource_prefix must be 3-40 characters: lowercase letters, numbers, and hyphens; start with a letter; end with a letter or number; and not contain consecutive hyphens."
  }
}

variable "name" {
  type        = string
  description = "Human-readable application name shown in setup and cloud IAM review metadata."
}

variable "token" {
  type        = string
  description = "Install token from the application setup page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "stack_settings_json" {
  type        = string
  description = "Optional JSON-encoded StackSettings override supplied by deployment installers."
  default     = "{\"network\":{\"type\":\"create\",\"cidr\":\"10.46.0.0/16\",\"availability_zones\":1},\"updates\":\"approval-required\"}"
  sensitive   = true
}

variable "azure_location" {
  type        = string
  description = "Azure location."
  default     = "eastus"
}

variable "azure_subscription_id" {
  type        = string
  description = "Azure subscription ID hosting the stack."
}

variable "azure_resource_group_name" {
  type        = string
  description = "Azure resource group name."
}

variable "azure_managing_tenant_id" {
  type        = string
  description = "Azure tenant ID the manager uses for cross-tenant access."
}

variable "azure_oidc_issuer" {
  type        = string
  description = "OIDC issuer URL for Azure Federated Identity Credential."
}

variable "azure_oidc_subject" {
  type        = string
  description = "OIDC subject claim for Azure Federated Identity Credential."
}

=== providers.tf ===
provider "azurerm" {
  resource_provider_registrations = "none"

  features {}
}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 4
}

=== locals.tf ===
locals {
  resource_prefix     = var.resource_prefix == "" ? format("a%s", random_id.resource_prefix.hex) : var.resource_prefix
  deployment_name     = var.name
  deployment_platform = "azure"
  deployment_target   = "azure"
  deployment_region   = var.azure_location
  deployment_management_config = {
    platform         = "azure"
    managingTenantId = var.azure_managing_tenant_id
    oidcIssuer       = var.azure_oidc_issuer
    oidcSubject      = var.azure_oidc_subject
  }
  deployment_settings = jsondecode(var.stack_settings_json)
  deployment_resources = [
    {
      id   = "default-resource-group"
      type = "azure_resource_group"
      importData = {
        subscriptionId = var.azure_subscription_id
        resourceGroup  = azurerm_resource_group.default_resource_group.name
        location       = azurerm_resource_group.default_resource_group.location
      }
    },
    {
      id   = "default-storage-account"
      type = "azure_storage_account"
      importData = {
        subscriptionId     = var.azure_subscription_id
        resourceGroup      = var.azure_resource_group_name
        storageAccountName = azurerm_storage_account.default_storage_account.name
        blobEndpoint       = azurerm_storage_account.default_storage_account.primary_blob_endpoint
        queueEndpoint      = azurerm_storage_account.default_storage_account.primary_queue_endpoint
      }
    },
    {
      id   = "default-service-bus-namespace"
      type = "azure_service_bus_namespace"
      importData = {
        subscriptionId = var.azure_subscription_id
        resourceGroup  = var.azure_resource_group_name
        namespaceName  = azurerm_servicebus_namespace.default_service_bus_namespace.name
        endpoint       = "${azurerm_servicebus_namespace.default_service_bus_namespace.name}.servicebus.windows.net"
      }
    },
    {
      id   = "default-container-apps-environment"
      type = "azure_container_apps_environment"
      importData = {
        subscriptionId             = var.azure_subscription_id
        resourceGroup              = var.azure_resource_group_name
        environmentName            = azurerm_container_app_environment.default_container_apps_environment.name
        resourceId                 = azurerm_container_app_environment.default_container_apps_environment.id
        defaultDomain              = azurerm_container_app_environment.default_container_apps_environment.default_domain
        customDomainVerificationId = azurerm_container_app_environment.default_container_apps_environment.custom_domain_verification_id
      }
    },
    {
      id   = "default-network"
      type = "network"
      importData = {
        subscriptionId = var.azure_subscription_id
        resourceGroup  = var.azure_resource_group_name
        vnetId         = azurerm_virtual_network.default_network.id
        vnetName       = azurerm_virtual_network.default_network.name
        subnetIds = [
          azurerm_subnet.default_network_public.id,
          azurerm_subnet.default_network_private.id
        ]
        natGatewayId           = azurerm_nat_gateway.default_network_nat.id
        networkSecurityGroupId = azurerm_network_security_group.default_network_workload.id
        isByoVnet              = false
      }
    },
    {
      id   = "execution-sa"
      type = "service-account"
      importData = {
        subscriptionId          = var.azure_subscription_id
        resourceGroup           = var.azure_resource_group_name
        identityId              = azurerm_user_assigned_identity.execution_sa.id
        principalId             = azurerm_user_assigned_identity.execution_sa.principal_id
        clientId                = azurerm_user_assigned_identity.execution_sa.client_id
        stackPermissionsApplied = true
      }
    },
    {
      id   = "management"
      type = "remote-stack-management"
      importData = {
        subscriptionId               = var.azure_subscription_id
        resourceGroup                = var.azure_resource_group_name
        tenantId                     = data.azurerm_client_config.management_current.tenant_id
        identityId                   = azurerm_user_assigned_identity.management.id
        principalId                  = azurerm_user_assigned_identity.management.principal_id
        clientId                     = azurerm_user_assigned_identity.management.client_id
        managementPermissionsApplied = true
      }
    },
    {
      id   = "assets"
      type = "storage"
      importData = {
        subscriptionId     = var.azure_subscription_id
        resourceGroup      = var.azure_resource_group_name
        storageAccountName = azurerm_storage_account.default_storage_account.name
        containerName      = azurerm_storage_container.assets.name
      }
    },
    {
      id   = "jobs"
      type = "queue"
      importData = {
        subscriptionId = var.azure_subscription_id
        resourceGroup  = var.azure_resource_group_name
        namespaceName  = azurerm_servicebus_namespace.default_service_bus_namespace.name
        queueName      = azurerm_servicebus_queue.jobs.name
      }
    },
    {
      id   = "metadata"
      type = "kv"
      importData = {
        subscriptionId     = var.azure_subscription_id
        resourceGroup      = var.azure_resource_group_name
        storageAccountName = azurerm_storage_account.default_storage_account.name
        tableName          = azurerm_storage_table.metadata.name
        tableEndpoint      = azurerm_storage_account.default_storage_account.primary_table_endpoint
      }
    },
    {
      id   = "secrets"
      type = "vault"
      importData = {
        subscriptionId = var.azure_subscription_id
        resourceGroup  = var.azure_resource_group_name
        vaultName      = azurerm_key_vault.secrets.name
        vaultUri       = azurerm_key_vault.secrets.vault_uri
      }
    },
    {
      id   = "registry"
      type = "artifact-registry"
      importData = {
        subscriptionId  = var.azure_subscription_id
        resourceGroup   = var.azure_resource_group_name
        registryName    = azurerm_container_registry.registry.name
        loginServer     = azurerm_container_registry.registry.login_server
        pullPrincipalId = azurerm_user_assigned_identity.registry_pull.principal_id
        pushPrincipalId = azurerm_user_assigned_identity.registry_push.principal_id
      }
    }
  ]
}

=== default_resource_group.tf ===
resource "azurerm_resource_group" "default_resource_group" {
  name     = var.azure_resource_group_name
  location = var.azure_location
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-resource-group"
    "resource-type" = "resource-group"
  }
}

resource "azurerm_role_definition" "setup_management_write_key_vault_secrets_0" {
  name               = "${local.resource_prefix}-Write Key Vault Secrets [mgmt]"
  role_definition_id = uuidv5("oid", "deployment:azure:mgmt-res-role-def:${local.resource_prefix}:setup_management_write_key_vault_secrets_0")
  scope              = "/subscriptions/${var.azure_subscription_id}/resourceGroups/${var.azure_resource_group_name}"
  description        = "Used by $${local.deployment_name}. Create, update, and delete application-owned Azure Key Vault secrets. Resource prefix: $${local.resource_prefix}."

  permissions {
    actions = []
    data_actions = [
      "Microsoft.KeyVault/vaults/secrets/delete",
      "Microsoft.KeyVault/vaults/secrets/readMetadata/action",
      "Microsoft.KeyVault/vaults/secrets/setSecret/action"
    ]
    not_actions      = []
    not_data_actions = []
  }

  assignable_scopes = [
    "/subscriptions/${var.azure_subscription_id}/resourceGroups/${var.azure_resource_group_name}"
  ]
}

resource "azurerm_role_definition" "setup_management_manage_container_apps_0" {
  name               = "${local.resource_prefix}-Manage Container Apps [mgmt]"
  role_definition_id = uuidv5("oid", "deployment:azure:mgmt-res-role-def:${local.resource_prefix}:setup_management_manage_container_apps_0")
  scope              = "/subscriptions/${var.azure_subscription_id}/resourceGroups/${var.azure_resource_group_name}"
  description        = "Used by $${local.deployment_name}. Update Azure Container Apps, queues, identities, certificates, and role assignments owned by this application. Resource prefix: $${local.resource_prefix}."

  permissions {
    actions = [
      "Microsoft.App/containerApps/authConfigs/read",
      "Microsoft.App/containerApps/authConfigs/write",
      "Microsoft.App/containerApps/read",
      "Microsoft.App/containerApps/revisions/activate/action",
      "Microsoft.App/containerApps/revisions/deactivate/action",
      "Microsoft.App/containerApps/revisions/read",
      "Microsoft.App/containerApps/revisions/replicas/read",
      "Microsoft.App/containerApps/revisions/restart/action",
      "Microsoft.App/containerApps/sourceControls/read",
      "Microsoft.App/containerApps/write",
      "Microsoft.App/managedEnvironments/daprComponents/delete",
      "Microsoft.App/managedEnvironments/daprComponents/read",
      "Microsoft.App/managedEnvironments/daprComponents/write",
      "Microsoft.App/managedEnvironments/join/action",
      "Microsoft.App/managedEnvironments/read",
      "Microsoft.Authorization/roleAssignments/delete",
      "Microsoft.Authorization/roleAssignments/read",
      "Microsoft.Authorization/roleAssignments/write",
      "Microsoft.Authorization/roleDefinitions/read",
      "Microsoft.ManagedIdentity/userAssignedIdentities/assign/action",
      "Microsoft.ServiceBus/namespaces/queues/delete",
      "Microsoft.ServiceBus/namespaces/queues/read",
      "Microsoft.ServiceBus/namespaces/queues/write",
      "Microsoft.ServiceBus/namespaces/read"
    ]
    data_actions = [
      "Microsoft.KeyVault/vaults/certificates/import/action",
      "Microsoft.KeyVault/vaults/certificates/read",
      "Microsoft.ServiceBus/namespaces/messages/send/action"
    ]
    not_actions      = []
    not_data_actions = []
  }

  assignable_scopes = [
    "/subscriptions/${var.azure_subscription_id}/resourceGroups/${var.azure_resource_group_name}"
  ]
}

=== default_storage_account.tf ===
resource "azurerm_storage_account" "default_storage_account" {
  name                            = substr(replace(lower("${local.resource_prefix}default"), "-", ""), 0, 24)
  resource_group_name             = var.azure_resource_group_name
  location                        = var.azure_location
  account_tier                    = "Standard"
  account_replication_type        = "LRS"
  account_kind                    = "StorageV2"
  access_tier                     = "Hot"
  min_tls_version                 = "TLS1_2"
  allow_nested_items_to_be_public = false
  https_traffic_only_enabled      = true
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-storage-account"
    "resource-type" = "storage-account"
  }

  blob_properties {
    versioning_enabled  = true
    change_feed_enabled = false
  }

  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

=== default_service_bus_namespace.tf ===
resource "azurerm_servicebus_namespace" "default_service_bus_namespace" {
  name                = format("%s-bus-%s", trim(substr(lower("a-${local.resource_prefix}"), 0, 37), "-"), substr(sha1(local.resource_prefix), 0, 8))
  resource_group_name = var.azure_resource_group_name
  location            = var.azure_location
  sku                 = "Standard"
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-service-bus-namespace"
    "resource-type" = "service-bus-namespace"
  }
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}


---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "name" {
  type        = string
  description = "Human-readable deployment name shown in the deployment portal."
}

variable "token" {
  type        = string
  description = "Deployment token from the deployment page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "resource_prefix" {
  type        = string
  description = "Optional stable cloud resource prefix. Leave empty to generate one and store it in Terraform state."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || can(regex("^[a-z][a-z0-9-]{1,30}[a-z0-9]$", var.resource_prefix))
    error_message = "resource_prefix must be empty or 3-32 characters using lowercase letters, numbers, and hyphens, starting with a letter and ending with a letter or number."
  }
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "deployment_settings_json" {
  type        = string
  description = "Optional JSON-encoded deployment settings override supplied by deployment installers."
  default     = "{\"network\":{\"type\":\"create\",\"cidr\":\"10.42.0.0/16\",\"availability_zones\":2}}"
  sensitive   = true
}

variable "aws_region" {
  type        = string
  description = "AWS region used by the AWS provider."
  default     = "us-east-1"
}

variable "managing_role_arn" {
  type        = string
  description = "ARN of the manager IAM identity allowed to assume management roles."
  default     = ""
}

variable "managing_account_id" {
  type        = string
  description = "Account ID hosting the manager. Referenced by resource-side IAM policies that scope cross-account image pulls. Empty disables those grants."
  default     = ""
}

variable "network_mode" {
  type        = string
  description = "Choose whether this setup creates a new network, uses an existing network, or uses the default network. Values: create-new, use-existing, use-default."
  default     = "create-new"
}

variable "vpc_cidr" {
  type        = string
  description = "CIDR for a newly-created network. Empty uses 10.42.0.0/16."
  default     = ""
}

variable "availability_zones" {
  type        = number
  description = "Number of availability zones to use when creating a new network."
  default     = 2
}

variable "vpc_id" {
  type        = string
  description = "Existing VPC ID. Required when network is use-existing."
  default     = ""
}

variable "public_subnet_ids" {
  type        = list(string)
  description = "Existing public subnet IDs. Required when network is use-existing."
  default     = []
}

variable "private_subnet_ids" {
  type        = list(string)
  description = "Existing private subnet IDs. Required when network is use-existing."
  default     = []
}

variable "security_group_ids" {
  type        = list(string)
  description = "Existing security group IDs. Required when network is use-existing."
  default     = []
}

=== providers.tf ===
provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 8
}

=== locals.tf ===
locals {
  resource_prefix     = var.resource_prefix != "" ? var.resource_prefix : "a${random_id.resource_prefix.hex}"
  deployment_platform = "aws"
  deployment_target   = "aws"
  deployment_region   = data.aws_region.current.region
  deployment_management_config = {
    platform        = "aws"
    managingRoleArn = var.managing_role_arn
  }
  deployment_settings = merge(jsondecode(var.deployment_settings_json), { network = jsondecode(var.network_mode == "create-new" ? jsonencode({ type = "create", cidr = var.vpc_cidr == "" ? null : var.vpc_cidr, availabilityZones = var.availability_zones }) : var.network_mode == "use-existing" ? jsonencode({ type = "byo-vpc-aws", vpcId = var.vpc_id, publicSubnetIds = var.public_subnet_ids, privateSubnetIds = var.private_subnet_ids, securityGroupIds = var.security_group_ids }) : jsonencode({ type = "use-default" })) })
  deployment_resources = [
    {
      id   = "default-network"
      type = "network"
      importData = {
        vpcId               = var.network_mode == "create-new" ? aws_vpc.default_network[0].id : var.network_mode == "use-existing" ? var.vpc_id : null
        cidrBlock           = var.network_mode == "create-new" ? aws_vpc.default_network[0].cidr_block : null
        internetGatewayId   = var.network_mode == "create-new" ? aws_internet_gateway.default_network[0].id : null
        natGatewayId        = var.network_mode == "create-new" ? aws_nat_gateway.default_network[0].id : null
        eipAllocationId     = var.network_mode == "create-new" ? aws_eip.default_network_nat[0].id : null
        publicSubnetIds     = var.network_mode == "create-new" ? aws_subnet.default_network_public[*].id : var.network_mode == "use-existing" ? var.public_subnet_ids : []
        privateSubnetIds    = var.network_mode == "create-new" ? aws_subnet.default_network_private[*].id : var.network_mode == "use-existing" ? var.private_subnet_ids : []
        publicRouteTableId  = var.network_mode == "create-new" ? aws_route_table.default_network_public[0].id : null
        privateRouteTableId = var.network_mode == "create-new" ? aws_route_table.default_network_private[0].id : null
        securityGroupId     = var.network_mode == "create-new" ? aws_security_group.default_network_workload[0].id : var.network_mode == "use-existing" ? try(var.security_group_ids[0], null) : null
        availabilityZones   = var.network_mode == "use-default" ? [] : slice(data.aws_availability_zones.available.names, 0, 2)
        isByoVpc            = false
      }
    }
  ]
}

=== default_network.tf ===
data "aws_availability_zones" "available" {
  state = "available"
}

resource "aws_vpc" "default_network" {
  count                = var.network_mode == "create-new" ? 1 : 0
  cidr_block           = var.vpc_cidr == "" ? "10.42.0.0/16" : var.vpc_cidr
  enable_dns_support   = true
  enable_dns_hostnames = true
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_internet_gateway" "default_network" {
  count  = var.network_mode == "create-new" ? 1 : 0
  vpc_id = aws_vpc.default_network[0].id
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_subnet" "default_network_public" {
  count                   = var.network_mode == "create-new" ? var.availability_zones : 0
  vpc_id                  = aws_vpc.default_network[0].id
  cidr_block              = cidrsubnet(aws_vpc.default_network[0].cidr_block, 8, count.index)
  availability_zone       = data.aws_availability_zones.available.names[count.index]
  map_public_ip_on_launch = true
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_subnet" "default_network_private" {
  count             = var.network_mode == "create-new" ? var.availability_zones : 0
  vpc_id            = aws_vpc.default_network[0].id
  cidr_block        = cidrsubnet(aws_vpc.default_network[0].cidr_block, 8, count.index + var.availability_zones)
  availability_zone = data.aws_availability_zones.available.names[count.index]
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_eip" "default_network_nat" {
  count  = var.network_mode == "create-new" ? 1 : 0
  domain = "vpc"
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_nat_gateway" "default_network" {
  count         = var.network_mode == "create-new" ? 1 : 0
  allocation_id = aws_eip.default_network_nat[0].id
  subnet_id     = aws_subnet.default_network_public[0].id
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_route_table" "default_network_public" {
  count  = var.network_mode == "create-new" ? 1 : 0
  vpc_id = aws_vpc.default_network[0].id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.default_network[0].id
  }

  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_route_table" "default_network_private" {
  count  = var.network_mode == "create-new" ? 1 : 0
  vpc_id = aws_vpc.default_network[0].id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.default_network[0].id
  }

  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_route_table_association" "default_network_public" {
  count          = var.network_mode == "create-new" ? var.availability_zones : 0
  subnet_id      = aws_subnet.default_network_public[count.index].id
  route_table_id = aws_route_table.default_network_public[0].id
}

resource "aws_route_table_association" "default_network_private" {
  count          = var.network_mode == "create-new" ? var.availability_zones : 0
  subnet_id      = aws_subnet.default_network_private[count.index].id
  route_table_id = aws_route_table.default_network_private[0].id
}

resource "aws_security_group" "default_network_workload" {
  count       = var.network_mode == "create-new" ? 1 : 0
  name_prefix = "${local.resource_prefix}-workload-"
  description = "Private workload security group"
  vpc_id      = aws_vpc.default_network[0].id

  egress {
    from_port = 0
    to_port   = 0
    protocol  = "-1"
    cidr_blocks = [
      "0.0.0.0/0"
    ]
  }

  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                  = local.deployment_platform
    token                     = var.token
    name                      = var.name
    resource_prefix           = local.resource_prefix
    setup_target              = ""
    setup_fingerprint         = ""
    setup_fingerprint_version = 0
    manager_url               = var.manager_url
    management_config         = local.deployment_management_config
    deployment_settings       = local.deployment_settings
    resources                 = local.deployment_resources
  }
  depends_on = [
    aws_vpc.default_network,
    aws_internet_gateway.default_network,
    aws_subnet.default_network_public,
    aws_subnet.default_network_private,
    aws_eip.default_network_nat,
    aws_nat_gateway.default_network,
    aws_route_table.default_network_public,
    aws_route_table.default_network_private,
    aws_route_table_association.default_network_public,
    aws_route_table_association.default_network_private,
    aws_security_group.default_network_workload
  ]
}

=== outputs.tf ===
output "deployment_target" {
  value       = "aws"
  description = "Terraform module target."
}

output "deployment_resource_prefix" {
  value       = local.resource_prefix
  description = "Stable physical resource prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_setup_target" {
  value       = ""
  description = "Setup target."
}

output "deployment_setup_fingerprint" {
  value       = ""
  description = "Setup compatibility fingerprint."
}

output "deployment_setup_fingerprint_version" {
  value       = 0
  description = "Setup fingerprint algorithm version."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_settings_json" {
  value       = jsonencode(local.deployment_settings)
  description = "Manager import deployment settings JSON."
  sensitive   = true
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-net

Target: `aws`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='name=acme-net' -var='token=...'
```

This module exposes `deployment_management_config` / `deployment_settings_json` / `deployment_resources` for external registration flows.

---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

=== variables.tf ===
variable "stack_name" {
  type        = string
  description = "Stable physical-name prefix for resources created by this module."
}

variable "deployment_name" {
  type        = string
  description = "Deployment name used when registering the resolved stack import. Defaults to stack_name."
  default     = ""
}

variable "deployment_group_token" {
  type        = string
  description = "Deployment group token used when registering the resolved stack import."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "aws_region" {
  type        = string
  description = "AWS region used by the AWS provider."
  default     = "us-east-1"
}

variable "managing_role_arn" {
  type        = string
  description = "ARN of the manager IAM identity allowed to assume management roles."
  default     = ""
}

variable "managing_account_id" {
  type        = string
  description = "AWS account ID hosting the manager. Referenced by stack-side IAM policies that scope cross-account ECR pulls. Empty disables those grants."
  default     = ""
}

=== providers.tf ===
provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

=== locals.tf ===
locals {
  deployment_platform = "aws"
  deployment_target   = "aws"
  deployment_region   = data.aws_region.current.region
  deployment_management_config = {
    platform        = "aws"
    managingRoleArn = data.aws_caller_identity.current.arn
  }
  deployment_stack_settings = {}
  deployment_resources = [
    {
      id   = "public-api"
      type = "function"
      import_data = {
        functionName                      = aws_lambda_function.public_api.function_name
        functionArn                       = aws_lambda_function.public_api.arn
        eventSourceMappings               = []
        eventbridgeRuleNames              = []
        s3PermissionStatementIds          = []
        eventbridgePermissionStatementIds = []
        url                               = aws_apigatewayv2_api.public_api.api_endpoint
        apiId                             = aws_apigatewayv2_api.public_api.id
        integrationId                     = aws_apigatewayv2_integration.public_api.id
        routeId                           = aws_apigatewayv2_route.public_api.id
        stageName                         = "$default"
      }
    }
  ]
}

=== public_api.tf ===
resource "aws_iam_role" "public_api_role" {
  name               = "${var.stack_name}-public-api-fn"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { Service = "lambda.amazonaws.com" }, Action = "sts:AssumeRole" }] })
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "public-api"
    AlienResourceType = "function"
  }

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_iam_role_policy" "public_api_role_inline" {
  name   = "alien-managed-policy"
  role   = aws_iam_role.public_api_role.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "WriteLogs", Effect = "Allow", Action = ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"], Resource = "*" }] })

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_cloudwatch_log_group" "public_api_logs" {
  name              = "/aws/lambda/${var.stack_name}-public-api"
  retention_in_days = 30
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "public-api"
    AlienResourceType = "function"
  }

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_lambda_function" "public_api" {
  function_name = "${var.stack_name}-public-api"
  package_type  = "Image"
  image_uri     = "123456789012.dkr.ecr.us-east-1.amazonaws.com/app:1"
  role          = aws_iam_role.public_api_role.arn
  memory_size   = 512
  timeout       = 60

  environment {
    variables = {
      ALIEN_CURRENT_FUNCTION_BINDING_NAME = "public-api"
      ALIEN_DEPLOYMENT_TYPE               = "aws"
      ALIEN_LAMBDA_MODE                   = "buffered"
      ALIEN_RUNTIME_SEND_OTLP             = "true"
      ALIEN_TRANSPORT                     = "lambda"
      AWS_ACCOUNT_ID                      = data.aws_caller_identity.current.account_id
    }
  }

  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "public-api"
    AlienResourceType = "function"
  }

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_apigatewayv2_api" "public_api" {
  name          = "${var.stack_name}-public_api-api"
  protocol_type = "HTTP"

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_apigatewayv2_integration" "public_api" {
  api_id                 = aws_apigatewayv2_api.public_api.id
  integration_type       = "AWS_PROXY"
  integration_method     = "POST"
  integration_uri        = aws_lambda_function.public_api.invoke_arn
  payload_format_version = "2.0"

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_apigatewayv2_route" "public_api" {
  api_id    = aws_apigatewayv2_api.public_api.id
  route_key = "ANY /{proxy+}"
  target    = "integrations/${aws_apigatewayv2_integration.public_api.id}"

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_apigatewayv2_stage" "public_api" {
  api_id      = aws_apigatewayv2_api.public_api.id
  name        = "$default"
  auto_deploy = true

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

resource "aws_lambda_permission" "public_api_api" {
  statement_id  = "public_apiApiInvoke"
  action        = "lambda:InvokeFunction"
  function_name = aws_lambda_function.public_api.function_name
  principal     = "apigateway.amazonaws.com"
  source_arn    = "${aws_apigatewayv2_api.public_api.execution_arn}/*/*"

  lifecycle {
    ignore_changes  = all
    prevent_destroy = true
  }
}

=== import.tf ===
resource "terraform_data" "deployment_stack_import" {
  input = {
    platform               = local.deployment_platform
    deployment_group_token = var.deployment_group_token
    deployment_name        = var.deployment_name == "" ? var.stack_name : var.deployment_name
    stack_prefix           = var.stack_name
    manager_url            = var.manager_url
    management_config      = local.deployment_management_config
    stack_settings         = local.deployment_stack_settings
    resources              = local.deployment_resources
  }
}

=== outputs.tf ===
output "deployment_target" {
  value       = "aws"
  description = "Terraform module target."
}

output "deployment_stack_prefix" {
  value       = var.stack_name
  description = "Physical stack prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_stack_settings" {
  value       = jsonencode(local.deployment_stack_settings)
  description = "Manager import StackSettings JSON."
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-public

Target: `aws`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='stack_name=acme-public' -var='deployment_group_token=...'
```

This module exposes `deployment_management_config` / `deployment_stack_settings` / `deployment_resources` for external registration flows.

---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 5.0"
    }
  }
}

=== variables.tf ===
variable "stack_name" {
  type        = string
  description = "Stable physical-name prefix for resources created by this module."
}

variable "deployment_name" {
  type        = string
  description = "Deployment name used when registering the resolved stack import. Defaults to stack_name."
  default     = ""
}

variable "deployment_group_token" {
  type        = string
  description = "Deployment group token used when registering the resolved stack import."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "gcp_project" {
  type        = string
  description = "GCP project ID."
}

variable "gcp_region" {
  type        = string
  description = "GCP region."
  default     = "us-central1"
}

variable "managing_service_account_email" {
  type        = string
  description = "Email of the manager's service account that may impersonate the management identity. Empty disables the binding."
  default     = ""
}

=== providers.tf ===
provider "google" {
  project = var.gcp_project
  region  = var.gcp_region
}

=== locals.tf ===
locals {
  deployment_platform = "gcp"
  deployment_target   = "gcp"
  deployment_region   = var.gcp_region
  deployment_management_config = {
    platform            = "gcp"
    projectId           = var.gcp_project
    serviceAccountEmail = var.managing_service_account_email
  }
  deployment_stack_settings = {}
  deployment_resources = [
    {
      id   = "jobs"
      type = "queue"
      import_data = {
        projectId        = var.gcp_project
        topicId          = google_pubsub_topic.jobs.name
        topicName        = google_pubsub_topic.jobs.id
        subscriptionId   = google_pubsub_subscription.jobs.name
        subscriptionName = google_pubsub_subscription.jobs.id
      }
    },
    {
      id   = "assets"
      type = "storage"
      import_data = {
        bucketName     = google_storage_bucket.assets.name
        bucketSelfLink = google_storage_bucket.assets.self_link
        projectId      = var.gcp_project
        location       = google_storage_bucket.assets.location
      }
    },
    {
      id   = "worker"
      type = "function"
      import_data = {
        projectId   = var.gcp_project
        region      = var.gcp_region
        serviceName = google_cloud_run_v2_service.worker.name
        url         = null
        pubsubSubscriptionNames = [
          google_pubsub_subscription.worker_queue_0.name
        ]
        schedulerJobNames = [
          google_cloud_scheduler_job.worker_schedule_1.name
        ]
        eventarcTriggerNames = [
          google_eventarc_trigger.worker_storage_2.name
        ]
        commandsTopicName        = null
        commandsSubscriptionName = null
      }
    }
  ]
}

=== jobs.tf ===
resource "google_pubsub_topic" "jobs" {
  name    = "${var.stack_name}-jobs"
  project = var.gcp_project
  labels = {
    "managed-by"          = "alien-dev"
    "alien-stack-id"      = var.stack_name
    "alien-resource-id"   = "jobs"
    "alien-resource-type" = "queue"
  }
}

resource "google_pubsub_subscription" "jobs" {
  name                       = "${var.stack_name}-jobs-default"
  project                    = var.gcp_project
  topic                      = google_pubsub_topic.jobs.id
  ack_deadline_seconds       = 120
  message_retention_duration = "604800s"
  enable_message_ordering    = false

  expiration_policy {
    ttl = ""
  }

  labels = {
    "managed-by"          = "alien-dev"
    "alien-stack-id"      = var.stack_name
    "alien-resource-id"   = "jobs"
    "alien-resource-type" = "queue"
  }
}

=== assets.tf ===
resource "google_storage_bucket" "assets" {
  name                        = "${var.stack_name}-assets"
  project                     = var.gcp_project
  location                    = upper(var.gcp_region)
  storage_class               = "STANDARD"
  uniform_bucket_level_access = true
  force_destroy               = false
  public_access_prevention    = "enforced"
  labels = {
    "managed-by"          = "alien-dev"
    "alien-stack-id"      = var.stack_name
    "alien-resource-id"   = "assets"
    "alien-resource-type" = "storage"
  }
}

=== worker.tf ===
resource "google_cloud_run_v2_service" "worker" {
  name     = "${var.stack_name}-worker"
  project  = var.gcp_project
  location = var.gcp_region
  ingress  = "INGRESS_TRAFFIC_INTERNAL_ONLY"
  labels = {
    "managed-by"          = "alien-dev"
    "alien-stack-id"      = var.stack_name
    "alien-resource-id"   = "worker"
    "alien-resource-type" = "function"
  }

  template {
    timeout = "60s"

    containers {
      image = "us-central1-docker.pkg.dev/proj/app/worker:1"

      resources {
        limits = {
          cpu    = "1"
          memory = "512Mi"
        }
        cpu_idle = true
      }

      env {
        name  = "ALIEN_CURRENT_FUNCTION_BINDING_NAME"
        value = "worker"
      }

      env {
        name  = "ALIEN_DEPLOYMENT_TYPE"
        value = "gcp"
      }

      env {
        name  = "ALIEN_RUNTIME_SEND_OTLP"
        value = "true"
      }

      env {
        name  = "ALIEN_TRANSPORT"
        value = "cloud-run"
      }

      env {
        name  = "GCP_PROJECT_ID"
        value = var.gcp_project
      }

      env {
        name  = "GCP_REGION"
        value = var.gcp_region
      }

      env {
        name  = "GOOGLE_CLOUD_PROJECT"
        value = var.gcp_project
      }
    }
  }

  lifecycle {
    ignore_changes = all
  }
}

resource "google_pubsub_subscription" "worker_queue_0" {
  name                 = "${var.stack_name}-worker-from-jobs"
  project              = var.gcp_project
  topic                = google_pubsub_topic.jobs.id
  ack_deadline_seconds = 120

  push_config {
    push_endpoint = google_cloud_run_v2_service.worker.uri
  }

  lifecycle {
    ignore_changes = all
  }
}

resource "google_cloud_scheduler_job" "worker_schedule_1" {
  name      = "${var.stack_name}-worker-sched-1"
  project   = var.gcp_project
  region    = var.gcp_region
  schedule  = "*/5 * * * *"
  time_zone = "Etc/UTC"

  http_target {
    uri         = google_cloud_run_v2_service.worker.uri
    http_method = "POST"
  }

  lifecycle {
    ignore_changes = all
  }
}

resource "google_eventarc_trigger" "worker_storage_2" {
  name     = "${var.stack_name}-worker-assets-storage"
  project  = var.gcp_project
  location = var.gcp_region

  matching_criteria {
    attribute = "type"
    value     = "google.cloud.storage.object.v1.finalized"
  }

  matching_criteria {
    attribute = "bucket"
    value     = google_storage_bucket.assets.name
  }

  destination {
    cloud_run_service {
      service = google_cloud_run_v2_service.worker.name
      region  = google_cloud_run_v2_service.worker.location
    }
  }

  lifecycle {
    ignore_changes = all
  }
}

=== import.tf ===
resource "terraform_data" "deployment_stack_import" {
  input = {
    platform               = local.deployment_platform
    deployment_group_token = var.deployment_group_token
    deployment_name        = var.deployment_name == "" ? var.stack_name : var.deployment_name
    stack_prefix           = var.stack_name
    manager_url            = var.manager_url
    management_config      = local.deployment_management_config
    stack_settings         = local.deployment_stack_settings
    resources              = local.deployment_resources
  }
}

=== outputs.tf ===
output "deployment_target" {
  value       = "gcp"
  description = "Terraform module target."
}

output "deployment_stack_prefix" {
  value       = var.stack_name
  description = "Physical stack prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_stack_settings" {
  value       = jsonencode(local.deployment_stack_settings)
  description = "Manager import StackSettings JSON."
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-triggers

Target: `gcp`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='stack_name=acme-triggers' -var='deployment_group_token=...'
```

This module exposes `deployment_management_config` / `deployment_stack_settings` / `deployment_resources` for external registration flows.

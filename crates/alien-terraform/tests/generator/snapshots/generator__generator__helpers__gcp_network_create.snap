---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "name" {
  type        = string
  description = "Human-readable deployment name shown in the deployment portal."
}

variable "token" {
  type        = string
  description = "Deployment token from the deployment page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "resource_prefix" {
  type        = string
  description = "Optional stable cloud resource prefix. Leave empty to generate one and store it in Terraform state."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || can(regex("^[a-z][a-z0-9-]{1,30}[a-z0-9]$", var.resource_prefix))
    error_message = "resource_prefix must be empty or 3-32 characters using lowercase letters, numbers, and hyphens, starting with a letter and ending with a letter or number."
  }
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "deployment_settings_json" {
  type        = string
  description = "Optional JSON-encoded deployment settings override supplied by deployment installers."
  default     = "{\"network\":{\"type\":\"create\",\"cidr\":\"10.42.0.0/16\",\"availability_zones\":2}}"
  sensitive   = true
}

variable "gcp_project" {
  type        = string
  description = "GCP project ID."
}

variable "gcp_region" {
  type        = string
  description = "GCP region."
  default     = "us-central1"
}

variable "managing_service_account_email" {
  type        = string
  description = "Email of the manager's service account that may impersonate the management identity. Empty disables the binding."
  default     = ""
}

=== providers.tf ===
provider "google" {
  project = var.gcp_project
  region  = var.gcp_region
}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 8
}

=== locals.tf ===
locals {
  resource_prefix     = var.resource_prefix != "" ? var.resource_prefix : "a${random_id.resource_prefix.hex}"
  deployment_platform = "gcp"
  deployment_target   = "gcp"
  deployment_region   = var.gcp_region
  deployment_management_config = {
    platform            = "gcp"
    projectId           = var.gcp_project
    serviceAccountEmail = var.managing_service_account_email
  }
  deployment_settings = jsondecode(var.deployment_settings_json)
  deployment_resources = [
    {
      id   = "default-network"
      type = "network"
      importData = {
        projectId   = var.gcp_project
        vpcSelfLink = google_compute_network.default_network.self_link
        vpcName     = google_compute_network.default_network.name
        subnetSelfLinks = [
          google_compute_subnetwork.default_network_workload.self_link
        ]
        routerSelfLink = google_compute_router.default_network_router.self_link
        natName        = google_compute_router_nat.default_network_nat.name
        isByoVpc       = false
      }
    }
  ]
}

=== default_network.tf ===
resource "google_compute_network" "default_network" {
  name                    = "${local.resource_prefix}-default_network"
  project                 = var.gcp_project
  auto_create_subnetworks = false
  routing_mode            = "REGIONAL"
}

resource "google_compute_subnetwork" "default_network_workload" {
  name                     = "${local.resource_prefix}-default_network-workload"
  project                  = var.gcp_project
  region                   = var.gcp_region
  ip_cidr_range            = "10.42.0.0/16"
  network                  = google_compute_network.default_network.id
  private_ip_google_access = true
}

resource "google_compute_router" "default_network_router" {
  name    = "${local.resource_prefix}-default_network-router"
  project = var.gcp_project
  region  = var.gcp_region
  network = google_compute_network.default_network.id
}

resource "google_compute_router_nat" "default_network_nat" {
  name                               = "${local.resource_prefix}-default_network-nat"
  project                            = var.gcp_project
  region                             = var.gcp_region
  router                             = google_compute_router.default_network_router.name
  nat_ip_allocate_option             = "AUTO_ONLY"
  source_subnetwork_ip_ranges_to_nat = "ALL_SUBNETWORKS_ALL_IP_RANGES"

  log_config {
    enable = true
    filter = "ERRORS_ONLY"
  }
}

resource "google_compute_firewall" "default_network_internal" {
  name      = "${local.resource_prefix}-default_network-internal"
  project   = var.gcp_project
  network   = google_compute_network.default_network.id
  direction = "INGRESS"
  source_ranges = [
    "10.42.0.0/16"
  ]

  allow {
    protocol = "all"
  }
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                  = local.deployment_platform
    token                     = var.token
    name                      = var.name
    resource_prefix           = local.resource_prefix
    setup_target              = ""
    setup_fingerprint         = ""
    setup_fingerprint_version = 0
    manager_url               = var.manager_url
    management_config         = local.deployment_management_config
    deployment_settings       = local.deployment_settings
    resources                 = local.deployment_resources
  }
  depends_on = [
    google_compute_network.default_network,
    google_compute_subnetwork.default_network_workload,
    google_compute_router.default_network_router,
    google_compute_router_nat.default_network_nat,
    google_compute_firewall.default_network_internal
  ]
}

=== outputs.tf ===
output "deployment_target" {
  value       = "gcp"
  description = "Terraform module target."
}

output "deployment_resource_prefix" {
  value       = local.resource_prefix
  description = "Stable physical resource prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_setup_target" {
  value       = ""
  description = "Setup target."
}

output "deployment_setup_fingerprint" {
  value       = ""
  description = "Setup compatibility fingerprint."
}

output "deployment_setup_fingerprint_version" {
  value       = 0
  description = "Setup fingerprint algorithm version."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_settings_json" {
  value       = jsonencode(local.deployment_settings)
  description = "Manager import deployment settings JSON."
  sensitive   = true
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-net

Target: `gcp`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='name=acme-net' -var='token=...'
```

This module exposes `deployment_management_config` / `deployment_settings_json` / `deployment_resources` for external registration flows.

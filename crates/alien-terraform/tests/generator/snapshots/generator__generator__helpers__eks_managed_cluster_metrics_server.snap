---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
    tls = {
      source  = "hashicorp/tls"
      version = ">= 4.0"
    }
    kubernetes = {
      source  = "hashicorp/kubernetes"
      version = ">= 2.30"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "resource_prefix" {
  type        = string
  description = "Optional stable physical resource prefix. Leave empty to generate one."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || (can(regex("^[a-z][a-z0-9-]{1,38}[a-z0-9]$", var.resource_prefix)) && length(regexall("--", var.resource_prefix)) == 0)
    error_message = "resource_prefix must be 3-40 characters: lowercase letters, numbers, and hyphens; start with a letter; end with a letter or number; and not contain consecutive hyphens."
  }
}

variable "name" {
  type        = string
  description = "Human-readable application name shown in setup and cloud IAM review metadata."
}

variable "token" {
  type        = string
  description = "Install token from the application setup page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "stack_settings_json" {
  type        = string
  description = "Optional JSON-encoded StackSettings override supplied by deployment installers."
  default     = "{}"
  sensitive   = true
}

variable "aws_region" {
  type        = string
  description = "AWS region used by the AWS provider."
  default     = "us-east-1"
}

variable "managing_role_arn" {
  type        = string
  description = "ARN of the manager IAM identity allowed to assume management roles."
  default     = ""
}

variable "managing_account_id" {
  type        = string
  description = "Account ID hosting the manager. Referenced by resource-side IAM policies that scope cross-account image pulls. Empty disables those grants."
  default     = ""
}

variable "kubernetes_cluster_mode" {
  type        = string
  description = "Kubernetes cluster mode. Values: create or existing."
  default     = "create"
}

variable "install_metrics_server" {
  type        = bool
  description = "Whether to install metrics-server into Kubernetes clusters created by this module."
  default     = true
}

variable "kubernetes_namespace" {
  type        = string
  description = "Kubernetes namespace for runtime resources."
  default     = "default"
}

variable "eks_cluster_name" {
  type        = string
  description = "Existing EKS cluster name that Helm will install into."
  default     = ""
}

=== providers.tf ===
provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

provider "kubernetes" {
  host                   = data.aws_eks_cluster.target.endpoint
  cluster_ca_certificate = base64decode(data.aws_eks_cluster.target.certificate_authority[0].data)
  token                  = data.aws_eks_cluster_auth.target.token
}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 4
}

=== locals.tf ===
locals {
  resource_prefix          = var.resource_prefix == "" ? format("a%s", random_id.resource_prefix.hex) : var.resource_prefix
  deployment_name          = var.name
  deployment_platform      = "kubernetes"
  deployment_base_platform = "aws"
  deployment_target        = "eks"
  deployment_region        = data.aws_region.current.region
  deployment_management_config = {
    platform        = "aws"
    managingRoleArn = var.managing_role_arn
  }
  deployment_kubernetes_settings = merge(try(jsondecode(var.stack_settings_json).kubernetes, {}), { exposure = coalesce(try(jsondecode(var.stack_settings_json).kubernetes.exposure, null), local.kubernetes_exposure) })
  deployment_settings            = merge(jsondecode(var.stack_settings_json), { kubernetes = local.deployment_kubernetes_settings })
  deployment_resources = [
    {
      id   = "kubernetes"
      type = "kubernetes-cluster"
      importData = {
        provider           = "eks"
        ownership          = var.kubernetes_cluster_mode == "create" ? "managed" : "managed"
        namespace          = var.kubernetes_namespace
        clusterName        = local.kubernetes_cluster_name
        clusterId          = local.kubernetes_cluster_name
        cloudMetadataReady = true
      }
    }
  ]
  kubernetes_cluster_name = var.kubernetes_cluster_mode == "create" ? aws_eks_cluster.kubernetes[0].name : var.eks_cluster_name
  kubernetes_kube_context = local.kubernetes_cluster_name
  kubernetes_kubeconfig   = var.kubernetes_cluster_mode == "create" ? yamlencode({ apiVersion = "v1", kind = "Config", clusters = [{ name = aws_eks_cluster.kubernetes[0].name, cluster = { server = aws_eks_cluster.kubernetes[0].endpoint, "certificate-authority-data" = aws_eks_cluster.kubernetes[0].certificate_authority[0].data } }], contexts = [{ name = aws_eks_cluster.kubernetes[0].name, context = { cluster = aws_eks_cluster.kubernetes[0].name, user = aws_eks_cluster.kubernetes[0].name } }], "current-context" = aws_eks_cluster.kubernetes[0].name, users = [{ name = aws_eks_cluster.kubernetes[0].name, user = { exec = { apiVersion = "client.authentication.k8s.io/v1beta1", command = "aws", args = ["eks", "get-token", "--cluster-name", aws_eks_cluster.kubernetes[0].name, "--region", var.aws_region] } } }] }) : ""
  kubernetes_exposure = {
    mode = "generated"
    route = {
      routeApi         = "ingress"
      controller       = "eks.amazonaws.com/alb"
      ingressClassName = "alb"
      labels           = {}
      annotations      = {}
      provider = {
        provider   = "awsAlb"
        scheme     = "internet-facing"
        targetType = "ip"
        subnetIds  = var.kubernetes_cluster_mode == "create" ? aws_subnet.kubernetes_public[*].id : []
      }
    }
    certificate = {
      mode   = "managedAcmImport"
      region = var.aws_region
      tags = {
        "alien.dev/resource-prefix" = local.resource_prefix
        "alien.dev/managed-by"      = "alien"
      }
    }
  }
  eks_oidc_issuer_host_path = trimprefix(data.aws_eks_cluster.target.identity[0].oidc[0].issuer, "https://")
  eks_oidc_provider_arn     = var.kubernetes_cluster_mode == "create" ? aws_iam_openid_connect_provider.eks[0].arn : data.aws_iam_openid_connect_provider.eks_existing[0].arn
  helm_service_accounts     = {}
  helm_manager_service_account = {
    annotations = {}
    labels      = {}
  }
  helm_values = {
    serviceAccounts       = local.helm_service_accounts
    managerServiceAccount = local.helm_manager_service_account
    stackSettings         = local.deployment_settings
    basePlatform          = local.deployment_base_platform
    serviceAccountPrefix  = local.resource_prefix
    heartbeat = {
      collection = {
        nodes = {
          enabled = true
        }
      }
    }
  }
}

=== kubernetes.tf ===
data "aws_availability_zones" "kubernetes_available" {
  count = var.kubernetes_cluster_mode == "create" ? 1 : 0
  state = "available"
}

data "aws_eks_cluster" "kubernetes_existing" {
  count = var.kubernetes_cluster_mode == "existing" ? 1 : 0
  name  = var.eks_cluster_name
}

data "aws_eks_cluster" "target" {
  name = local.kubernetes_cluster_name
  depends_on = [
    aws_eks_cluster.kubernetes
  ]
}

data "aws_eks_cluster_auth" "target" {
  name = local.kubernetes_cluster_name
}

data "tls_certificate" "eks_oidc" {
  url = data.aws_eks_cluster.target.identity[0].oidc[0].issuer
}

data "aws_iam_openid_connect_provider" "eks_existing" {
  count = var.kubernetes_cluster_mode == "existing" ? 1 : 0
  url   = data.aws_eks_cluster.target.identity[0].oidc[0].issuer
}

resource "aws_iam_openid_connect_provider" "eks" {
  count = var.kubernetes_cluster_mode == "create" ? 1 : 0
  url   = data.aws_eks_cluster.target.identity[0].oidc[0].issuer
  client_id_list = [
    "sts.amazonaws.com"
  ]
  thumbprint_list = [
    data.tls_certificate.eks_oidc.certificates[0].sha1_fingerprint
  ]
  tags = {
    Name                    = "${local.resource_prefix}-eks-oidc"
    "alien-resource-prefix" = local.resource_prefix
  }
}

resource "aws_vpc" "kubernetes" {
  count                = var.kubernetes_cluster_mode == "create" ? 1 : 0
  cidr_block           = "10.251.0.0/16"
  enable_dns_hostnames = true
  enable_dns_support   = true
  tags = {
    Name = "$${local.resource_prefix}-kubernetes"
  }
}

resource "aws_internet_gateway" "kubernetes" {
  count  = var.kubernetes_cluster_mode == "create" ? 1 : 0
  vpc_id = aws_vpc.kubernetes[0].id
  tags = {
    Name = "$${local.resource_prefix}-kubernetes"
  }
}

resource "aws_subnet" "kubernetes_public" {
  count                   = var.kubernetes_cluster_mode == "create" ? 2 : 0
  vpc_id                  = aws_vpc.kubernetes[0].id
  cidr_block              = cidrsubnet(aws_vpc.kubernetes[0].cidr_block, 8, count.index)
  availability_zone       = data.aws_availability_zones.kubernetes_available[0].names[count.index]
  map_public_ip_on_launch = true
  tags = {
    Name                                                  = "$${local.resource_prefix}-kubernetes-public"
    "kubernetes.io/cluster/$${local.resource_prefix}-k8s" = "shared"
    "kubernetes.io/role/elb"                              = "1"
  }
}

resource "aws_subnet" "kubernetes_private" {
  count             = var.kubernetes_cluster_mode == "create" ? 2 : 0
  vpc_id            = aws_vpc.kubernetes[0].id
  cidr_block        = cidrsubnet(aws_vpc.kubernetes[0].cidr_block, 8, count.index + 10)
  availability_zone = data.aws_availability_zones.kubernetes_available[0].names[count.index]
  tags = {
    Name                                                  = "$${local.resource_prefix}-kubernetes-private"
    "kubernetes.io/cluster/$${local.resource_prefix}-k8s" = "shared"
    "kubernetes.io/role/internal-elb"                     = "1"
  }
}

resource "aws_eip" "kubernetes_nat" {
  count  = var.kubernetes_cluster_mode == "create" ? 1 : 0
  domain = "vpc"
  tags = {
    Name = "$${local.resource_prefix}-kubernetes-nat"
  }
}

resource "aws_nat_gateway" "kubernetes" {
  count         = var.kubernetes_cluster_mode == "create" ? 1 : 0
  allocation_id = aws_eip.kubernetes_nat[0].id
  subnet_id     = aws_subnet.kubernetes_public[0].id
  tags = {
    Name = "$${local.resource_prefix}-kubernetes"
  }
}

resource "aws_route_table" "kubernetes_public" {
  count  = var.kubernetes_cluster_mode == "create" ? 1 : 0
  vpc_id = aws_vpc.kubernetes[0].id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.kubernetes[0].id
  }

  tags = {
    Name = "$${local.resource_prefix}-kubernetes-public"
  }
}

resource "aws_route_table" "kubernetes_private" {
  count  = var.kubernetes_cluster_mode == "create" ? 1 : 0
  vpc_id = aws_vpc.kubernetes[0].id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.kubernetes[0].id
  }

  tags = {
    Name = "$${local.resource_prefix}-kubernetes-private"
  }
}

resource "aws_route_table_association" "kubernetes_public" {
  count          = var.kubernetes_cluster_mode == "create" ? 2 : 0
  subnet_id      = aws_subnet.kubernetes_public[count.index].id
  route_table_id = aws_route_table.kubernetes_public[0].id
}

resource "aws_route_table_association" "kubernetes_private" {
  count          = var.kubernetes_cluster_mode == "create" ? 2 : 0
  subnet_id      = aws_subnet.kubernetes_private[count.index].id
  route_table_id = aws_route_table.kubernetes_private[0].id
}

resource "aws_iam_role" "kubernetes_cluster" {
  count              = var.kubernetes_cluster_mode == "create" ? 1 : 0
  name               = "${local.resource_prefix}-kubernetes-eks"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { Service = "eks.amazonaws.com" }, Action = ["sts:AssumeRole", "sts:TagSession"] }] })
}

resource "aws_iam_role_policy_attachment" "kubernetes_cluster" {
  for_each   = var.kubernetes_cluster_mode == "create" ? toset(["arn:aws:iam::aws:policy/AmazonEKSClusterPolicy", "arn:aws:iam::aws:policy/AmazonEKSBlockStoragePolicy", "arn:aws:iam::aws:policy/AmazonEKSComputePolicy", "arn:aws:iam::aws:policy/AmazonEKSLoadBalancingPolicy", "arn:aws:iam::aws:policy/AmazonEKSNetworkingPolicy"]) : toset([])
  role       = aws_iam_role.kubernetes_cluster[0].name
  policy_arn = each.value
}

resource "aws_iam_role" "kubernetes_node" {
  count              = var.kubernetes_cluster_mode == "create" ? 1 : 0
  name               = "${local.resource_prefix}-kubernetes-node"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { Service = "ec2.amazonaws.com" }, Action = "sts:AssumeRole" }] })
}

resource "aws_iam_role_policy_attachment" "kubernetes_node" {
  for_each   = var.kubernetes_cluster_mode == "create" ? toset(["arn:aws:iam::aws:policy/AmazonEKSWorkerNodePolicy", "arn:aws:iam::aws:policy/AmazonEC2ContainerRegistryPullOnly", "arn:aws:iam::aws:policy/AmazonEKS_CNI_Policy", "arn:aws:iam::aws:policy/AmazonEKSWorkerNodeMinimalPolicy"]) : toset([])
  role       = aws_iam_role.kubernetes_node[0].name
  policy_arn = each.value
}

resource "aws_iam_role" "kubernetes_managed_node" {
  count              = var.kubernetes_cluster_mode == "create" ? 1 : 0
  name               = "${local.resource_prefix}-kubernetes-mng-node"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { Service = "ec2.amazonaws.com" }, Action = "sts:AssumeRole" }] })
}

resource "aws_iam_role_policy_attachment" "kubernetes_managed_node" {
  for_each   = var.kubernetes_cluster_mode == "create" ? toset(["arn:aws:iam::aws:policy/AmazonEKSWorkerNodePolicy", "arn:aws:iam::aws:policy/AmazonEC2ContainerRegistryPullOnly", "arn:aws:iam::aws:policy/AmazonEKS_CNI_Policy"]) : toset([])
  role       = aws_iam_role.kubernetes_managed_node[0].name
  policy_arn = each.value
}

resource "aws_eks_cluster" "kubernetes" {
  count                         = var.kubernetes_cluster_mode == "create" ? 1 : 0
  name                          = "${local.resource_prefix}-k8s"
  role_arn                      = aws_iam_role.kubernetes_cluster[0].arn
  bootstrap_self_managed_addons = false

  vpc_config {
    subnet_ids              = concat(aws_subnet.kubernetes_public[*].id, aws_subnet.kubernetes_private[*].id)
    endpoint_public_access  = true
    endpoint_private_access = true
  }

  access_config {
    authentication_mode                         = "API_AND_CONFIG_MAP"
    bootstrap_cluster_creator_admin_permissions = true
  }

  compute_config {
    enabled = true
    node_pools = [
      "general-purpose",
      "system"
    ]
    node_role_arn = aws_iam_role.kubernetes_node[0].arn
  }

  kubernetes_network_config {
    elastic_load_balancing {
      enabled = true
    }
  }

  storage_config {
    block_storage {
      enabled = true
    }
  }

  depends_on = [
    aws_iam_role_policy_attachment.kubernetes_cluster,
    aws_iam_role_policy_attachment.kubernetes_node
  ]
}

resource "aws_eks_addon" "kubernetes_vpc_cni" {
  count        = var.kubernetes_cluster_mode == "create" ? 1 : 0
  cluster_name = aws_eks_cluster.kubernetes[0].name
  addon_name   = "vpc-cni"
}

resource "aws_eks_node_group" "kubernetes" {
  count           = var.kubernetes_cluster_mode == "create" ? 1 : 0
  cluster_name    = aws_eks_cluster.kubernetes[0].name
  node_group_name = "${local.resource_prefix}-kubernetes"
  node_role_arn   = aws_iam_role.kubernetes_managed_node[0].arn
  subnet_ids      = aws_subnet.kubernetes_private[*].id
  ami_type        = "AL2023_ARM_64_STANDARD"
  capacity_type   = "ON_DEMAND"
  disk_size       = 20
  instance_types = [
    "t4g.medium"
  ]

  scaling_config {
    desired_size = 2
    max_size     = 3
    min_size     = 2
  }

  update_config {
    max_unavailable = 1
  }

  depends_on = [
    aws_eks_addon.kubernetes_vpc_cni,
    aws_iam_role_policy_attachment.kubernetes_managed_node
  ]
}

resource "aws_iam_role" "kubernetes_ebs_csi" {
  count              = var.kubernetes_cluster_mode == "create" ? 1 : 0
  name               = "${local.resource_prefix}-kubernetes-ebs-csi"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { Federated = local.eks_oidc_provider_arn }, Action = "sts:AssumeRoleWithWebIdentity", Condition = { StringEquals = { "${local.eks_oidc_issuer_host_path}:aud" = "sts.amazonaws.com", "${local.eks_oidc_issuer_host_path}:sub" = "system:serviceaccount:kube-system:ebs-csi-controller-sa" } } }] })
}

resource "aws_iam_role_policy_attachment" "kubernetes_ebs_csi" {
  count      = var.kubernetes_cluster_mode == "create" ? 1 : 0
  role       = aws_iam_role.kubernetes_ebs_csi[0].name
  policy_arn = "arn:aws:iam::aws:policy/service-role/AmazonEBSCSIDriverPolicy"
}

resource "aws_eks_addon" "kubernetes_ebs_csi" {
  count                    = var.kubernetes_cluster_mode == "create" ? 1 : 0
  cluster_name             = aws_eks_cluster.kubernetes[0].name
  addon_name               = "aws-ebs-csi-driver"
  service_account_role_arn = aws_iam_role.kubernetes_ebs_csi[0].arn
  depends_on = [
    aws_eks_node_group.kubernetes,
    aws_iam_role_policy_attachment.kubernetes_ebs_csi
  ]
}

resource "aws_eks_addon" "kubernetes_kube_proxy" {
  count        = var.kubernetes_cluster_mode == "create" ? 1 : 0
  cluster_name = aws_eks_cluster.kubernetes[0].name
  addon_name   = "kube-proxy"
  depends_on = [
    aws_eks_node_group.kubernetes
  ]
}

resource "aws_eks_addon" "kubernetes_coredns" {
  count        = var.kubernetes_cluster_mode == "create" ? 1 : 0
  cluster_name = aws_eks_cluster.kubernetes[0].name
  addon_name   = "coredns"
  depends_on = [
    aws_eks_node_group.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_gp3_storage_class" {
  count = var.kubernetes_cluster_mode == "create" ? 1 : 0
  manifest = {
    apiVersion = "storage.k8s.io/v1"
    kind       = "StorageClass"
    metadata = {
      name = "gp3"
      annotations = {
        "storageclass.kubernetes.io/is-default-class" = "true"
      }
    }
    provisioner = "ebs.csi.aws.com"
    parameters = {
      type   = "gp3"
      fsType = "ext4"
    }
    reclaimPolicy        = "Delete"
    volumeBindingMode    = "WaitForFirstConsumer"
    allowVolumeExpansion = true
  }
  depends_on = [
    aws_eks_addon.kubernetes_ebs_csi
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_service_account" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "v1"
    kind       = "ServiceAccount"
    metadata = {
      name      = "metrics-server"
      namespace = "kube-system"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
  }
  depends_on = [
    aws_eks_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_aggregated_metrics_reader" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "rbac.authorization.k8s.io/v1"
    kind       = "ClusterRole"
    metadata = {
      name = "system:aggregated-metrics-reader"
      labels = {
        "rbac.authorization.k8s.io/aggregate-to-admin" = "true"
        "rbac.authorization.k8s.io/aggregate-to-edit"  = "true"
        "rbac.authorization.k8s.io/aggregate-to-view"  = "true"
      }
    }
    rules = [
      {
        apiGroups = [
          "metrics.k8s.io"
        ]
        resources = [
          "pods",
          "nodes"
        ]
        verbs = [
          "get",
          "list",
          "watch"
        ]
      }
    ]
  }
  depends_on = [
    aws_eks_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_cluster_role" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "rbac.authorization.k8s.io/v1"
    kind       = "ClusterRole"
    metadata = {
      name = "system:metrics-server"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    rules = [
      {
        apiGroups = [
          ""
        ]
        resources = [
          "nodes/metrics"
        ]
        verbs = [
          "get"
        ]
      },
      {
        apiGroups = [
          ""
        ]
        resources = [
          "pods",
          "nodes"
        ]
        verbs = [
          "get",
          "list",
          "watch"
        ]
      }
    ]
  }
  depends_on = [
    aws_eks_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_auth_reader_role_binding" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "rbac.authorization.k8s.io/v1"
    kind       = "RoleBinding"
    metadata = {
      name      = "metrics-server-auth-reader"
      namespace = "kube-system"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    roleRef = {
      apiGroup = "rbac.authorization.k8s.io"
      kind     = "Role"
      name     = "extension-apiserver-authentication-reader"
    }
    subjects = [
      {
        kind      = "ServiceAccount"
        name      = "metrics-server"
        namespace = "kube-system"
      }
    ]
  }
  depends_on = [
    aws_eks_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_auth_delegator_binding" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "rbac.authorization.k8s.io/v1"
    kind       = "ClusterRoleBinding"
    metadata = {
      name = "metrics-server:system:auth-delegator"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    roleRef = {
      apiGroup = "rbac.authorization.k8s.io"
      kind     = "ClusterRole"
      name     = "system:auth-delegator"
    }
    subjects = [
      {
        kind      = "ServiceAccount"
        name      = "metrics-server"
        namespace = "kube-system"
      }
    ]
  }
  depends_on = [
    aws_eks_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_cluster_role_binding" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "rbac.authorization.k8s.io/v1"
    kind       = "ClusterRoleBinding"
    metadata = {
      name = "system:metrics-server"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    roleRef = {
      apiGroup = "rbac.authorization.k8s.io"
      kind     = "ClusterRole"
      name     = "system:metrics-server"
    }
    subjects = [
      {
        kind      = "ServiceAccount"
        name      = "metrics-server"
        namespace = "kube-system"
      }
    ]
  }
  depends_on = [
    aws_eks_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_service" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "v1"
    kind       = "Service"
    metadata = {
      name      = "metrics-server"
      namespace = "kube-system"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    spec = {
      selector = {
        "k8s-app" = "metrics-server"
      }
      ports = [
        {
          name       = "https"
          port       = 443
          protocol   = "TCP"
          targetPort = "https"
        }
      ]
    }
  }
  depends_on = [
    aws_eks_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_deployment" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "apps/v1"
    kind       = "Deployment"
    metadata = {
      name      = "metrics-server"
      namespace = "kube-system"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    spec = {
      selector = {
        matchLabels = {
          "k8s-app" = "metrics-server"
        }
      }
      strategy = {
        rollingUpdate = {
          maxUnavailable = 0
        }
      }
      template = {
        metadata = {
          labels = {
            "k8s-app" = "metrics-server"
          }
        }
        spec = {
          serviceAccountName = "metrics-server"
          priorityClassName  = "system-cluster-critical"
          containers = [
            {
              name  = "metrics-server"
              image = "registry.k8s.io/metrics-server/metrics-server:v0.8.1"
              args = [
                "--cert-dir=/tmp",
                "--secure-port=10250",
                "--kubelet-preferred-address-types=InternalIP,ExternalIP,Hostname",
                "--kubelet-use-node-status-port",
                "--metric-resolution=15s"
              ]
              ports = [
                {
                  name          = "https"
                  containerPort = 10250
                  protocol      = "TCP"
                }
              ]
              resources = {
                requests = {
                  cpu    = "100m"
                  memory = "200Mi"
                }
              }
              volumeMounts = [
                {
                  name      = "tmp-dir"
                  mountPath = "/tmp"
                }
              ]
            }
          ]
          volumes = [
            {
              name     = "tmp-dir"
              emptyDir = {}
            }
          ]
        }
      }
    }
  }
  depends_on = [
    aws_eks_cluster.kubernetes
  ]
}

resource "kubernetes_manifest" "kubernetes_metrics_server_api_service" {
  count = var.kubernetes_cluster_mode == "create" && var.install_metrics_server ? 1 : 0
  manifest = {
    apiVersion = "apiregistration.k8s.io/v1"
    kind       = "APIService"
    metadata = {
      name = "v1beta1.metrics.k8s.io"
      labels = {
        "k8s-app" = "metrics-server"
      }
    }
    spec = {
      group                 = "metrics.k8s.io"
      version               = "v1beta1"
      groupPriorityMinimum  = 100
      versionPriority       = 100
      insecureSkipTLSVerify = true
      service = {
        name      = "metrics-server"
        namespace = "kube-system"
      }
    }
  }
  depends_on = [
    aws_eks_cluster.kubernetes
  ]
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                    = local.deployment_platform
    token                       = var.token
    name                        = var.name
    resource_prefix             = local.resource_prefix
    setup_target                = ""
    setup_import_format_version = 1
    setup_fingerprint           = ""
    setup_fingerprint_version   = 0
    manager_url                 = var.manager_url
    management_config           = local.deployment_management_config
    stack_settings              = local.deployment_settings
    resources                   = local.deployment_resources
    basePlatform                = local.deployment_base_platform
  }
  depends_on = [
    aws_iam_openid_connect_provider.eks,
    aws_vpc.kubernetes,
    aws_internet_gateway.kubernetes,
    aws_subnet.kubernetes_public,
    aws_subnet.kubernetes_private,
    aws_eip.kubernetes_nat,
    aws_nat_gateway.kubernetes,
    aws_route_table.kubernetes_public,
    aws_route_table.kubernetes_private,
    aws_route_table_association.kubernetes_public,
    aws_route_table_association.kubernetes_private,
    aws_iam_role.kubernetes_cluster,
    aws_iam_role_policy_attachment.kubernetes_cluster,
    aws_iam_role.kubernetes_node,
    aws_iam_role_policy_attachment.kubernetes_node,
    aws_iam_role.kubernetes_managed_node,
    aws_iam_role_policy_attachment.kubernetes_managed_node,
    aws_eks_cluster.kubernetes,
    aws_eks_addon.kubernetes_vpc_cni,
    aws_eks_node_group.kubernetes,
    aws_iam_role.kubernetes_ebs_csi,
    aws_iam_role_policy_attachment.kubernetes_ebs_csi,
    aws_eks_addon.kubernetes_ebs_csi,
    aws_eks_addon.kubernetes_kube_proxy,
    aws_eks_addon.kubernetes_coredns,
    kubernetes_manifest.kubernetes_gp3_storage_class,
    kubernetes_manifest.kubernetes_metrics_server_service_account,
    kubernetes_manifest.kubernetes_metrics_server_aggregated_metrics_reader,
    kubernetes_manifest.kubernetes_metrics_server_cluster_role,
    kubernetes_manifest.kubernetes_metrics_server_auth_reader_role_binding,
    kubernetes_manifest.kubernetes_metrics_server_auth_delegator_binding,
    kubernetes_manifest.kubernetes_metrics_server_cluster_role_binding,
    kubernetes_manifest.kubernetes_metrics_server_service,
    kubernetes_manifest.kubernetes_metrics_server_deployment,
    kubernetes_manifest.kubernetes_metrics_server_api_service
  ]
}


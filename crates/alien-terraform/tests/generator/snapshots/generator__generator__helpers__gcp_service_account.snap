---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 5.0"
    }
    time = {
      source  = "hashicorp/time"
      version = ">= 0.9"
    }
  }
}

=== variables.tf ===
variable "stack_name" {
  type        = string
  description = "Stable physical-name prefix for resources created by this module."
}

variable "deployment_name" {
  type        = string
  description = "Deployment name used when registering the resolved stack import. Defaults to stack_name."
  default     = ""
}

variable "deployment_group_token" {
  type        = string
  description = "Deployment group token used when registering the resolved stack import."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "stack_settings_json" {
  type        = string
  description = "Optional JSON-encoded StackSettings override supplied by deployment installers."
  default     = "{}"
  sensitive   = true
}

variable "gcp_project" {
  type        = string
  description = "GCP project ID."
}

variable "gcp_region" {
  type        = string
  description = "GCP region."
  default     = "us-central1"
}

variable "managing_service_account_email" {
  type        = string
  description = "Email of the manager's service account that may impersonate the management identity. Empty disables the binding."
  default     = ""
}

variable "gcp_use_existing_custom_roles" {
  type        = bool
  description = "Use pre-created project custom roles named after Alien permission sets instead of creating per-stack custom roles."
  default     = false
}

=== providers.tf ===
provider "google" {
  project = var.gcp_project
  region  = var.gcp_region
}

=== locals.tf ===
locals {
  deployment_platform = "gcp"
  deployment_target   = "gcp"
  deployment_region   = var.gcp_region
  deployment_management_config = {
    platform            = "gcp"
    projectId           = var.gcp_project
    serviceAccountEmail = var.managing_service_account_email
  }
  deployment_stack_settings = jsondecode(var.stack_settings_json)
  deployment_resources = [
    {
      id   = "execution-sa"
      type = "service-account"
      importData = {
        projectId               = var.gcp_project
        serviceAccountEmail     = google_service_account.execution_sa.email
        serviceAccountUniqueId  = google_service_account.execution_sa.unique_id
        stackPermissionsApplied = true
      }
    }
  ]
}

=== execution_sa.tf ===
resource "google_service_account" "execution_sa" {
  project      = var.gcp_project
  account_id   = format("%s-%s", trim(substr(replace(lower(format("a-%s-execution_sa", var.stack_name)), "_", "-"), 0, 21), "-"), substr(sha1(replace(lower(format("%s-execution_sa", var.stack_name)), "_", "-")), 0, 8))
  display_name = "Alien execution-sa service account"
  description  = "${var.stack_name} stack service account for permission profile 'execution_sa'"
}

resource "google_project_iam_custom_role" "execution_sa_storagedataread" {
  count       = var.gcp_use_existing_custom_roles ? 0 : 1
  project     = var.gcp_project
  role_id     = format("%s_execution_sa_storageDataRead_%s", substr(replace(var.stack_name, "-", "_"), 0, 12), substr(sha1(format("%s-execution_sa-storageDataRead", var.stack_name)), 0, 8))
  title       = "Storage Data Read"
  description = "Allows reading data from storage buckets and containers"
  stage       = "GA"
  permissions = [
    "storage.buckets.get",
    "storage.buckets.list",
    "storage.objects.get",
    "storage.objects.list",
    "storage.objects.getIamPolicy",
    "storage.multipartUploads.list",
    "storage.multipartUploads.listParts",
    "iam.serviceAccounts.signBlob"
  ]
}

resource "google_project_iam_member" "execution_sa_storagedataread_binding_0" {
  project = var.gcp_project
  role    = var.gcp_use_existing_custom_roles ? format("projects/%s/roles/storageDataRead", var.gcp_project) : google_project_iam_custom_role.execution_sa_storagedataread[0].name
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

resource "google_project_iam_custom_role" "execution_sa_queuedatawrite" {
  count       = var.gcp_use_existing_custom_roles ? 0 : 1
  project     = var.gcp_project
  role_id     = format("%s_execution_sa_queueDataWrite_%s", substr(replace(var.stack_name, "-", "_"), 0, 12), substr(sha1(format("%s-execution_sa-queueDataWrite", var.stack_name)), 0, 8))
  title       = "Queue Data Write"
  description = "Allows sending messages to queues and acknowledging received messages"
  stage       = "GA"
  permissions = [
    "pubsub.topics.publish",
    "pubsub.subscriptions.consume",
    "pubsub.subscriptions.get"
  ]
}

resource "google_project_iam_member" "execution_sa_queuedatawrite_binding_0" {
  project = var.gcp_project
  role    = var.gcp_use_existing_custom_roles ? format("projects/%s/roles/queueDataWrite", var.gcp_project) : google_project_iam_custom_role.execution_sa_queuedatawrite[0].name
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

=== iam_propagation.tf ===
resource "time_sleep" "gcp_iam_propagation" {
  create_duration = "120s"
  depends_on = [
    google_project_iam_custom_role.execution_sa_storagedataread,
    google_project_iam_member.execution_sa_storagedataread_binding_0,
    google_project_iam_custom_role.execution_sa_queuedatawrite,
    google_project_iam_member.execution_sa_queuedatawrite_binding_0
  ]
}

=== import.tf ===
resource "terraform_data" "deployment_stack_import" {
  input = {
    platform                  = local.deployment_platform
    deployment_group_token    = var.deployment_group_token
    deployment_name           = var.deployment_name == "" ? var.stack_name : var.deployment_name
    stack_prefix              = var.stack_name
    setup_target              = ""
    setup_fingerprint         = ""
    setup_fingerprint_version = 0
    manager_url               = var.manager_url
    management_config         = local.deployment_management_config
    stack_settings            = local.deployment_stack_settings
    resources                 = local.deployment_resources
  }
  depends_on = [
    google_service_account.execution_sa,
    google_project_iam_custom_role.execution_sa_storagedataread,
    google_project_iam_member.execution_sa_storagedataread_binding_0,
    google_project_iam_custom_role.execution_sa_queuedatawrite,
    google_project_iam_member.execution_sa_queuedatawrite_binding_0,
    time_sleep.gcp_iam_propagation
  ]
}

=== outputs.tf ===
output "deployment_target" {
  value       = "gcp"
  description = "Terraform module target."
}

output "deployment_stack_prefix" {
  value       = var.stack_name
  description = "Physical stack prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_setup_target" {
  value       = ""
  description = "Setup target."
}

output "deployment_setup_fingerprint" {
  value       = ""
  description = "Setup compatibility fingerprint."
}

output "deployment_setup_fingerprint_version" {
  value       = 0
  description = "Setup fingerprint algorithm version."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_stack_settings" {
  value       = jsonencode(local.deployment_stack_settings)
  description = "Manager import StackSettings JSON."
  sensitive   = true
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-iam

Target: `gcp`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='stack_name=acme-iam' -var='deployment_group_token=...'
```

This module exposes `deployment_management_config` / `deployment_stack_settings` / `deployment_resources` for external registration flows.

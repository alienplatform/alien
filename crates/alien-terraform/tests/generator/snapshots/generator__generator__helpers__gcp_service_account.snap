=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    google = {
      source  = "hashicorp/google"
      version = ">= 5.0"
    }
    time = {
      source  = "hashicorp/time"
      version = ">= 0.9"
    }
  }
}

=== variables.tf ===
variable "stack_name" {
  type        = string
  description = "Stable physical-name prefix for resources created by this setup."
}

variable "name" {
  type        = string
  description = "Human-readable deployment name shown in the deployment portal."
}

variable "token" {
  type        = string
  description = "Deployment token from the deployment page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "stack_settings_json" {
  type        = string
  description = "Optional JSON-encoded StackSettings override supplied by deployment installers."
  default     = "{}"
  sensitive   = true
}

variable "gcp_project" {
  type        = string
  description = "GCP project ID."
}

variable "gcp_region" {
  type        = string
  description = "GCP region."
  default     = "us-central1"
}

variable "managing_service_account_email" {
  type        = string
  description = "Email of the manager's service account that may impersonate the management identity. Empty disables the binding."
  default     = ""
}

=== providers.tf ===
provider "google" {
  project = var.gcp_project
  region  = var.gcp_region
}

=== locals.tf ===
locals {
  resource_prefix     = var.stack_name
  deployment_platform = "gcp"
  deployment_target   = "gcp"
  deployment_region   = var.gcp_region
  deployment_management_config = {
    platform            = "gcp"
    projectId           = var.gcp_project
    serviceAccountEmail = var.managing_service_account_email
  }
  deployment_settings = jsondecode(var.stack_settings_json)
  deployment_resources = [
    {
      id   = "execution-sa"
      type = "service-account"
      importData = {
        projectId               = var.gcp_project
        serviceAccountEmail     = google_service_account.execution_sa.email
        serviceAccountUniqueId  = google_service_account.execution_sa.unique_id
        stackPermissionsApplied = true
      }
    }
  ]
}

=== execution_sa.tf ===
resource "google_service_account" "execution_sa" {
  project      = var.gcp_project
  account_id   = format("%s-%s", trim(substr(replace(lower(format("a-%s-execution_sa", local.resource_prefix)), "_", "-"), 0, 21), "-"), substr(sha1(replace(lower(format("%s-execution_sa", local.resource_prefix)), "_", "-")), 0, 8))
  display_name = "Deployment execution-sa service account"
  description  = "${local.resource_prefix} deployment service account for permission profile 'execution_sa'"
}

resource "google_project_iam_custom_role" "gcp_role_storage_data_read_part1" {
  project     = var.gcp_project
  role_id     = format("role_%s_storage_data_read_part1", substr(replace(lower(local.resource_prefix), "-", "_"), 0, 18))
  title       = "acme-iam: Storage data read (part 1)"
  description = "Allows reading data from storage buckets and containers. Stack: acme-iam. Deployment prefix: ${local.resource_prefix}. Permission set: storage/data-read."
  stage       = "GA"
  permissions = [
    "storage.buckets.get",
    "storage.buckets.list",
    "storage.multipartUploads.list",
    "storage.multipartUploads.listParts",
    "storage.objects.get",
    "storage.objects.getIamPolicy",
    "storage.objects.list"
  ]
}

resource "google_project_iam_custom_role" "gcp_role_storage_data_read_part2" {
  project     = var.gcp_project
  role_id     = format("role_%s_storage_data_read_part2", substr(replace(lower(local.resource_prefix), "-", "_"), 0, 18))
  title       = "acme-iam: Storage data read (part 2)"
  description = "Allows reading data from storage buckets and containers. Stack: acme-iam. Deployment prefix: ${local.resource_prefix}. Permission set: storage/data-read."
  stage       = "GA"
  permissions = [
    "iam.serviceAccounts.signBlob"
  ]
}

resource "google_project_iam_member" "gcp_role_storage_data_read_part1_execution_sa_binding_0" {
  project = var.gcp_project
  role    = google_project_iam_custom_role.gcp_role_storage_data_read_part1.name
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

resource "google_project_iam_member" "gcp_role_storage_data_read_part2_execution_sa_binding_1" {
  project = var.gcp_project
  role    = google_project_iam_custom_role.gcp_role_storage_data_read_part2.name
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

resource "google_project_iam_custom_role" "gcp_role_queue_data_write" {
  project     = var.gcp_project
  role_id     = format("role_%s_queue_data_write", substr(replace(lower(local.resource_prefix), "-", "_"), 0, 18))
  title       = "acme-iam: Queue data write"
  description = "Allows sending messages to queues and acknowledging received messages. Stack: acme-iam. Deployment prefix: ${local.resource_prefix}. Permission set: queue/data-write."
  stage       = "GA"
  permissions = [
    "pubsub.subscriptions.consume",
    "pubsub.subscriptions.get",
    "pubsub.topics.publish"
  ]
}

resource "google_project_iam_member" "gcp_role_queue_data_write_execution_sa_binding_0" {
  project = var.gcp_project
  role    = google_project_iam_custom_role.gcp_role_queue_data_write.name
  member  = "serviceAccount:${google_service_account.execution_sa.email}"
}

=== iam_propagation.tf ===
resource "time_sleep" "gcp_iam_propagation" {
  create_duration = "120s"
  depends_on = [
    google_project_iam_member.gcp_role_storage_data_read_part1_execution_sa_binding_0,
    google_project_iam_member.gcp_role_storage_data_read_part2_execution_sa_binding_1,
    google_project_iam_member.gcp_role_queue_data_write_execution_sa_binding_0
  ]
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                  = local.deployment_platform
    token                     = var.token
    name                      = var.name
    resource_prefix           = local.resource_prefix
    setup_target              = ""
    setup_fingerprint         = ""
    setup_fingerprint_version = 0
    manager_url               = var.manager_url
    management_config         = local.deployment_management_config
    stack_settings            = local.deployment_settings
    resources                 = local.deployment_resources
  }
  depends_on = [
    google_service_account.execution_sa,
    google_project_iam_custom_role.gcp_role_storage_data_read_part1,
    google_project_iam_custom_role.gcp_role_storage_data_read_part2,
    google_project_iam_member.gcp_role_storage_data_read_part1_execution_sa_binding_0,
    google_project_iam_member.gcp_role_storage_data_read_part2_execution_sa_binding_1,
    google_project_iam_custom_role.gcp_role_queue_data_write,
    google_project_iam_member.gcp_role_queue_data_write_execution_sa_binding_0,
    time_sleep.gcp_iam_propagation
  ]
}


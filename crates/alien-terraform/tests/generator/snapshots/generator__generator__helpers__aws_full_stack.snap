---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "resource_prefix" {
  type        = string
  description = "Optional stable physical resource prefix. Leave empty to generate one."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || (can(regex("^[a-z][a-z0-9-]{1,38}[a-z0-9]$", var.resource_prefix)) && length(regexall("--", var.resource_prefix)) == 0)
    error_message = "resource_prefix must be 3-40 characters: lowercase letters, numbers, and hyphens; start with a letter; end with a letter or number; and not contain consecutive hyphens."
  }
}

variable "name" {
  type        = string
  description = "Human-readable application name shown in setup and cloud IAM review metadata."
}

variable "token" {
  type        = string
  description = "Install token from the application setup page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "stack_settings_json" {
  type        = string
  description = "Optional JSON-encoded StackSettings override supplied by deployment installers."
  default     = "{\"network\":{\"type\":\"create\",\"cidr\":\"10.44.0.0/16\",\"availability_zones\":2},\"updates\":\"approval-required\"}"
  sensitive   = true
}

variable "aws_region" {
  type        = string
  description = "AWS region used by the AWS provider."
  default     = "us-east-1"
}

variable "managing_role_arn" {
  type        = string
  description = "ARN of the manager IAM identity allowed to assume management roles."
  default     = ""
}

variable "managing_account_id" {
  type        = string
  description = "Account ID hosting the manager. Referenced by resource-side IAM policies that scope cross-account image pulls. Empty disables those grants."
  default     = ""
}

variable "network_mode" {
  type        = string
  description = "Choose whether this setup creates a new network, uses an existing network, or uses the default network. Values: create-new, use-existing, use-default."
  default     = "create-new"
}

variable "vpc_cidr" {
  type        = string
  description = "CIDR for a newly-created network. Empty uses 10.42.0.0/16."
  default     = ""
}

variable "availability_zones" {
  type        = number
  description = "Number of availability zones to use when creating a new network."
  default     = 2
}

variable "vpc_id" {
  type        = string
  description = "Existing VPC ID. Required when network is use-existing."
  default     = ""
}

variable "public_subnet_ids" {
  type        = list(string)
  description = "Existing public subnet IDs. Required when network is use-existing."
  default     = []
}

variable "private_subnet_ids" {
  type        = list(string)
  description = "Existing private subnet IDs. Required when network is use-existing."
  default     = []
}

variable "security_group_ids" {
  type        = list(string)
  description = "Existing security group IDs. Required when network is use-existing."
  default     = []
}

=== providers.tf ===
provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 4
}

=== locals.tf ===
locals {
  resource_prefix     = var.resource_prefix == "" ? format("a%s", random_id.resource_prefix.hex) : var.resource_prefix
  deployment_name     = var.name
  deployment_platform = "aws"
  deployment_target   = "aws"
  deployment_region   = data.aws_region.current.region
  deployment_management_config = {
    platform        = "aws"
    managingRoleArn = var.managing_role_arn
  }
  deployment_settings = merge(jsondecode(var.stack_settings_json), { network = jsondecode(var.network_mode == "create-new" ? jsonencode({ type = "create", cidr = var.vpc_cidr == "" ? null : var.vpc_cidr, availabilityZones = var.availability_zones }) : var.network_mode == "use-existing" ? jsonencode({ type = "byo-vpc-aws", vpcId = var.vpc_id, publicSubnetIds = var.public_subnet_ids, privateSubnetIds = var.private_subnet_ids, securityGroupIds = var.security_group_ids }) : jsonencode({ type = "use-default" })) })
  deployment_resources = [
    {
      id   = "default-network"
      type = "network"
      importData = {
        vpcId               = var.network_mode == "create-new" ? aws_vpc.default_network[0].id : var.network_mode == "use-existing" ? var.vpc_id : null
        cidrBlock           = var.network_mode == "create-new" ? aws_vpc.default_network[0].cidr_block : null
        internetGatewayId   = var.network_mode == "create-new" ? aws_internet_gateway.default_network[0].id : null
        natGatewayId        = var.network_mode == "create-new" ? aws_nat_gateway.default_network[0].id : null
        eipAllocationId     = var.network_mode == "create-new" ? aws_eip.default_network_nat[0].id : null
        publicSubnetIds     = var.network_mode == "create-new" ? aws_subnet.default_network_public[*].id : var.network_mode == "use-existing" ? var.public_subnet_ids : []
        privateSubnetIds    = var.network_mode == "create-new" ? aws_subnet.default_network_private[*].id : var.network_mode == "use-existing" ? var.private_subnet_ids : []
        publicRouteTableId  = var.network_mode == "create-new" ? aws_route_table.default_network_public[0].id : null
        privateRouteTableId = var.network_mode == "create-new" ? aws_route_table.default_network_private[0].id : null
        securityGroupId     = var.network_mode == "create-new" ? aws_security_group.default_network_workload[0].id : var.network_mode == "use-existing" ? try(var.security_group_ids[0], null) : null
        availabilityZones   = var.network_mode == "use-default" ? [] : slice(data.aws_availability_zones.available.names, 0, 2)
        isByoVpc            = var.network_mode != "create-new"
      }
    },
    {
      id   = "execution-sa"
      type = "service-account"
      importData = {
        roleName                = aws_iam_role.execution_sa.name
        roleArn                 = aws_iam_role.execution_sa.arn
        stackPermissionsApplied = true
      }
    },
    {
      id   = "management"
      type = "remote-stack-management"
      importData = {
        roleName                     = aws_iam_role.management.name
        roleArn                      = aws_iam_role.management.arn
        managementPermissionsApplied = true
      }
    },
    {
      id   = "assets"
      type = "storage"
      importData = {
        bucketName = aws_s3_bucket.assets.bucket
        bucketArn  = aws_s3_bucket.assets.arn
      }
    },
    {
      id   = "jobs"
      type = "queue"
      importData = {
        queueName = aws_sqs_queue.jobs.name
        queueUrl  = aws_sqs_queue.jobs.url
        queueArn  = aws_sqs_queue.jobs.arn
      }
    },
    {
      id   = "metadata"
      type = "kv"
      importData = {
        tableName = aws_dynamodb_table.metadata.name
        tableArn  = aws_dynamodb_table.metadata.arn
      }
    },
    {
      id   = "secrets"
      type = "vault"
      importData = {
        accountId       = data.aws_caller_identity.current.account_id
        region          = data.aws_region.current.region
        parameterPrefix = "${local.resource_prefix}-secrets"
      }
    },
    {
      id   = "registry"
      type = "artifact-registry"
      importData = {
        accountId        = data.aws_caller_identity.current.account_id
        region           = data.aws_region.current.region
        registryId       = "${data.aws_caller_identity.current.account_id}:${data.aws_region.current.region}"
        registryEndpoint = aws_ecr_repository.registry.registry_id
        repositoryPrefix = "${local.resource_prefix}-registry"
        pullRoleArn      = aws_iam_role.registry_pull.arn
        pushRoleArn      = aws_iam_role.registry_push.arn
      }
    }
  ]
}

=== default_network.tf ===
data "aws_availability_zones" "available" {
  state = "available"
}

resource "aws_vpc" "default_network" {
  count                = var.network_mode == "create-new" ? 1 : 0
  cidr_block           = var.vpc_cidr == "" ? "10.44.0.0/16" : var.vpc_cidr
  enable_dns_support   = true
  enable_dns_hostnames = true
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_internet_gateway" "default_network" {
  count  = var.network_mode == "create-new" ? 1 : 0
  vpc_id = aws_vpc.default_network[0].id
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_subnet" "default_network_public" {
  count                   = var.network_mode == "create-new" ? var.availability_zones : 0
  vpc_id                  = aws_vpc.default_network[0].id
  cidr_block              = cidrsubnet(aws_vpc.default_network[0].cidr_block, 8, count.index)
  availability_zone       = data.aws_availability_zones.available.names[count.index]
  map_public_ip_on_launch = true
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_subnet" "default_network_private" {
  count             = var.network_mode == "create-new" ? var.availability_zones : 0
  vpc_id            = aws_vpc.default_network[0].id
  cidr_block        = cidrsubnet(aws_vpc.default_network[0].cidr_block, 8, count.index + var.availability_zones)
  availability_zone = data.aws_availability_zones.available.names[count.index]
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_eip" "default_network_nat" {
  count  = var.network_mode == "create-new" ? 1 : 0
  domain = "vpc"
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_nat_gateway" "default_network" {
  count         = var.network_mode == "create-new" ? 1 : 0
  allocation_id = aws_eip.default_network_nat[0].id
  subnet_id     = aws_subnet.default_network_public[0].id
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_route_table" "default_network_public" {
  count  = var.network_mode == "create-new" ? 1 : 0
  vpc_id = aws_vpc.default_network[0].id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.default_network[0].id
  }

  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_route_table" "default_network_private" {
  count  = var.network_mode == "create-new" ? 1 : 0
  vpc_id = aws_vpc.default_network[0].id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.default_network[0].id
  }

  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

resource "aws_route_table_association" "default_network_public" {
  count          = var.network_mode == "create-new" ? var.availability_zones : 0
  subnet_id      = aws_subnet.default_network_public[count.index].id
  route_table_id = aws_route_table.default_network_public[0].id
}

resource "aws_route_table_association" "default_network_private" {
  count          = var.network_mode == "create-new" ? var.availability_zones : 0
  subnet_id      = aws_subnet.default_network_private[count.index].id
  route_table_id = aws_route_table.default_network_private[0].id
}

resource "aws_security_group" "default_network_workload" {
  count       = var.network_mode == "create-new" ? 1 : 0
  name_prefix = "${local.resource_prefix}-workload-"
  description = "Private workload security group"
  vpc_id      = aws_vpc.default_network[0].id

  egress {
    from_port = 0
    to_port   = 0
    protocol  = "-1"
    cidr_blocks = [
      "0.0.0.0/0"
    ]
  }

  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-network"
    "resource-type" = "network"
  }
}

=== execution_sa.tf ===
resource "aws_iam_role" "execution_sa" {
  name               = length(format("%s-%s", local.resource_prefix, "execution-sa")) <= 64 ? format("%s-%s", local.resource_prefix, "execution-sa") : format("%s-%s", substr(format("%s-%s", local.resource_prefix, "execution-sa"), 0, 55), substr(sha1(format("%s-%s", local.resource_prefix, "execution-sa")), 0, 8))
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { Service = ["codebuild.amazonaws.com", "lambda.amazonaws.com"] }, Action = "sts:AssumeRole" }] })
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "execution-sa"
    "resource-type" = "service-account"
  }
}

resource "aws_iam_role_policy" "execution_sa_set_0" {
  name   = "storage-data-read-0"
  role   = aws_iam_role.execution_sa.id
  policy = jsonencode({ Statement = [{ Action = ["s3:ListBucket", "s3:GetObject", "s3:GetObjectVersion", "s3:GetObjectAcl"], Effect = "Allow", Resource = ["arn:aws:s3:::${local.resource_prefix}-*", "arn:aws:s3:::${local.resource_prefix}-*/*"], Sid = "ReadS3Objects" }], Version = "2012-10-17" })
}

resource "aws_iam_role_policy" "execution_sa_set_1" {
  name   = "queue-data-write-1"
  role   = aws_iam_role.execution_sa.id
  policy = jsonencode({ Statement = [{ Action = ["sqs:SendMessage", "sqs:DeleteMessage", "sqs:ChangeMessageVisibility", "sqs:GetQueueAttributes", "sqs:GetQueueUrl"], Effect = "Allow", Resource = ["arn:aws:sqs:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:${local.resource_prefix}-*"], Sid = "SendSqsMessages" }], Version = "2012-10-17" })
}

=== management.tf ===
resource "aws_iam_role" "management" {
  name               = length(format("%s-%s", local.resource_prefix, "management")) <= 64 ? format("%s-%s", local.resource_prefix, "management") : format("%s-%s", substr(format("%s-%s", local.resource_prefix, "management"), 0, 55), substr(sha1(format("%s-%s", local.resource_prefix, "management")), 0, 8))
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "AllowManagingRole", Effect = "Allow", Principal = { AWS = var.managing_role_arn }, Action = "sts:AssumeRole", Condition = { StringEquals = { "aws:PrincipalArn" = var.managing_role_arn } } }] })
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "management"
    "resource-type" = "remote-stack-management"
  }
}

resource "aws_iam_policy" "management_managed_policy_0" {
  name   = length(format("%s-%s", local.resource_prefix, "deployment-management-0")) <= 128 ? format("%s-%s", local.resource_prefix, "deployment-management-0") : format("%s-%s", substr(format("%s-%s", local.resource_prefix, "deployment-management-0"), 0, 119), substr(sha1(format("%s-%s", local.resource_prefix, "deployment-management-0")), 0, 8))
  policy = jsonencode({ Statement = [{ Action = ["lambda:UpdateFunctionCode", "lambda:UpdateFunctionConfiguration", "lambda:PublishVersion", "lambda:CreateAlias", "lambda:DeleteAlias", "lambda:UpdateAlias", "lambda:PutFunctionConcurrency", "lambda:DeleteFunctionConcurrency", "lambda:PutFunctionEventInvokeConfig", "lambda:DeleteFunctionEventInvokeConfig", "lambda:GetFunction", "lambda:GetFunctionConfiguration", "lambda:ListVersionsByFunction", "lambda:ListAliases", "lambda:GetPolicy", "lambda:ListTags", "lambda:GetFunctionUrlConfig", "lambda:GetCodeSigningConfig", "lambda:GetFunctionEventInvokeConfig", "lambda:AddPermission", "lambda:RemovePermission", "lambda:GetEventSourceMapping", "lambda:ListEventSourceMappings", "lambda:UpdateEventSourceMapping"], Condition = { StringEquals = { "aws:ResourceTag/deployment" = "${local.resource_prefix}", "aws:ResourceTag/managed-by" = "deployment" } }, Effect = "Allow", Resource = ["arn:aws:lambda:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:function:${local.resource_prefix}-*"], Sid = "UpdateLambdaFunctions" }, { Action = ["iam:PassRole"], Effect = "Allow", Resource = ["arn:aws:iam::${data.aws_caller_identity.current.account_id}:role/${local.resource_prefix}-*-sa"], Sid = "PassLambdaExecutionRoles" }, { Action = ["ecr:GetAuthorizationToken"], Effect = "Allow", Resource = ["*"], Sid = "GetEcrLoginToken" }, { Action = ["ecr:BatchGetImage", "ecr:GetDownloadUrlForLayer"], Effect = "Allow", Resource = ["arn:aws:ecr:*:${var.managing_account_id}:repository/*"], Sid = "ReadDeploymentContainerImages" }, { Action = ["acm:ImportCertificate", "acm:AddTagsToCertificate"], Condition = { StringEquals = { "aws:RequestTag/deployment" = "${local.resource_prefix}", "aws:RequestTag/managed-by" = "deployment" } }, Effect = "Allow", Resource = ["arn:aws:acm:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:certificate/*"], Sid = "ImportTlsCertificates" }, { Action = ["acm:ImportCertificate", "acm:AddTagsToCertificate", "acm:DeleteCertificate", "acm:DescribeCertificate"], Condition = { StringEquals = { "aws:ResourceTag/deployment" = "${local.resource_prefix}", "aws:ResourceTag/managed-by" = "deployment" } }, Effect = "Allow", Resource = ["arn:aws:acm:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:certificate/*"], Sid = "ManageTlsCertificates" }, { Action = ["apigateway:POST", "apigateway:PUT"], Condition = { StringEquals = { "aws:RequestTag/deployment" = "${local.resource_prefix}", "aws:RequestTag/managed-by" = "deployment" } }, Effect = "Allow", Resource = ["arn:aws:apigateway:${data.aws_region.current.region}::/apis", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames", "arn:aws:apigateway:${data.aws_region.current.region}::/tags/*"], Sid = "CreateHttpApiEndpoints" }, { Action = ["apigateway:POST"], Condition = { StringEquals = { "aws:ResourceTag/deployment" = "${local.resource_prefix}", "aws:ResourceTag/managed-by" = "deployment" } }, Effect = "Allow", Resource = ["arn:aws:apigateway:${data.aws_region.current.region}::/apis/*", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames/*", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames/*/apimappings"], Sid = "CreateHttpApiRoutes" }, { Action = ["apigateway:TagResource", "apigateway:PUT"], Condition = { StringEquals = { "aws:RequestTag/deployment" = "${local.resource_prefix}", "aws:RequestTag/managed-by" = "deployment" } }, Effect = "Allow", Resource = ["arn:aws:apigateway:${data.aws_region.current.region}::/apis/*", "arn:aws:apigateway:${data.aws_region.current.region}::/apis/*/stages", "arn:aws:apigateway:${data.aws_region.current.region}::/apis/*/stages/*", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames/*", "arn:aws:apigateway:${data.aws_region.current.region}::/tags/*"], Sid = "TagHttpApiEndpoints" }, { Action = ["apigateway:GET", "apigateway:DELETE", "apigateway:PATCH", "apigateway:PUT"], Condition = { StringEquals = { "aws:ResourceTag/deployment" = "${local.resource_prefix}", "aws:ResourceTag/managed-by" = "deployment" } }, Effect = "Allow", Resource = ["arn:aws:apigateway:${data.aws_region.current.region}::/apis/*", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames/*", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames/*/apimappings", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames/*/apimappings/*"], Sid = "ManageHttpApiEndpoints" }, { Action = ["events:PutRule", "events:TagResource"], Condition = { StringEquals = { "aws:RequestTag/deployment" = "${local.resource_prefix}", "aws:RequestTag/managed-by" = "deployment" } }, Effect = "Allow", Resource = ["arn:aws:events:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:rule/${local.resource_prefix}-*"], Sid = "CreateEventbridgeSchedules" }, { Action = ["events:DeleteRule", "events:DescribeRule", "events:PutTargets", "events:RemoveTargets"], Condition = { StringEquals = { "aws:ResourceTag/deployment" = "${local.resource_prefix}", "aws:ResourceTag/managed-by" = "deployment" } }, Effect = "Allow", Resource = ["arn:aws:events:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:rule/${local.resource_prefix}-*"], Sid = "ManageEventbridgeSchedules" }, { Action = ["s3:GetBucketLocation", "s3:GetBucketVersioning", "s3:GetLifecycleConfiguration", "s3:GetBucketPolicy", "s3:GetBucketAcl", "s3:GetEncryptionConfiguration", "s3:GetBucketPublicAccessBlock"], Effect = "Allow", Resource = ["arn:aws:s3:::${local.resource_prefix}-*"], Sid = "CheckS3BucketHealth" }], Version = "2012-10-17" })
}

resource "aws_iam_role_policy_attachment" "management_managed_policy_0_attachment" {
  role       = aws_iam_role.management.name
  policy_arn = aws_iam_policy.management_managed_policy_0.arn
}

resource "aws_iam_policy" "management_managed_policy_1" {
  name   = length(format("%s-%s", local.resource_prefix, "deployment-management-1")) <= 128 ? format("%s-%s", local.resource_prefix, "deployment-management-1") : format("%s-%s", substr(format("%s-%s", local.resource_prefix, "deployment-management-1"), 0, 119), substr(sha1(format("%s-%s", local.resource_prefix, "deployment-management-1")), 0, 8))
  policy = jsonencode({ Statement = [{ Action = ["sqs:GetQueueAttributes", "sqs:ListQueueTags"], Effect = "Allow", Resource = ["arn:aws:sqs:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:${local.resource_prefix}-*"], Sid = "CheckSqsQueueHealth" }, { Action = ["dynamodb:DescribeTable", "dynamodb:ListTables", "dynamodb:DescribeTimeToLive", "dynamodb:ListTagsOfResource", "dynamodb:DescribeContinuousBackups"], Effect = "Allow", Resource = ["arn:aws:dynamodb:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:table/${local.resource_prefix}-*"], Sid = "CheckDynamodbTableHealth" }], Version = "2012-10-17" })
}

resource "aws_iam_role_policy_attachment" "management_managed_policy_1_attachment" {
  role       = aws_iam_role.management.name
  policy_arn = aws_iam_policy.management_managed_policy_1.arn
}

resource "aws_iam_role_policy" "management_self_read" {
  name   = "deployment-management-self-read"
  role   = aws_iam_role.management.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "ReadOwnManagementRole", Effect = "Allow", Action = "iam:GetRole", Resource = aws_iam_role.management.arn }] })
}

=== assets.tf ===
resource "aws_s3_bucket" "assets" {
  bucket        = "${local.resource_prefix}-assets"
  force_destroy = true
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "assets"
    "resource-type" = "storage"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "assets" {
  bucket = aws_s3_bucket.assets.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

resource "aws_s3_bucket_ownership_controls" "assets" {
  bucket = aws_s3_bucket.assets.id

  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

resource "aws_s3_bucket_public_access_block" "assets" {
  bucket                  = aws_s3_bucket.assets.id
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_policy" "assets" {
  bucket = aws_s3_bucket.assets.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "DenyInsecureTransport", Effect = "Deny", Principal = "*", Action = "s3:*", Resource = [aws_s3_bucket.assets.arn, "${aws_s3_bucket.assets.arn}/*"], Condition = { Bool = { "aws:SecureTransport" = "false" } } }] })
}

resource "aws_s3_bucket_versioning" "assets" {
  bucket = aws_s3_bucket.assets.id

  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_iam_role_policy" "assets_management_storage-heartbeat_0" {
  name   = "assets-storage-heartbeat-0"
  role   = aws_iam_role.management.id
  policy = jsonencode({ Statement = [{ Action = ["s3:GetBucketLocation", "s3:GetBucketVersioning", "s3:GetLifecycleConfiguration", "s3:GetBucketPolicy", "s3:GetBucketAcl", "s3:GetEncryptionConfiguration", "s3:GetBucketPublicAccessBlock"], Effect = "Allow", Resource = ["arn:aws:s3:::${aws_s3_bucket.assets.bucket}"], Sid = "CheckS3BucketHealth" }], Version = "2012-10-17" })
}

=== jobs.tf ===
resource "aws_sqs_queue" "jobs" {
  name                       = "${local.resource_prefix}-jobs"
  sqs_managed_sse_enabled    = true
  visibility_timeout_seconds = 1080
  message_retention_seconds  = 345600
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "jobs"
    "resource-type" = "queue"
  }
}

=== metadata.tf ===
resource "aws_dynamodb_table" "metadata" {
  name         = "${local.resource_prefix}-metadata"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "pk"
  range_key    = "sk"

  attribute {
    name = "pk"
    type = "S"
  }

  attribute {
    name = "sk"
    type = "S"
  }

  ttl {
    attribute_name = "ttl"
    enabled        = true
  }

  server_side_encryption {
    enabled = true
  }

  point_in_time_recovery {
    enabled = true
  }

  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "metadata"
    "resource-type" = "kv"
  }

  lifecycle {
    prevent_destroy = false
  }
}

=== secrets.tf ===
resource "aws_iam_role_policy" "management_vault_secrets_set_0" {
  name   = "alien-mgmt-secrets-vault-data-write"
  role   = aws_iam_role.management.id
  policy = jsonencode({ Statement = [{ Action = ["ssm:PutParameter", "ssm:DeleteParameter"], Effect = "Allow", Resource = ["arn:aws:ssm:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:parameter/${local.resource_prefix}-secrets-*"], Sid = "WriteSsmParameters" }], Version = "2012-10-17" })
}

=== registry.tf ===
resource "aws_ecr_repository" "registry" {
  name                 = "${local.resource_prefix}-registry"
  image_tag_mutability = "IMMUTABLE"

  image_scanning_configuration {
    scan_on_push = true
  }

  encryption_configuration {
    encryption_type = "AES256"
  }

  force_delete = false
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "registry"
    "resource-type" = "artifact-registry"
  }

  lifecycle {
    prevent_destroy = false
  }
}

resource "aws_ecr_lifecycle_policy" "registry" {
  repository = aws_ecr_repository.registry.name
  policy     = jsonencode({ rules = [{ rulePriority = 1, description = "Retain the 100 most recent images", selection = { tagStatus = "any", countType = "imageCountMoreThan", countNumber = 100 }, action = { type = "expire" } }] })
}

resource "aws_iam_role" "registry_pull" {
  name               = length(format("%s-%s", local.resource_prefix, "registry-pull")) <= 64 ? format("%s-%s", local.resource_prefix, "registry-pull") : format("%s-%s", substr(format("%s-%s", local.resource_prefix, "registry-pull"), 0, 55), substr(sha1(format("%s-%s", local.resource_prefix, "registry-pull")), 0, 8))
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { AWS = aws_iam_role.execution_sa.arn }, Action = "sts:AssumeRole" }] })
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "registry"
    "resource-type" = "artifact-registry"
  }
}

resource "aws_iam_role" "registry_push" {
  name               = length(format("%s-%s", local.resource_prefix, "registry-push")) <= 64 ? format("%s-%s", local.resource_prefix, "registry-push") : format("%s-%s", substr(format("%s-%s", local.resource_prefix, "registry-push"), 0, 55), substr(sha1(format("%s-%s", local.resource_prefix, "registry-push")), 0, 8))
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { AWS = aws_iam_role.execution_sa.arn }, Action = "sts:AssumeRole" }] })
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "registry"
    "resource-type" = "artifact-registry"
  }
}

resource "aws_iam_role_policy" "registry_pull_policy" {
  name   = "ecr-pull"
  role   = aws_iam_role.registry_pull.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "GetAuthorizationToken", Effect = "Allow", Action = "ecr:GetAuthorizationToken", Resource = "*" }, { Sid = "RepositoryAccess", Effect = "Allow", Action = ["ecr:BatchCheckLayerAvailability", "ecr:BatchGetImage", "ecr:DescribeImages", "ecr:DescribeRepositories", "ecr:GetDownloadUrlForLayer", "ecr:ListImages"], Resource = [aws_ecr_repository.registry.arn, format("%s-*", aws_ecr_repository.registry.arn)] }] })
}

resource "aws_iam_role_policy" "registry_push_policy" {
  name   = "ecr-push-pull"
  role   = aws_iam_role.registry_push.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "GetAuthorizationToken", Effect = "Allow", Action = "ecr:GetAuthorizationToken", Resource = "*" }, { Sid = "RepositoryAccess", Effect = "Allow", Action = ["ecr:BatchCheckLayerAvailability", "ecr:BatchGetImage", "ecr:DescribeImages", "ecr:DescribeRepositories", "ecr:GetDownloadUrlForLayer", "ecr:ListImages", "ecr:CompleteLayerUpload", "ecr:CreateRepository", "ecr:DeleteRepository", "ecr:InitiateLayerUpload", "ecr:PutImage", "ecr:UploadLayerPart"], Resource = [aws_ecr_repository.registry.arn, format("%s-*", aws_ecr_repository.registry.arn)] }] })
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                    = local.deployment_platform
    token                       = var.token
    name                        = var.name
    resource_prefix             = local.resource_prefix
    setup_target                = ""
    setup_import_format_version = 1
    setup_fingerprint           = ""
    setup_fingerprint_version   = 0
    manager_url                 = var.manager_url
    management_config           = local.deployment_management_config
    stack_settings              = local.deployment_settings
    resources                   = local.deployment_resources
  }
  depends_on = [
    aws_vpc.default_network,
    aws_internet_gateway.default_network,
    aws_subnet.default_network_public,
    aws_subnet.default_network_private,
    aws_eip.default_network_nat,
    aws_nat_gateway.default_network,
    aws_route_table.default_network_public,
    aws_route_table.default_network_private,
    aws_route_table_association.default_network_public,
    aws_route_table_association.default_network_private,
    aws_security_group.default_network_workload,
    aws_iam_role.execution_sa,
    aws_iam_role_policy.execution_sa_set_0,
    aws_iam_role_policy.execution_sa_set_1,
    aws_iam_role.management,
    aws_iam_policy.management_managed_policy_0,
    aws_iam_role_policy_attachment.management_managed_policy_0_attachment,
    aws_iam_policy.management_managed_policy_1,
    aws_iam_role_policy_attachment.management_managed_policy_1_attachment,
    aws_iam_role_policy.management_self_read,
    aws_s3_bucket.assets,
    aws_s3_bucket_server_side_encryption_configuration.assets,
    aws_s3_bucket_ownership_controls.assets,
    aws_s3_bucket_public_access_block.assets,
    aws_s3_bucket_policy.assets,
    aws_s3_bucket_versioning.assets,
    aws_iam_role_policy.assets_management_storage-heartbeat_0,
    aws_sqs_queue.jobs,
    aws_dynamodb_table.metadata,
    aws_iam_role_policy.management_vault_secrets_set_0,
    aws_ecr_repository.registry,
    aws_ecr_lifecycle_policy.registry,
    aws_iam_role.registry_pull,
    aws_iam_role.registry_push,
    aws_iam_role_policy.registry_pull_policy,
    aws_iam_role_policy.registry_push_policy
  ]
}

=== outputs.tf ===
output "deployment_target" {
  value       = "aws"
  description = "Terraform module target."
}

output "deployment_resource_prefix" {
  value       = local.resource_prefix
  description = "Physical resource prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_setup_target" {
  value       = ""
  description = "Setup target."
}

output "deployment_setup_import_format_version" {
  value       = 1
  description = "Setup import payload format version."
}

output "deployment_setup_fingerprint" {
  value       = ""
  description = "Setup compatibility fingerprint."
}

output "deployment_setup_fingerprint_version" {
  value       = 0
  description = "Setup fingerprint algorithm version."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_stack_settings" {
  value       = jsonencode(local.deployment_settings)
  description = "Manager import StackSettings JSON."
  sensitive   = true
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - full-aws

Target: `aws`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='name=full-aws' -var='token=...'
```

This module exposes `deployment_management_config` / `deployment_stack_settings` / `deployment_resources` for external registration flows.

---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }
}

=== variables.tf ===
variable "stack_name" {
  type        = string
  description = "Stable physical-name prefix for resources created by this module."
}

variable "deployment_name" {
  type        = string
  description = "Deployment name used when registering the resolved stack import. Defaults to stack_name."
  default     = ""
}

variable "deployment_group_token" {
  type        = string
  description = "Deployment group token used when registering the resolved stack import."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "aws_region" {
  type        = string
  description = "AWS region used by the AWS provider."
  default     = "us-east-1"
}

variable "managing_role_arn" {
  type        = string
  description = "ARN of the manager IAM identity allowed to assume management roles."
  default     = ""
}

variable "managing_account_id" {
  type        = string
  description = "AWS account ID hosting the manager. Referenced by stack-side IAM policies that scope cross-account ECR pulls. Empty disables those grants."
  default     = ""
}

=== providers.tf ===
provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

=== locals.tf ===
locals {
  deployment_platform = "aws"
  deployment_target   = "aws"
  deployment_region   = data.aws_region.current.region
  deployment_management_config = {
    platform        = "aws"
    managingRoleArn = data.aws_caller_identity.current.arn
  }
  deployment_stack_settings = {
    network = {
      availability_zones = 2
      cidr               = "10.44.0.0/16"
      type               = "create"
    }
    updates = "approval-required"
  }
  deployment_resources = [
    {
      id   = "default-network"
      type = "network"
      importData = {
        vpcId               = aws_vpc.default_network.id
        cidrBlock           = aws_vpc.default_network.cidr_block
        internetGatewayId   = aws_internet_gateway.default_network.id
        natGatewayId        = aws_nat_gateway.default_network.id
        eipAllocationId     = aws_eip.default_network_nat.id
        publicSubnetIds     = aws_subnet.default_network_public[*].id
        privateSubnetIds    = aws_subnet.default_network_private[*].id
        publicRouteTableId  = aws_route_table.default_network_public.id
        privateRouteTableId = aws_route_table.default_network_private.id
        securityGroupId     = aws_security_group.default_network_workload.id
        availabilityZones   = slice(data.aws_availability_zones.available.names, 0, 2)
        isByoVpc            = false
      }
    },
    {
      id   = "execution-sa"
      type = "service-account"
      importData = {
        roleName                = aws_iam_role.execution_sa.name
        roleArn                 = aws_iam_role.execution_sa.arn
        stackPermissionsApplied = true
      }
    },
    {
      id   = "management"
      type = "remote-stack-management"
      importData = {
        roleName                     = aws_iam_role.management.name
        roleArn                      = aws_iam_role.management.arn
        managementPermissionsApplied = true
      }
    },
    {
      id   = "assets"
      type = "storage"
      importData = {
        bucketName = aws_s3_bucket.assets.bucket
        bucketArn  = aws_s3_bucket.assets.arn
      }
    },
    {
      id   = "jobs"
      type = "queue"
      importData = {
        queueName = aws_sqs_queue.jobs.name
        queueUrl  = aws_sqs_queue.jobs.url
        queueArn  = aws_sqs_queue.jobs.arn
      }
    },
    {
      id   = "metadata"
      type = "kv"
      importData = {
        tableName = aws_dynamodb_table.metadata.name
        tableArn  = aws_dynamodb_table.metadata.arn
      }
    },
    {
      id   = "secrets"
      type = "vault"
      importData = {
        accountId       = data.aws_caller_identity.current.account_id
        region          = data.aws_region.current.region
        parameterPrefix = "${var.stack_name}-secrets"
      }
    },
    {
      id   = "registry"
      type = "artifact-registry"
      importData = {
        accountId        = data.aws_caller_identity.current.account_id
        region           = data.aws_region.current.region
        registryId       = "${data.aws_caller_identity.current.account_id}:${data.aws_region.current.region}"
        registryEndpoint = aws_ecr_repository.registry.registry_id
        repositoryPrefix = "${var.stack_name}-registry"
        pullRoleArn      = aws_iam_role.registry_pull.arn
        pushRoleArn      = aws_iam_role.registry_push.arn
      }
    }
  ]
}

=== default_network.tf ===
data "aws_availability_zones" "available" {
  state = "available"
}

resource "aws_vpc" "default_network" {
  cidr_block           = "10.44.0.0/16"
  enable_dns_support   = true
  enable_dns_hostnames = true
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "default-network"
    AlienResourceType = "network"
  }
}

resource "aws_internet_gateway" "default_network" {
  vpc_id = aws_vpc.default_network.id
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "default-network"
    AlienResourceType = "network"
  }
}

resource "aws_subnet" "default_network_public" {
  count                   = 2
  vpc_id                  = aws_vpc.default_network.id
  cidr_block              = cidrsubnet(aws_vpc.default_network.cidr_block, 8, count.index)
  availability_zone       = data.aws_availability_zones.available.names[count.index]
  map_public_ip_on_launch = true
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "default-network"
    AlienResourceType = "network"
  }
}

resource "aws_subnet" "default_network_private" {
  count             = 2
  vpc_id            = aws_vpc.default_network.id
  cidr_block        = cidrsubnet(aws_vpc.default_network.cidr_block, 8, count.index + 2)
  availability_zone = data.aws_availability_zones.available.names[count.index]
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "default-network"
    AlienResourceType = "network"
  }
}

resource "aws_eip" "default_network_nat" {
  domain = "vpc"
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "default-network"
    AlienResourceType = "network"
  }
}

resource "aws_nat_gateway" "default_network" {
  allocation_id = aws_eip.default_network_nat.id
  subnet_id     = aws_subnet.default_network_public[0].id
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "default-network"
    AlienResourceType = "network"
  }
}

resource "aws_route_table" "default_network_public" {
  vpc_id = aws_vpc.default_network.id

  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.default_network.id
  }

  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "default-network"
    AlienResourceType = "network"
  }
}

resource "aws_route_table" "default_network_private" {
  vpc_id = aws_vpc.default_network.id

  route {
    cidr_block     = "0.0.0.0/0"
    nat_gateway_id = aws_nat_gateway.default_network.id
  }

  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "default-network"
    AlienResourceType = "network"
  }
}

resource "aws_route_table_association" "default_network_public" {
  count          = 2
  subnet_id      = aws_subnet.default_network_public[count.index].id
  route_table_id = aws_route_table.default_network_public.id
}

resource "aws_route_table_association" "default_network_private" {
  count          = 2
  subnet_id      = aws_subnet.default_network_private[count.index].id
  route_table_id = aws_route_table.default_network_private.id
}

resource "aws_security_group" "default_network_workload" {
  name_prefix = "${var.stack_name}-workload-"
  description = "Private workload security group"
  vpc_id      = aws_vpc.default_network.id

  egress {
    from_port = 0
    to_port   = 0
    protocol  = "-1"
    cidr_blocks = [
      "0.0.0.0/0"
    ]
  }

  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "default-network"
    AlienResourceType = "network"
  }
}

=== execution_sa.tf ===
resource "aws_iam_role" "execution_sa" {
  name               = "${var.stack_name}-execution-sa"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { Service = ["codebuild.amazonaws.com", "lambda.amazonaws.com"] }, Action = "sts:AssumeRole" }] })
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "execution-sa"
    AlienResourceType = "service-account"
  }
}

resource "aws_iam_role_policy" "execution_sa_set_0" {
  name   = "storage-data-read-0"
  role   = aws_iam_role.execution_sa.id
  policy = jsonencode({ Statement = [{ Action = ["s3:ListBucket", "s3:GetObject", "s3:GetObjectVersion", "s3:GetObjectAcl"], Effect = "Allow", Resource = ["arn:aws:s3:::${var.stack_name}-*", "arn:aws:s3:::${var.stack_name}-*/*"], Sid = "StorageDataRead" }], Version = "2012-10-17" })
}

resource "aws_iam_role_policy" "execution_sa_set_1" {
  name   = "queue-data-write-1"
  role   = aws_iam_role.execution_sa.id
  policy = jsonencode({ Statement = [{ Action = ["sqs:SendMessage", "sqs:DeleteMessage", "sqs:ChangeMessageVisibility", "sqs:GetQueueAttributes", "sqs:GetQueueUrl"], Effect = "Allow", Resource = ["arn:aws:sqs:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:${var.stack_name}-*"], Sid = "QueueDataWrite" }], Version = "2012-10-17" })
}

=== management.tf ===
resource "aws_iam_role" "management" {
  name               = "${var.stack_name}-management"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "AllowManagingRole", Effect = "Allow", Principal = { AWS = var.managing_role_arn }, Action = "sts:AssumeRole", Condition = { StringEquals = { "aws:PrincipalArn" = var.managing_role_arn } } }] })
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "management"
    AlienResourceType = "remote-stack-management"
  }
}

resource "aws_iam_role_policy" "management_set_0" {
  name   = "function-management-0"
  role   = aws_iam_role.management.id
  policy = jsonencode({ Statement = [{ Action = ["lambda:UpdateFunctionCode", "lambda:UpdateFunctionConfiguration", "lambda:PublishVersion", "lambda:CreateAlias", "lambda:DeleteAlias", "lambda:UpdateAlias", "lambda:PutFunctionConcurrency", "lambda:DeleteFunctionConcurrency", "lambda:PutFunctionEventInvokeConfig", "lambda:DeleteFunctionEventInvokeConfig", "lambda:GetFunction", "lambda:GetFunctionConfiguration", "lambda:ListVersionsByFunction", "lambda:ListAliases", "lambda:GetPolicy", "lambda:ListTags", "lambda:GetFunctionUrlConfig", "lambda:GetCodeSigningConfig", "lambda:GetFunctionEventInvokeConfig", "lambda:AddPermission", "lambda:RemovePermission", "lambda:GetEventSourceMapping", "lambda:ListEventSourceMappings", "lambda:UpdateEventSourceMapping"], Condition = { StringEquals = { "aws:ResourceTag/alien.dev/managed-by" = "alien", "aws:ResourceTag/alien.dev/stack" = "${var.stack_name}" } }, Effect = "Allow", Resource = ["arn:aws:lambda:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:function:${var.stack_name}-*"], Sid = "FunctionManagement1" }, { Action = ["iam:PassRole"], Effect = "Allow", Resource = ["arn:aws:iam::${data.aws_caller_identity.current.account_id}:role/${var.stack_name}-*-sa"], Sid = "FunctionManagement2" }, { Action = ["ecr:GetAuthorizationToken"], Effect = "Allow", Resource = ["*"], Sid = "FunctionManagement3" }, { Action = ["ecr:BatchGetImage", "ecr:GetDownloadUrlForLayer"], Effect = "Allow", Resource = ["arn:aws:ecr:*:${var.managing_account_id}:repository/*"], Sid = "FunctionManagement4" }, { Action = ["acm:ImportCertificate"], Condition = { StringEquals = { "aws:RequestTag/alien.dev/managed-by" = "alien", "aws:RequestTag/alien.dev/stack" = "${var.stack_name}" } }, Effect = "Allow", Resource = ["arn:aws:acm:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:certificate/*"], Sid = "FunctionManagement5" }, { Action = ["acm:ImportCertificate", "acm:DeleteCertificate", "acm:DescribeCertificate"], Condition = { StringEquals = { "aws:ResourceTag/alien.dev/managed-by" = "alien", "aws:ResourceTag/alien.dev/stack" = "${var.stack_name}" } }, Effect = "Allow", Resource = ["arn:aws:acm:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:certificate/*"], Sid = "FunctionManagement6" }, { Action = ["apigateway:POST"], Condition = { StringEquals = { "aws:RequestTag/alien.dev/managed-by" = "alien", "aws:RequestTag/alien.dev/stack" = "${var.stack_name}" } }, Effect = "Allow", Resource = ["arn:aws:apigateway:${data.aws_region.current.region}::/apis", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames", "arn:aws:apigateway:${data.aws_region.current.region}::/tags/*"], Sid = "FunctionManagement7" }, { Action = ["apigateway:POST"], Condition = { StringEquals = { "aws:ResourceTag/alien.dev/managed-by" = "alien", "aws:ResourceTag/alien.dev/stack" = "${var.stack_name}" } }, Effect = "Allow", Resource = ["arn:aws:apigateway:${data.aws_region.current.region}::/apis/*", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames/*"], Sid = "FunctionManagement8" }, { Action = ["apigateway:TagResource"], Condition = { StringEquals = { "aws:RequestTag/alien.dev/managed-by" = "alien", "aws:RequestTag/alien.dev/stack" = "${var.stack_name}" } }, Effect = "Allow", Resource = ["arn:aws:apigateway:${data.aws_region.current.region}::/apis/*", "arn:aws:apigateway:${data.aws_region.current.region}::/apis/*/stages", "arn:aws:apigateway:${data.aws_region.current.region}::/apis/*/stages/*", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames/*"], Sid = "FunctionManagement9" }, { Action = ["apigateway:GET", "apigateway:DELETE", "apigateway:PATCH", "apigateway:PUT"], Condition = { StringEquals = { "aws:ResourceTag/alien.dev/managed-by" = "alien", "aws:ResourceTag/alien.dev/stack" = "${var.stack_name}" } }, Effect = "Allow", Resource = ["arn:aws:apigateway:${data.aws_region.current.region}::/apis/*", "arn:aws:apigateway:${data.aws_region.current.region}::/domainnames/*"], Sid = "FunctionManagement10" }, { Action = ["events:PutRule", "events:TagResource"], Condition = { StringEquals = { "aws:RequestTag/alien.dev/managed-by" = "alien", "aws:RequestTag/alien.dev/stack" = "${var.stack_name}" } }, Effect = "Allow", Resource = ["arn:aws:events:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:rule/${var.stack_name}-*"], Sid = "FunctionManagement11" }, { Action = ["events:DeleteRule", "events:DescribeRule", "events:PutTargets", "events:RemoveTargets"], Condition = { StringEquals = { "aws:ResourceTag/alien.dev/managed-by" = "alien", "aws:ResourceTag/alien.dev/stack" = "${var.stack_name}" } }, Effect = "Allow", Resource = ["arn:aws:events:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:rule/${var.stack_name}-*"], Sid = "FunctionManagement12" }], Version = "2012-10-17" })
}

resource "aws_iam_role_policy" "management_set_1" {
  name   = "storage-heartbeat-1"
  role   = aws_iam_role.management.id
  policy = jsonencode({ Statement = [{ Action = ["s3:GetBucketLocation", "s3:GetBucketVersioning", "s3:GetLifecycleConfiguration", "s3:GetBucketPolicy", "s3:GetBucketAcl", "s3:GetEncryptionConfiguration", "s3:GetBucketPublicAccessBlock"], Effect = "Allow", Resource = ["arn:aws:s3:::${var.stack_name}-*"], Sid = "StorageHeartbeat" }], Version = "2012-10-17" })
}

resource "aws_iam_role_policy" "management_set_2" {
  name   = "queue-heartbeat-2"
  role   = aws_iam_role.management.id
  policy = jsonencode({ Statement = [{ Action = ["sqs:GetQueueAttributes", "sqs:ListQueueTags"], Effect = "Allow", Resource = ["arn:aws:sqs:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:${var.stack_name}-*"], Sid = "QueueHeartbeat" }], Version = "2012-10-17" })
}

resource "aws_iam_role_policy" "management_set_3" {
  name   = "kv-heartbeat-3"
  role   = aws_iam_role.management.id
  policy = jsonencode({ Statement = [{ Action = ["dynamodb:DescribeTable", "dynamodb:ListTables", "dynamodb:DescribeTimeToLive", "dynamodb:ListTagsOfResource", "dynamodb:DescribeContinuousBackups"], Effect = "Allow", Resource = ["arn:aws:dynamodb:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:table/${var.stack_name}-*"], Sid = "KvHeartbeat" }], Version = "2012-10-17" })
}

resource "aws_iam_role_policy" "management_set_4" {
  name   = "vault-data-write-4"
  role   = aws_iam_role.management.id
  policy = jsonencode({ Statement = [{ Action = ["ssm:PutParameter", "ssm:DeleteParameter"], Effect = "Allow", Resource = ["arn:aws:ssm:${data.aws_region.current.region}:${data.aws_caller_identity.current.account_id}:parameter/${var.stack_name}-*"], Sid = "VaultDataWrite" }], Version = "2012-10-17" })
}

resource "aws_iam_role_policy" "management_self_read" {
  name   = "alien-management-self-read"
  role   = aws_iam_role.management.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "ReadOwnManagementRole", Effect = "Allow", Action = "iam:GetRole", Resource = "arn:aws:iam::${data.aws_caller_identity.current.account_id}:role/${var.stack_name}-management" }] })
}

=== assets.tf ===
resource "aws_s3_bucket" "assets" {
  bucket        = "${var.stack_name}-assets"
  force_destroy = false
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "assets"
    AlienResourceType = "storage"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "assets" {
  bucket = aws_s3_bucket.assets.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

resource "aws_s3_bucket_ownership_controls" "assets" {
  bucket = aws_s3_bucket.assets.id

  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

resource "aws_s3_bucket_public_access_block" "assets" {
  bucket                  = aws_s3_bucket.assets.id
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_policy" "assets" {
  bucket = aws_s3_bucket.assets.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "DenyInsecureTransport", Effect = "Deny", Principal = "*", Action = "s3:*", Resource = [aws_s3_bucket.assets.arn, "${aws_s3_bucket.assets.arn}/*"], Condition = { Bool = { "aws:SecureTransport" = "false" } } }] })
}

resource "aws_s3_bucket_versioning" "assets" {
  bucket = aws_s3_bucket.assets.id

  versioning_configuration {
    status = "Enabled"
  }
}

=== jobs.tf ===
resource "aws_sqs_queue" "jobs" {
  name                       = "${var.stack_name}-jobs"
  sqs_managed_sse_enabled    = true
  visibility_timeout_seconds = 1080
  message_retention_seconds  = 345600
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "jobs"
    AlienResourceType = "queue"
  }
}

=== metadata.tf ===
resource "aws_dynamodb_table" "metadata" {
  name         = "${var.stack_name}-metadata"
  billing_mode = "PAY_PER_REQUEST"
  hash_key     = "pk"
  range_key    = "sk"

  attribute {
    name = "pk"
    type = "S"
  }

  attribute {
    name = "sk"
    type = "S"
  }

  ttl {
    attribute_name = "ttl"
    enabled        = true
  }

  server_side_encryption {
    enabled = true
  }

  point_in_time_recovery {
    enabled = true
  }

  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "metadata"
    AlienResourceType = "kv"
  }

  lifecycle {
    prevent_destroy = false
  }
}

=== registry.tf ===
resource "aws_ecr_repository" "registry" {
  name                 = "${var.stack_name}-registry"
  image_tag_mutability = "IMMUTABLE"

  image_scanning_configuration {
    scan_on_push = true
  }

  encryption_configuration {
    encryption_type = "AES256"
  }

  force_delete = false
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "registry"
    AlienResourceType = "artifact-registry"
  }

  lifecycle {
    prevent_destroy = false
  }
}

resource "aws_ecr_lifecycle_policy" "registry" {
  repository = aws_ecr_repository.registry.name
  policy     = jsonencode({ rules = [{ rulePriority = 1, description = "Retain the 100 most recent images", selection = { tagStatus = "any", countType = "imageCountMoreThan", countNumber = 100 }, action = { type = "expire" } }] })
}

resource "aws_iam_role" "registry_pull" {
  name               = "${var.stack_name}-registry-pull"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { AWS = aws_iam_role.execution_sa.arn }, Action = "sts:AssumeRole" }] })
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "registry"
    AlienResourceType = "artifact-registry"
  }
}

resource "aws_iam_role" "registry_push" {
  name               = "${var.stack_name}-registry-push"
  assume_role_policy = jsonencode({ Version = "2012-10-17", Statement = [{ Effect = "Allow", Principal = { AWS = aws_iam_role.execution_sa.arn }, Action = "sts:AssumeRole" }] })
  tags = {
    ManagedBy         = "alien.dev"
    AlienStackId      = var.stack_name
    AlienResourceId   = "registry"
    AlienResourceType = "artifact-registry"
  }
}

resource "aws_iam_role_policy" "registry_pull_policy" {
  name   = "ecr-pull"
  role   = aws_iam_role.registry_pull.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "GetAuthorizationToken", Effect = "Allow", Action = "ecr:GetAuthorizationToken", Resource = "*" }, { Sid = "RepositoryAccess", Effect = "Allow", Action = ["ecr:BatchCheckLayerAvailability", "ecr:BatchGetImage", "ecr:DescribeImages", "ecr:DescribeRepositories", "ecr:GetDownloadUrlForLayer", "ecr:ListImages"], Resource = aws_ecr_repository.registry.arn }] })
}

resource "aws_iam_role_policy" "registry_push_policy" {
  name   = "ecr-push-pull"
  role   = aws_iam_role.registry_push.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "GetAuthorizationToken", Effect = "Allow", Action = "ecr:GetAuthorizationToken", Resource = "*" }, { Sid = "RepositoryAccess", Effect = "Allow", Action = ["ecr:BatchCheckLayerAvailability", "ecr:BatchGetImage", "ecr:DescribeImages", "ecr:DescribeRepositories", "ecr:GetDownloadUrlForLayer", "ecr:ListImages", "ecr:CompleteLayerUpload", "ecr:InitiateLayerUpload", "ecr:PutImage", "ecr:UploadLayerPart"], Resource = aws_ecr_repository.registry.arn }] })
}

=== import.tf ===
resource "terraform_data" "deployment_stack_import" {
  input = {
    platform               = local.deployment_platform
    deployment_group_token = var.deployment_group_token
    deployment_name        = var.deployment_name == "" ? var.stack_name : var.deployment_name
    stack_prefix           = var.stack_name
    manager_url            = var.manager_url
    management_config      = local.deployment_management_config
    stack_settings         = local.deployment_stack_settings
    resources              = local.deployment_resources
  }
  depends_on = [
    aws_vpc.default_network,
    aws_internet_gateway.default_network,
    aws_subnet.default_network_public,
    aws_subnet.default_network_private,
    aws_eip.default_network_nat,
    aws_nat_gateway.default_network,
    aws_route_table.default_network_public,
    aws_route_table.default_network_private,
    aws_route_table_association.default_network_public,
    aws_route_table_association.default_network_private,
    aws_security_group.default_network_workload,
    aws_iam_role.execution_sa,
    aws_iam_role_policy.execution_sa_set_0,
    aws_iam_role_policy.execution_sa_set_1,
    aws_iam_role.management,
    aws_iam_role_policy.management_set_0,
    aws_iam_role_policy.management_set_1,
    aws_iam_role_policy.management_set_2,
    aws_iam_role_policy.management_set_3,
    aws_iam_role_policy.management_set_4,
    aws_iam_role_policy.management_self_read,
    aws_s3_bucket.assets,
    aws_s3_bucket_server_side_encryption_configuration.assets,
    aws_s3_bucket_ownership_controls.assets,
    aws_s3_bucket_public_access_block.assets,
    aws_s3_bucket_policy.assets,
    aws_s3_bucket_versioning.assets,
    aws_sqs_queue.jobs,
    aws_dynamodb_table.metadata,
    aws_ecr_repository.registry,
    aws_ecr_lifecycle_policy.registry,
    aws_iam_role.registry_pull,
    aws_iam_role.registry_push,
    aws_iam_role_policy.registry_pull_policy,
    aws_iam_role_policy.registry_push_policy
  ]
}

=== outputs.tf ===
output "deployment_target" {
  value       = "aws"
  description = "Terraform module target."
}

output "deployment_stack_prefix" {
  value       = var.stack_name
  description = "Physical stack prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_stack_settings" {
  value       = jsonencode(local.deployment_stack_settings)
  description = "Manager import StackSettings JSON."
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - full-aws

Target: `aws`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='stack_name=full-aws' -var='deployment_group_token=...'
```

This module exposes `deployment_management_config` / `deployment_stack_settings` / `deployment_resources` for external registration flows.

source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    azurerm = {
      source  = "hashicorp/azurerm"
      version = ">= 3.100"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "resource_prefix" {
  type        = string
  description = "Optional stable physical resource prefix. Leave empty to generate one."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || (can(regex("^[a-z][a-z0-9-]{1,38}[a-z0-9]$", var.resource_prefix)) && length(regexall("--", var.resource_prefix)) == 0)
    error_message = "resource_prefix must be 3-40 characters: lowercase letters, numbers, and hyphens; start with a letter; end with a letter or number; and not contain consecutive hyphens."
  }
}

variable "name" {
  type        = string
  description = "Human-readable application name shown in setup and cloud IAM review metadata."
}

variable "token" {
  type        = string
  description = "Install token from the application setup page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "stack_settings_json" {
  type        = string
  description = "Optional JSON-encoded StackSettings override supplied by deployment installers."
  default     = "{}"
  sensitive   = true
}

variable "azure_location" {
  type        = string
  description = "Azure location."
  default     = "eastus"
}

variable "azure_subscription_id" {
  type        = string
  description = "Azure subscription ID hosting the stack."
}

variable "azure_resource_group_name" {
  type        = string
  description = "Azure resource group name."
}

variable "azure_managing_tenant_id" {
  type        = string
  description = "Azure tenant ID the manager uses for cross-tenant access."
}

variable "azure_oidc_issuer" {
  type        = string
  description = "OIDC issuer URL for Azure Federated Identity Credential."
}

variable "azure_oidc_subject" {
  type        = string
  description = "OIDC subject claim for Azure Federated Identity Credential."
}

=== providers.tf ===
provider "azurerm" {
  resource_provider_registrations = "none"

  features {}
}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 4
}

=== locals.tf ===
locals {
  resource_prefix     = var.resource_prefix == "" ? format("a%s", random_id.resource_prefix.hex) : var.resource_prefix
  deployment_name     = var.name
  deployment_platform = "azure"
  deployment_target   = "azure"
  deployment_region   = var.azure_location
  deployment_management_config = {
    platform         = "azure"
    managingTenantId = var.azure_managing_tenant_id
    oidcIssuer       = var.azure_oidc_issuer
    oidcSubject      = var.azure_oidc_subject
  }
  deployment_settings = jsondecode(var.stack_settings_json)
  deployment_resources = [
    {
      id   = "default-resource-group"
      type = "azure_resource_group"
      importData = {
        subscriptionId = var.azure_subscription_id
        resourceGroup  = azurerm_resource_group.default_resource_group.name
        location       = azurerm_resource_group.default_resource_group.location
      }
    },
    {
      id   = "execution-sa"
      type = "service-account"
      importData = {
        subscriptionId          = var.azure_subscription_id
        resourceGroup           = var.azure_resource_group_name
        identityId              = azurerm_user_assigned_identity.execution_sa.id
        principalId             = azurerm_user_assigned_identity.execution_sa.principal_id
        clientId                = azurerm_user_assigned_identity.execution_sa.client_id
        stackPermissionsApplied = true
      }
    }
  ]
}

=== default_resource_group.tf ===
resource "azurerm_resource_group" "default_resource_group" {
  name     = var.azure_resource_group_name
  location = var.azure_location
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "default-resource-group"
    "resource-type" = "resource-group"
  }
}

=== execution_sa.tf ===
resource "azurerm_user_assigned_identity" "execution_sa" {
  name                = "${local.resource_prefix}-execution-sa"
  resource_group_name = var.azure_resource_group_name
  location            = var.azure_location
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "execution-sa"
    "resource-type" = "service-account"
  }
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

resource "azurerm_role_assignment" "execution_sa_storage_blob_data_reader___var_azure_resource_group_name__assignment" {
  name               = uuidv5("oid", "deployment:azure:role-assign:execution-sa:storage_blob_data_reader___var_azure_resource_group_name_:${azurerm_user_assigned_identity.execution_sa.principal_id}")
  scope              = "/subscriptions/${var.azure_subscription_id}/resourceGroups/${var.azure_resource_group_name}"
  role_definition_id = "/subscriptions/${var.azure_subscription_id}/providers/Microsoft.Authorization/roleDefinitions/2a2b9908-6ea1-4ae2-8e65-a410df84e7d1"
  principal_id       = azurerm_user_assigned_identity.execution_sa.principal_id
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

resource "azurerm_role_assignment" "execution_sa_azure_service_bus_data_sender___var_azure_resource_group_name__assignment" {
  name               = uuidv5("oid", "deployment:azure:role-assign:execution-sa:azure_service_bus_data_sender___var_azure_resource_group_name_:${azurerm_user_assigned_identity.execution_sa.principal_id}")
  scope              = "/subscriptions/${var.azure_subscription_id}/resourceGroups/${var.azure_resource_group_name}"
  role_definition_id = "/subscriptions/${var.azure_subscription_id}/providers/Microsoft.Authorization/roleDefinitions/69a216fc-b8fb-44d8-bc22-1f3c2cd27a39"
  principal_id       = azurerm_user_assigned_identity.execution_sa.principal_id
  depends_on = [
    azurerm_resource_group.default_resource_group
  ]
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                  = local.deployment_platform
    token                     = var.token
    name                      = var.name
    resource_prefix           = local.resource_prefix
    setup_target              = ""
    setup_fingerprint         = ""
    setup_fingerprint_version = 0
    manager_url               = var.manager_url
    management_config         = local.deployment_management_config
    stack_settings            = local.deployment_settings
    resources                 = local.deployment_resources
  }
  depends_on = [
    azurerm_resource_group.default_resource_group,
    azurerm_user_assigned_identity.execution_sa,
    azurerm_role_assignment.execution_sa_storage_blob_data_reader___var_azure_resource_group_name__assignment,
    azurerm_role_assignment.execution_sa_azure_service_bus_data_sender___var_azure_resource_group_name__assignment
  ]
}

=== outputs.tf ===
output "deployment_target" {
  value       = "azure"
  description = "Terraform module target."
}

output "deployment_resource_prefix" {
  value       = local.resource_prefix
  description = "Physical resource prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_setup_target" {
  value       = ""
  description = "Setup target."
}

output "deployment_setup_fingerprint" {
  value       = ""
  description = "Setup compatibility fingerprint."
}

output "deployment_setup_fingerprint_version" {
  value       = 0
  description = "Setup fingerprint algorithm version."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_stack_settings" {
  value       = jsonencode(local.deployment_settings)
  description = "Manager import StackSettings JSON."
  sensitive   = true
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-iam

Target: `azure`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='name=acme-iam' -var='token=...'
```

This module exposes `deployment_management_config` / `deployment_stack_settings` / `deployment_resources` for external registration flows.

---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "name" {
  type        = string
  description = "Human-readable deployment name shown in the deployment portal."
}

variable "token" {
  type        = string
  description = "Deployment token from the deployment page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "resource_prefix" {
  type        = string
  description = "Optional stable cloud resource prefix. Leave empty to generate one and store it in Terraform state."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || can(regex("^[a-z][a-z0-9-]{1,30}[a-z0-9]$", var.resource_prefix))
    error_message = "resource_prefix must be empty or 3-32 characters using lowercase letters, numbers, and hyphens, starting with a letter and ending with a letter or number."
  }
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "deployment_settings_json" {
  type        = string
  description = "Optional JSON-encoded deployment settings override supplied by deployment installers."
  default     = "{}"
  sensitive   = true
}

variable "aws_region" {
  type        = string
  description = "AWS region used by the AWS provider."
  default     = "us-east-1"
}

variable "managing_role_arn" {
  type        = string
  description = "ARN of the manager IAM identity allowed to assume management roles."
  default     = ""
}

variable "managing_account_id" {
  type        = string
  description = "Account ID hosting the manager. Referenced by resource-side IAM policies that scope cross-account image pulls. Empty disables those grants."
  default     = ""
}

=== providers.tf ===
provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 8
}

=== locals.tf ===
locals {
  resource_prefix     = var.resource_prefix != "" ? var.resource_prefix : "a${random_id.resource_prefix.hex}"
  deployment_platform = "aws"
  deployment_target   = "aws"
  deployment_region   = data.aws_region.current.region
  deployment_management_config = {
    platform        = "aws"
    managingRoleArn = var.managing_role_arn
  }
  deployment_settings = jsondecode(var.deployment_settings_json)
  deployment_resources = [
    {
      id   = "audit"
      type = "storage"
      importData = {
        bucketName = aws_s3_bucket.audit.bucket
        bucketArn  = aws_s3_bucket.audit.arn
      }
    }
  ]
}

=== audit.tf ===
resource "aws_s3_bucket" "audit" {
  bucket        = "${local.resource_prefix}-audit"
  force_destroy = true
  tags = {
    "managed-by"    = "deployment"
    deployment      = local.resource_prefix
    resource        = "audit"
    "resource-type" = "storage"
  }
}

resource "aws_s3_bucket_server_side_encryption_configuration" "audit" {
  bucket = aws_s3_bucket.audit.id

  rule {
    apply_server_side_encryption_by_default {
      sse_algorithm = "AES256"
    }
  }
}

resource "aws_s3_bucket_ownership_controls" "audit" {
  bucket = aws_s3_bucket.audit.id

  rule {
    object_ownership = "BucketOwnerEnforced"
  }
}

resource "aws_s3_bucket_public_access_block" "audit" {
  bucket                  = aws_s3_bucket.audit.id
  block_public_acls       = true
  block_public_policy     = true
  ignore_public_acls      = true
  restrict_public_buckets = true
}

resource "aws_s3_bucket_policy" "audit" {
  bucket = aws_s3_bucket.audit.id
  policy = jsonencode({ Version = "2012-10-17", Statement = [{ Sid = "DenyInsecureTransport", Effect = "Deny", Principal = "*", Action = "s3:*", Resource = [aws_s3_bucket.audit.arn, "${aws_s3_bucket.audit.arn}/*"], Condition = { Bool = { "aws:SecureTransport" = "false" } } }] })
}

resource "aws_s3_bucket_versioning" "audit" {
  bucket = aws_s3_bucket.audit.id

  versioning_configuration {
    status = "Enabled"
  }
}

resource "aws_s3_bucket_lifecycle_configuration" "audit" {
  bucket = aws_s3_bucket.audit.id

  rule {
    id     = "rule-1"
    status = "Enabled"

    filter {
      prefix = "logs/"
    }

    expiration {
      days = 90
    }
  }
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                  = local.deployment_platform
    token                     = var.token
    name                      = var.name
    resource_prefix           = local.resource_prefix
    setup_target              = ""
    setup_fingerprint         = ""
    setup_fingerprint_version = 0
    manager_url               = var.manager_url
    management_config         = local.deployment_management_config
    deployment_settings       = local.deployment_settings
    resources                 = local.deployment_resources
  }
  depends_on = [
    aws_s3_bucket.audit,
    aws_s3_bucket_server_side_encryption_configuration.audit,
    aws_s3_bucket_ownership_controls.audit,
    aws_s3_bucket_public_access_block.audit,
    aws_s3_bucket_policy.audit,
    aws_s3_bucket_versioning.audit,
    aws_s3_bucket_lifecycle_configuration.audit
  ]
}

=== outputs.tf ===
output "deployment_target" {
  value       = "aws"
  description = "Terraform module target."
}

output "deployment_resource_prefix" {
  value       = local.resource_prefix
  description = "Stable physical resource prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_setup_target" {
  value       = ""
  description = "Setup target."
}

output "deployment_setup_fingerprint" {
  value       = ""
  description = "Setup compatibility fingerprint."
}

output "deployment_setup_fingerprint_version" {
  value       = 0
  description = "Setup fingerprint algorithm version."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_settings_json" {
  value       = jsonencode(local.deployment_settings)
  description = "Manager import deployment settings JSON."
  sensitive   = true
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-audit

Target: `aws`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='name=acme-audit' -var='token=...'
```

This module exposes `deployment_management_config` / `deployment_settings_json` / `deployment_resources` for external registration flows.

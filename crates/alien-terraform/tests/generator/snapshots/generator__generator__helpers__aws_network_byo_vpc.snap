---
source: crates/alien-terraform/tests/generator/helpers.rs
expression: buf
---
=== versions.tf ===
terraform {
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
    random = {
      source  = "hashicorp/random"
      version = ">= 3.6"
    }
  }
}

=== variables.tf ===
variable "resource_prefix" {
  type        = string
  description = "Optional stable physical resource prefix. Leave empty to generate one."
  default     = ""

  validation {
    condition     = var.resource_prefix == "" || can(regex("^[a-z][a-z0-9-]{1,38}[a-z0-9]$", var.resource_prefix))
    error_message = "resource_prefix must be 3-40 characters: lowercase letters, numbers, and hyphens; start with a letter; end with a letter or number."
  }
}

variable "name" {
  type        = string
  description = "Human-readable deployment name shown in the deployment portal."
}

variable "token" {
  type        = string
  description = "Deployment token from the deployment page. This is the same token used by the deploy CLI --token flag."
  sensitive   = true
}

variable "manager_url" {
  type        = string
  description = "Optional manager endpoint used by pull-style runtimes."
  default     = ""
}

variable "stack_settings_json" {
  type        = string
  description = "Optional JSON-encoded StackSettings override supplied by deployment installers."
  default     = "{\"network\":{\"type\":\"byo-vpc-aws\",\"vpc_id\":\"vpc-0123456789abcdef0\",\"public_subnet_ids\":[\"subnet-public-a\"],\"private_subnet_ids\":[\"subnet-private-a\"],\"security_group_ids\":[\"sg-0123456789abcdef0\"]}}"
  sensitive   = true
}

variable "aws_region" {
  type        = string
  description = "AWS region used by the AWS provider."
  default     = "us-east-1"
}

variable "managing_role_arn" {
  type        = string
  description = "ARN of the manager IAM identity allowed to assume management roles."
  default     = ""
}

variable "managing_account_id" {
  type        = string
  description = "Account ID hosting the manager. Referenced by resource-side IAM policies that scope cross-account image pulls. Empty disables those grants."
  default     = ""
}

variable "network_mode" {
  type        = string
  description = "Choose whether this setup creates a new network, uses an existing network, or uses the default network. Values: create-new, use-existing, use-default."
  default     = "create-new"
}

variable "vpc_cidr" {
  type        = string
  description = "CIDR for a newly-created network. Empty uses 10.42.0.0/16."
  default     = ""
}

variable "availability_zones" {
  type        = number
  description = "Number of availability zones to use when creating a new network."
  default     = 2
}

variable "vpc_id" {
  type        = string
  description = "Existing VPC ID. Required when network is use-existing."
  default     = ""
}

variable "public_subnet_ids" {
  type        = list(string)
  description = "Existing public subnet IDs. Required when network is use-existing."
  default     = []
}

variable "private_subnet_ids" {
  type        = list(string)
  description = "Existing private subnet IDs. Required when network is use-existing."
  default     = []
}

variable "security_group_ids" {
  type        = list(string)
  description = "Existing security group IDs. Required when network is use-existing."
  default     = []
}

variable "default_network_vpc_id" {
  type        = string
  description = "Existing VPC ID supplied by the customer."
  default     = "vpc-0123456789abcdef0"
}

variable "default_network_public_subnet_ids" {
  type        = list(string)
  description = "Existing public subnet IDs supplied by the customer."
  default = [
    "subnet-public-a"
  ]
}

variable "default_network_private_subnet_ids" {
  type        = list(string)
  description = "Existing private subnet IDs supplied by the customer."
  default = [
    "subnet-private-a"
  ]
}

variable "default_network_security_group_ids" {
  type        = list(string)
  description = "Existing security group IDs supplied by the customer."
  default = [
    "sg-0123456789abcdef0"
  ]
}

=== providers.tf ===
provider "aws" {
  region = var.aws_region
}

data "aws_caller_identity" "current" {}

data "aws_region" "current" {}

=== resource_prefix.tf ===
resource "random_id" "resource_prefix" {
  byte_length = 4
}

=== locals.tf ===
locals {
  resource_prefix     = var.resource_prefix == "" ? format("a%s", random_id.resource_prefix.hex) : var.resource_prefix
  deployment_platform = "aws"
  deployment_target   = "aws"
  deployment_region   = data.aws_region.current.region
  deployment_management_config = {
    platform        = "aws"
    managingRoleArn = var.managing_role_arn
  }
  deployment_settings = merge(jsondecode(var.stack_settings_json), { network = jsondecode(var.network_mode == "create-new" ? jsonencode({ type = "create", cidr = var.vpc_cidr == "" ? null : var.vpc_cidr, availabilityZones = var.availability_zones }) : var.network_mode == "use-existing" ? jsonencode({ type = "byo-vpc-aws", vpcId = var.vpc_id, publicSubnetIds = var.public_subnet_ids, privateSubnetIds = var.private_subnet_ids, securityGroupIds = var.security_group_ids }) : jsonencode({ type = "use-default" })) })
  deployment_resources = [
    {
      id   = "default-network"
      type = "network"
      importData = {
        vpcId               = var.default_network_vpc_id
        cidrBlock           = null
        internetGatewayId   = null
        natGatewayId        = null
        eipAllocationId     = null
        publicSubnetIds     = var.default_network_public_subnet_ids
        privateSubnetIds    = var.default_network_private_subnet_ids
        publicRouteTableId  = null
        privateRouteTableId = null
        securityGroupId     = try(var.default_network_security_group_ids[0], null)
        availabilityZones   = data.aws_availability_zones.available.names
        isByoVpc            = true
      }
    }
  ]
}

=== default_network.tf ===
data "aws_availability_zones" "available" {
  state = "available"
}

=== import.tf ===
resource "terraform_data" "deployment_import" {
  input = {
    platform                  = local.deployment_platform
    token                     = var.token
    name                      = var.name
    resource_prefix           = local.resource_prefix
    setup_target              = ""
    setup_fingerprint         = ""
    setup_fingerprint_version = 0
    manager_url               = var.manager_url
    management_config         = local.deployment_management_config
    stack_settings            = local.deployment_settings
    resources                 = local.deployment_resources
  }
}

=== outputs.tf ===
output "deployment_target" {
  value       = "aws"
  description = "Terraform module target."
}

output "deployment_resource_prefix" {
  value       = local.resource_prefix
  description = "Physical resource prefix."
}

output "deployment_platform" {
  value       = local.deployment_platform
  description = "Target platform."
}

output "deployment_region" {
  value       = local.deployment_region
  description = "Target cloud region or location."
}

output "deployment_setup_target" {
  value       = ""
  description = "Setup target."
}

output "deployment_setup_fingerprint" {
  value       = ""
  description = "Setup compatibility fingerprint."
}

output "deployment_setup_fingerprint_version" {
  value       = 0
  description = "Setup fingerprint algorithm version."
}

output "deployment_management_config" {
  value       = jsonencode(local.deployment_management_config)
  description = "Manager import ManagementConfig JSON."
}

output "deployment_stack_settings" {
  value       = jsonencode(local.deployment_settings)
  description = "Manager import StackSettings JSON."
  sensitive   = true
}

output "deployment_resources" {
  value       = jsonencode(local.deployment_resources)
  description = "Manager import resources JSON."
}

=== README.md ===
# Terraform module - acme-byo

Target: `aws`.

Run:

```bash
terraform init -backend=false
terraform validate
terraform apply -var='name=acme-byo' -var='token=...'
```

This module exposes `deployment_management_config` / `deployment_stack_settings` / `deployment_resources` for external registration flows.

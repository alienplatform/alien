---
source: crates/alien-permissions/tests/aws_cloudformation.rs
expression: result
---
{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "WorkerExecute1",
      "Effect": "Allow",
      "Action": [
        "lambda:InvokeWorker"
      ],
      "Resource": [
        {
          "Fn::Sub": "arn:${AWS::Partition}:lambda:${AWS::Region}:${AWS::AccountId}:function:${AWS::StackName}-*"
        }
      ]
    },
    {
      "Sid": "WorkerExecute2",
      "Effect": "Allow",
      "Action": [
        "ecr:BatchGetImage",
        "ecr:GetDownloadUrlForLayer"
      ],
      "Resource": [
        {
          "Fn::Sub": "arn:${AWS::Partition}:ecr:*:${ManagingAccountId}:repository/*"
        }
      ],
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "my-external-id"
        }
      }
    }
  ]
}

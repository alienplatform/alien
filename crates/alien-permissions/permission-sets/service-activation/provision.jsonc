{
  "id": "service-activation/provision",
  "description": "Allows enabling, disabling, and managing GCP project services",
  "platforms": {
    "gcp": [
      {
        "grant": {
          "predefinedRoles": ["roles/serviceusage.serviceUsageAdmin"]
        },
        "binding": {
          "stack": {
            "scope": "projects/${projectName}"
          },
          "resource": {
            "scope": "projects/${projectName}"
          }
        }
      }
    ]
  }
}

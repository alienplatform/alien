{
  "id": "service-activation/management",
  "description": "Allows reading GCP project service status and configuration",
  "platforms": {
    "gcp": [
      {
        "grant": {
          "predefinedRoles": ["roles/serviceusage.serviceUsageViewer"]
        },
        "binding": {
          "stack": {
            "scope": "projects/${projectName}"
          },
          "resource": {
            "scope": "projects/${projectName}"
          }
        }
      }
    ]
  }
}

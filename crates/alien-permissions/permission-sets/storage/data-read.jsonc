{
  // Allows reading data from storage resources
  "id": "storage/data-read",
  "description": "Allows reading data from storage buckets and containers",
  "platforms": {
    "aws": [
      {
        "label": "read-s3-objects",
        "description": "Read objects and object metadata from application-owned S3 buckets.",
        "grant": {
          "actions": ["s3:ListBucket", "s3:GetObject", "s3:GetObjectVersion", "s3:GetObjectAcl"]
        },
        "binding": {
          "stack": {
            "resources": ["arn:aws:s3:::${stackPrefix}-*", "arn:aws:s3:::${stackPrefix}-*/*"]
          },
          "resource": {
            "resources": ["arn:aws:s3:::${resourceName}", "arn:aws:s3:::${resourceName}/*"]
          }
        }
      }
    ],
    "gcp": [
      {
        "label": "read-cloud-storage-objects",
        "description": "Read objects and object metadata from application-owned Cloud Storage buckets.",
        "grant": {
          "permissions": [
            "storage.buckets.get",
            "storage.buckets.list",
            "storage.objects.get",
            "storage.objects.list",
            "storage.objects.getIamPolicy",
            "storage.multipartUploads.list",
            "storage.multipartUploads.listParts"
          ]
        },
        "binding": {
          "stack": {
            "scope": "projects/${projectName}"
          },
          "resource": {
            "scope": "projects/${projectName}/buckets/${resourceName}"
          }
        }
      },
      {
        "label": "sign-cloud-storage-download-urls",
        "description": "Sign Cloud Storage download URLs on behalf of this application's service account.",
        "grant": {
          "permissions": ["iam.serviceAccounts.signBlob"]
        },
        "binding": {
          "stack": {
            "scope": "projects/${projectName}"
          },
          "resource": {
            "scope": "projects/${projectName}"
          }
        }
      }
    ],
    "azure": [
      {
        "label": "read-blob-storage-objects",
        "description": "Read objects from application-owned Azure Blob Storage containers.",
        "grant": {
          "predefinedRoles": ["Storage Blob Data Reader"]
        },
        "binding": {
          "stack": {
            "scope": "/subscriptions/${subscriptionId}/resourceGroups/${resourceGroup}"
          },
          "resource": {
            "scope": "/subscriptions/${subscriptionId}/resourceGroups/${resourceGroup}/providers/Microsoft.Storage/storageAccounts/${storageAccountName}"
          }
        }
      }
    ]
  }
}

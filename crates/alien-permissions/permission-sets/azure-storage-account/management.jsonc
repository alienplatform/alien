{
  "id": "azure-storage-account/management",
  "description": "Allows managing Azure storage account configuration, metadata, and monitoring",
  "platforms": {
    "azure": [
      {
        "grant": {
          "predefinedRoles": ["Reader"]
        },
        "binding": {
          "stack": {
            "scope": "/subscriptions/${subscriptionId}/resourceGroups/${resourceGroup}"
          },
          "resource": {
            "scope": "/subscriptions/${subscriptionId}/resourceGroups/${resourceGroup}/providers/Microsoft.Storage/storageAccounts/${resourceName}"
          }
        }
      }
    ]
  }
}

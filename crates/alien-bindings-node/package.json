{
  "name": "@alienplatform/bindings-node",
  "version": "0.0.0",
  "private": true,
  "description": "napi-rs addon exposing alien-bindings storage/kv/queue/vault to JavaScript",
  "napi": {
    "binaryName": "alien-bindings-node",

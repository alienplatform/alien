---
source: crates/alien-cloudformation/tests/generator/aws_data_layer_tests.rs
expression: yaml
---
AWSTemplateFormatVersion: 2010-09-09
Description: aws storage minimal
Transform:
- AWS::LanguageExtensions
Metadata:
  AWS::CloudFormation::Interface:
    ParameterGroups:
    - Label:
        default: Registration
      Parameters:
      - DeploymentGroupToken
      - ManagingRoleArn
      - ManagingAccountId
    - Label:
        default: Domains
      Parameters:
      - DomainName
      - HostedZoneId
      - CertificateArn
    - Label:
        default: Operations
      Parameters:
      - UpdatesMode
      - TelemetryMode
      - HeartbeatsMode
    ParameterLabels:
      CertificateArn:
        default: Certificate ARN
      DeploymentGroupToken:
        default: Deployment group token
      DomainName:
        default: Domain name
      HeartbeatsMode:
        default: Heartbeats
      HostedZoneId:
        default: Hosted zone ID
      ManagingAccountId:
        default: Manager AWS account ID
      ManagingRoleArn:
        default: Manager role ARN
      TelemetryMode:
        default: Telemetry
      UpdatesMode:
        default: Updates
Parameters:
  DeploymentGroupToken:
    Type: String
    Description: Deployment-group token used when registering the resolved stack import.
    NoEcho: true
  ManagingRoleArn:
    Type: String
    Description: AWS IAM role ARN for the manager identity allowed to assume generated management roles.
  ManagingAccountId:
    Type: String
    Description: AWS account ID hosting the manager. Referenced by stack-side IAM policies that scope cross-account ECR pulls. Empty disables those grants.
    Default: ''
  DomainName:
    Type: String
    Description: Optional domain name for public endpoints. Empty disables custom domains.
  HostedZoneId:
    Type: String
    Description: Optional Route 53 hosted zone ID for the domain.
  CertificateArn:
    Type: String
    Description: Optional ACM certificate ARN for the domain.
  UpdatesMode:
    Type: String
    Description: How updates are applied after import.
    Default: auto
    AllowedValues:
    - auto
    - approval-required
  TelemetryMode:
    Type: String
    Description: Telemetry collection behavior.
    Default: auto
    AllowedValues:
    - off
    - auto
    - approval-required
  HeartbeatsMode:
    Type: String
    Description: Heartbeat health-check behavior.
    Default: on
    AllowedValues:
    - off
    - on
Conditions:
  HasDomainName:
    Fn::Not:
    - Fn::Equals:
      - Ref: DomainName
      - ''
Resources:
  Data:
    Type: AWS::S3::Bucket
    Properties:
      BucketEncryption:
        ServerSideEncryptionConfiguration:
        - ServerSideEncryptionByDefault:
            SSEAlgorithm: AES256
      OwnershipControls:
        Rules:
        - ObjectOwnership: BucketOwnerEnforced
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: storage-minimal
      - Key: AlienResourceId
        Value: data
      - Key: AlienResourceType
        Value: storage
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  DataBucketPolicy:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket:
        Ref: Data
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Sid: DenyInsecureTransport
          Effect: Deny
          Principal: '*'
          Action: s3:*
          Resource:
          - Fn::GetAtt:
            - Data
            - Arn
          - Fn::Sub: arn:${AWS::Partition}:s3:::${Data}/*
          Condition:
            Bool:
              aws:SecureTransport: 'false'
Outputs:
  AlienSourceKind:
    Value: cloudformation
    Description: Distribution source kind.
  AlienPlatform:
    Value: aws
    Description: Target platform.
  AlienRegion:
    Value:
      Ref: AWS::Region
    Description: AWS region.
  AlienManagementConfig:
    Value:
      Fn::ToJsonString:
        platform: aws
        managingRoleArn:
          Ref: ManagingRoleArn
    Description: Manager import ManagementConfig JSON.
  AlienStackSettings:
    Value:
      Fn::ToJsonString:
        deploymentModel: push
        updates:
          Ref: UpdatesMode
        telemetry:
          Ref: TelemetryMode
        heartbeats:
          Ref: HeartbeatsMode
        network:
          Ref: AWS::NoValue
        domains:
          Fn::If:
          - HasDomainName
          - customDomains:
              default:
                domain:
                  Ref: DomainName
                certificate:
                  aws:
                    certificateArn:
                      Ref: CertificateArn
          - Ref: AWS::NoValue
    Description: Manager import StackSettings JSON.
  AlienResources:
    Value:
      Fn::ToJsonString:
      - id: data
        type: storage
        importData:
          bucketName:
            Ref: Data
          bucketArn:
            Fn::GetAtt:
            - Data
            - Arn
    Description: Manager import resources JSON.

---
source: crates/alien-cloudformation/tests/generator/aws_email_tests.rs
expression: yaml
---
AWSTemplateFormatVersion: 2010-09-09
Description: aws email
Transform:
- AWS::LanguageExtensions
Metadata:
  AWS::CloudFormation::Interface:
    ParameterGroups:
    - Label:
        default: Registration
      Parameters:
      - Token
      - ManagingRoleArn
      - ManagingAccountId
    - Label:
        default: Operations
      Parameters:
      - UpdatesMode
      - TelemetryMode
      - HeartbeatsMode
    ParameterLabels:
      HeartbeatsMode:
        default: Heartbeats
      ManagingAccountId:
        default: Image account ID
      ManagingRoleArn:
        default: Management role ARN
      TelemetryMode:
        default: Telemetry
      Token:
        default: Install token
      UpdatesMode:
        default: Updates
Parameters:
  Token:
    Type: String
    Description: Install token from the application setup page.
    NoEcho: true
  ManagingRoleArn:
    Type: String
    Description: ARN of the management identity allowed to assume setup-created roles.
    Default: ''
  ManagingAccountId:
    Type: String
    Description: AWS account ID for the management account that hosts application container images.
    Default: ''
  NetworkMode:
    Type: String
    Description: Choose create-new for a managed VPC, use-existing for your VPC, or use-default for the account default VPC.
    Default: create-new
    AllowedValues:
    - create-new
    - use-existing
    - use-default
  UpdatesMode:
    Type: String
    Description: How updates are applied after setup registration.
    Default: auto
    AllowedValues:
    - auto
    - approval-required
  TelemetryMode:
    Type: String
    Description: Telemetry collection behavior.
    Default: auto
    AllowedValues:
    - auto
  HeartbeatsMode:
    Type: String
    Description: Heartbeat health-check behavior.
    Default: "on"
    AllowedValues:
    - "off"
    - "on"
Resources:
  Mailbox:
    Type: AWS::S3::Bucket
    Properties:
      BucketName:
        Fn::Join:
        - '-'
        - - Ref: AWS::StackName
          - mailbox
          - Fn::Select:
            - 0
            - Fn::Split:
              - '-'
              - Fn::Select:
                - 2
                - Fn::Split:
                  - /
                  - Ref: AWS::StackId
      BucketEncryption:
        ServerSideEncryptionConfiguration:
        - ServerSideEncryptionByDefault:
            SSEAlgorithm: AES256
      OwnershipControls:
        Rules:
        - ObjectOwnership: BucketOwnerEnforced
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: mailbox
      - Key: resource-type
        Value: storage
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  MailboxBucketPolicy:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket:
        Ref: Mailbox
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Sid: DenyInsecureTransport
          Effect: Deny
          Principal: '*'
          Action: s3:*
          Resource:
          - Fn::GetAtt:
            - Mailbox
            - Arn
          - Fn::Sub: arn:${AWS::Partition}:s3:::${Mailbox}/*
          Condition:
            Bool:
              aws:SecureTransport: 'false'
        - Sid: AllowSesInboundDelivery
          Effect: Allow
          Principal:
            Service: ses.amazonaws.com
          Action: s3:PutObject
          Resource:
            Fn::Sub: arn:${AWS::Partition}:s3:::${Mailbox}/*
          Condition:
            StringEquals:
              aws:SourceAccount:
                Ref: AWS::AccountId
  MailEvents:
    Type: AWS::SQS::Queue
    Properties:
      SqsManagedSseEnabled: true
      VisibilityTimeout: 30
      MessageRetentionPeriod: 345600
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: mail-events
      - Key: resource-type
        Value: queue
  MailerConfigSet:
    Type: AWS::SES::ConfigurationSet
    Properties:
      Name:
        Fn::Sub: ${AWS::StackName}-mailer
  MailerIdentity0:
    Type: AWS::SES::EmailIdentity
    Properties:
      EmailIdentity: mail.example.com
      DkimAttributes:
        SigningEnabled: true
      ConfigurationSetAttributes:
        ConfigurationSetName:
          Ref: MailerConfigSet
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: mailer
      - Key: resource-type
        Value: email
  MailerIdentity1:
    Type: AWS::SES::EmailIdentity
    Properties:
      EmailIdentity: mail.example.org
      DkimAttributes:
        SigningEnabled: true
      ConfigurationSetAttributes:
        ConfigurationSetName:
          Ref: MailerConfigSet
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: mailer
      - Key: resource-type
        Value: email
  MailerEventsTopic:
    Type: AWS::SNS::Topic
    Properties:
      TopicName:
        Fn::Sub: ${AWS::StackName}-mailer-email-events
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: mailer
      - Key: resource-type
        Value: email
  MailerEventDestination:
    Type: AWS::SES::ConfigurationSetEventDestination
    Properties:
      ConfigurationSetName:
        Ref: MailerConfigSet
      EventDestination:
        Name:
          Fn::Sub: ${AWS::StackName}-mailer-events
        Enabled: true
        MatchingEventTypes:
        - SEND
        - DELIVERY
        - BOUNCE
        - COMPLAINT
        - DELIVERY_DELAY
        - REJECT
        SnsDestination:
          TopicARN:
            Ref: MailerEventsTopic
  MailerEventsSubscription:
    Type: AWS::SNS::Subscription
    Properties:
      TopicArn:
        Ref: MailerEventsTopic
      Protocol: sqs
      Endpoint:
        Fn::GetAtt:
        - MailEvents
        - Arn
      RawMessageDelivery: true
  MailerEventsQueuePolicy:
    Type: AWS::SQS::QueuePolicy
    Properties:
      Queues:
      - Ref: MailEvents
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Sid: AllowSesEventsTopic
          Effect: Allow
          Principal:
            Service: sns.amazonaws.com
          Action: sqs:SendMessage
          Resource:
            Fn::GetAtt:
            - MailEvents
            - Arn
          Condition:
            ArnEquals:
              aws:SourceArn:
                Ref: MailerEventsTopic
  MailerRuleSet:
    Type: AWS::SES::ReceiptRuleSet
    Properties:
      RuleSetName:
        Fn::Sub: ${AWS::StackName}-mailer
  MailerInboundRule:
    Type: AWS::SES::ReceiptRule
    Properties:
      RuleSetName:
        Ref: MailerRuleSet
      Rule:
        Name:
          Fn::Sub: ${AWS::StackName}-mailer-inbound
        Enabled: true
        ScanEnabled: true
        Recipients:
        - mail.example.com
        - mail.example.org
        Actions:
        - S3Action:
            BucketName:
              Ref: Mailbox
    DependsOn:
    - MailboxBucketPolicy
Outputs:
  DeploymentSourceKind:
    Value: cloudformation
    Description: Setup source kind.
  DeploymentResourcePrefix:
    Value:
      Ref: AWS::StackName
    Description: Stable physical resource prefix.
  DeploymentPlatform:
    Value: aws
    Description: Target platform.
  DeploymentRegion:
    Value:
      Ref: AWS::Region
    Description: AWS region.
  DeploymentSetupTarget:
    Value: aws
    Description: Setup target.
  DeploymentSetupFingerprint:
    Value: test
    Description: Setup compatibility fingerprint.
  DeploymentSetupImportFormatVersion:
    Value: 1
    Description: Setup registration payload format version.
  DeploymentSetupFingerprintVersion:
    Value: 1
    Description: Setup fingerprint algorithm version.
  DeploymentManagementConfig:
    Value:
      Fn::ToJsonString:
        platform: aws
        managingRoleArn:
          Ref: ManagingRoleArn
    Description: Deployment registration management configuration JSON.
  DeploymentStackSettings:
    Value:
      Fn::ToJsonString:
        deploymentModel: push
        updates:
          Ref: UpdatesMode
        telemetry:
          Ref: TelemetryMode
        heartbeats:
          Ref: HeartbeatsMode
        network:
          Ref: AWS::NoValue
    Description: Deployment registration settings JSON.
  DeploymentResources:
    Value:
      Fn::ToJsonString:
      - id: mailbox
        type: storage
        importData:
          bucketName:
            Ref: Mailbox
          bucketArn:
            Fn::GetAtt:
            - Mailbox
            - Arn
      - id: mail-events
        type: queue
        importData:
          queueName:
            Fn::GetAtt:
            - MailEvents
            - QueueName
          queueUrl:
            Ref: MailEvents
          queueArn:
            Fn::GetAtt:
            - MailEvents
            - Arn
      - id: mailer
        type: email
        importData:
          configurationSet:
            Ref: MailerConfigSet
          domains:
            mail.example.com:
              dkimTokens:
              - name:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenName1
                value:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenValue1
              - name:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenName2
                value:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenValue2
              - name:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenName3
                value:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenValue3
            mail.example.org:
              dkimTokens:
              - name:
                  Fn::GetAtt:
                  - MailerIdentity1
                  - DkimDNSTokenName1
                value:
                  Fn::GetAtt:
                  - MailerIdentity1
                  - DkimDNSTokenValue1
              - name:
                  Fn::GetAtt:
                  - MailerIdentity1
                  - DkimDNSTokenName2
                value:
                  Fn::GetAtt:
                  - MailerIdentity1
                  - DkimDNSTokenValue2
              - name:
                  Fn::GetAtt:
                  - MailerIdentity1
                  - DkimDNSTokenName3
                value:
                  Fn::GetAtt:
                  - MailerIdentity1
                  - DkimDNSTokenValue3
          ruleSetName:
            Ref: MailerRuleSet
    Description: Deployment registration resources JSON.

---
source: crates/alien-cloudformation/tests/generator/aws_compute_tests.rs
expression: yaml
---
AWSTemplateFormatVersion: 2010-09-09
Description: aws_function_public
Transform:
- AWS::LanguageExtensions
Metadata:
  AWS::CloudFormation::Interface:
    ParameterGroups:
    - Label:
        default: Registration
      Parameters:
      - DeploymentGroupToken
      - ManagingRoleArn
      - ManagingAccountId
    - Label:
        default: Domains
      Parameters:
      - DomainName
      - HostedZoneId
      - CertificateArn
    - Label:
        default: Operations
      Parameters:
      - UpdatesMode
      - TelemetryMode
      - HeartbeatsMode
    ParameterLabels:
      CertificateArn:
        default: Certificate ARN
      DeploymentGroupToken:
        default: Deployment group token
      DomainName:
        default: Domain name
      HeartbeatsMode:
        default: Heartbeats
      HostedZoneId:
        default: Hosted zone ID
      ManagingAccountId:
        default: Manager AWS account ID
      ManagingRoleArn:
        default: Manager role ARN
      TelemetryMode:
        default: Telemetry
      UpdatesMode:
        default: Updates
Parameters:
  DeploymentGroupToken:
    Type: String
    Description: Deployment-group token used when registering the resolved stack import.
    NoEcho: true
  ManagingRoleArn:
    Type: String
    Description: AWS IAM role ARN for the manager identity allowed to assume generated management roles.
  ManagingAccountId:
    Type: String
    Description: AWS account ID hosting the manager. Referenced by stack-side IAM policies that scope cross-account ECR pulls. Empty disables those grants.
    Default: ''
  DomainName:
    Type: String
    Description: Optional domain name for public endpoints. Empty disables custom domains.
  HostedZoneId:
    Type: String
    Description: Optional Route 53 hosted zone ID for the domain.
  CertificateArn:
    Type: String
    Description: Optional ACM certificate ARN for the domain.
  UpdatesMode:
    Type: String
    Description: How updates are applied after import.
    Default: auto
    AllowedValues:
    - auto
    - approval-required
  TelemetryMode:
    Type: String
    Description: Telemetry collection behavior.
    Default: auto
    AllowedValues:
    - "off"
    - auto
    - approval-required
  HeartbeatsMode:
    Type: String
    Description: Heartbeat health-check behavior.
    Default: "on"
    AllowedValues:
    - "off"
    - "on"
Conditions:
  HasDomainName:
    Fn::Not:
    - Fn::Equals:
      - Ref: DomainName
      - ''
Resources:
  PublicApiRole:
    Type: AWS::IAM::Role
    Properties:
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Effect: Allow
          Principal:
            Service: lambda.amazonaws.com
          Action: sts:AssumeRole
      Policies:
      - PolicyName: alien-managed-policy
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Sid: WriteLogs
            Effect: Allow
            Action:
            - logs:CreateLogGroup
            - logs:CreateLogStream
            - logs:PutLogEvents
            Resource: '*'
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: acme-public
      - Key: AlienResourceId
        Value: public-api
      - Key: AlienResourceType
        Value: function
  PublicApiLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName:
        Fn::Sub: /aws/lambda/${AWS::StackName}-public-api
      RetentionInDays: 30
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  PublicApi:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName:
        Fn::Sub: ${AWS::StackName}-public-api
      PackageType: Image
      Code:
        ImageUri: 123456789012.dkr.ecr.us-east-1.amazonaws.com/app:1
      Role:
        Fn::GetAtt:
        - PublicApiRole
        - Arn
      MemorySize: 512
      Timeout: 60
      Environment:
        Variables:
          ALIEN_CURRENT_FUNCTION_BINDING_NAME: public-api
          ALIEN_DEPLOYMENT_TYPE: aws
          ALIEN_LAMBDA_MODE: buffered
          ALIEN_RUNTIME_SEND_OTLP: 'true'
          ALIEN_TRANSPORT: lambda
          AWS_ACCOUNT_ID:
            Ref: AWS::AccountId
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: acme-public
      - Key: AlienResourceId
        Value: public-api
      - Key: AlienResourceType
        Value: function
    DependsOn:
    - PublicApiLogGroup
    - PublicApiRole
  PublicApiApi:
    Type: AWS::ApiGatewayV2::Api
    Properties:
      Name:
        Fn::Sub: ${AWS::StackName}-PublicApi
      ProtocolType: HTTP
      DisableExecuteApiEndpoint: false
  PublicApiIntegration:
    Type: AWS::ApiGatewayV2::Integration
    Properties:
      ApiId:
        Ref: PublicApiApi
      IntegrationType: AWS_PROXY
      IntegrationMethod: POST
      IntegrationUri:
        Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${PublicApi.Arn}/invocations
      PayloadFormatVersion: '2.0'
  PublicApiRoute:
    Type: AWS::ApiGatewayV2::Route
    Properties:
      ApiId:
        Ref: PublicApiApi
      RouteKey: ANY /{proxy+}
      Target:
        Fn::Sub: integrations/${PublicApiIntegration}
  PublicApiStage:
    Type: AWS::ApiGatewayV2::Stage
    Properties:
      ApiId:
        Ref: PublicApiApi
      StageName: $default
      AutoDeploy: true
  PublicApiApiPermission:
    Type: AWS::Lambda::Permission
    Properties:
      Action: lambda:InvokeFunction
      FunctionName:
        Ref: PublicApi
      Principal: apigateway.amazonaws.com
      SourceArn:
        Fn::Sub: arn:${AWS::Partition}:execute-api:${AWS::Region}:${AWS::AccountId}:${PublicApiApi}/*/*
Outputs:
  AlienSourceKind:
    Value: cloudformation
    Description: Distribution source kind.
  AlienPlatform:
    Value: aws
    Description: Target platform.
  AlienRegion:
    Value:
      Ref: AWS::Region
    Description: AWS region.
  AlienManagementConfig:
    Value:
      Fn::ToJsonString:
        platform: aws
        managingRoleArn:
          Ref: ManagingRoleArn
    Description: Manager import ManagementConfig JSON.
  AlienStackSettings:
    Value:
      Fn::ToJsonString:
        deploymentModel: push
        updates:
          Ref: UpdatesMode
        telemetry:
          Ref: TelemetryMode
        heartbeats:
          Ref: HeartbeatsMode
        network:
          Ref: AWS::NoValue
        domains:
          Fn::If:
          - HasDomainName
          - customDomains:
              default:
                domain:
                  Ref: DomainName
                certificate:
                  aws:
                    certificateArn:
                      Ref: CertificateArn
          - Ref: AWS::NoValue
    Description: Manager import StackSettings JSON.
  AlienResources:
    Value:
      Fn::ToJsonString:
      - id: public-api
        type: function
        importData:
          functionName:
            Ref: PublicApi
          functionArn:
            Fn::GetAtt:
            - PublicApi
            - Arn
          eventSourceMappings: []
          eventbridgeRuleNames: []
          s3PermissionStatementIds: []
          eventbridgePermissionStatementIds: []
          url:
            Fn::Sub: https://${PublicApiApi}.execute-api.${AWS::Region}.${AWS::URLSuffix}
          apiId:
            Ref: PublicApiApi
          integrationId:
            Ref: PublicApiIntegration
          routeId:
            Ref: PublicApiRoute
          stageName: $default
    Description: Manager import resources JSON.

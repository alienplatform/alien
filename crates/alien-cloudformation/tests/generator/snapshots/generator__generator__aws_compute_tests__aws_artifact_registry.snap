---
source: crates/alien-cloudformation/tests/generator/aws_compute_tests.rs
expression: yaml
---
AWSTemplateFormatVersion: 2010-09-09
Description: aws_artifact_registry
Transform:
- AWS::LanguageExtensions
Metadata:
  AWS::CloudFormation::Interface:
    ParameterGroups:
    - Label:
        default: Registration
      Parameters:
      - DeploymentGroupToken
      - ManagingRoleArn
      - ManagingAccountId
    - Label:
        default: Domains
      Parameters:
      - DomainName
      - HostedZoneId
      - CertificateArn
    - Label:
        default: Operations
      Parameters:
      - UpdatesMode
      - TelemetryMode
      - HeartbeatsMode
    ParameterLabels:
      CertificateArn:
        default: Certificate ARN
      DeploymentGroupToken:
        default: Deployment group token
      DomainName:
        default: Domain name
      HeartbeatsMode:
        default: Heartbeats
      HostedZoneId:
        default: Hosted zone ID
      ManagingAccountId:
        default: Manager account ID
      ManagingRoleArn:
        default: Manager role ARN
      TelemetryMode:
        default: Telemetry
      UpdatesMode:
        default: Updates
Parameters:
  DeploymentGroupToken:
    Type: String
    Description: Deployment-group token used when registering the resolved stack import.
    NoEcho: true
  ManagingRoleArn:
    Type: String
    Description: Manager IAM role ARN allowed to assume generated management roles.
  ManagingAccountId:
    Type: String
    Description: Account ID hosting the manager. Referenced by stack-side IAM policies that scope cross-account image pulls. Empty disables those grants.
    Default: ''
  NetworkMode:
    Type: String
    Description: Choose whether this setup creates a new network, uses an existing network, or uses the default network.
    Default: create-new
    AllowedValues:
    - create-new
    - use-existing
    - use-default
  DomainName:
    Type: String
    Description: Optional domain name for public endpoints. Empty disables custom domains.
    Default: ''
  HostedZoneId:
    Type: String
    Description: Optional Route 53 hosted zone ID for the domain.
    Default: ''
  CertificateArn:
    Type: String
    Description: Optional ACM certificate ARN for the domain.
    Default: ''
  UpdatesMode:
    Type: String
    Description: How updates are applied after import.
    Default: auto
    AllowedValues:
    - auto
    - approval-required
  TelemetryMode:
    Type: String
    Description: Telemetry collection behavior.
    Default: auto
    AllowedValues:
    - "off"
    - auto
    - approval-required
  HeartbeatsMode:
    Type: String
    Description: Heartbeat health-check behavior.
    Default: "on"
    AllowedValues:
    - "off"
    - "on"
Conditions:
  HasDomainName:
    Fn::Not:
    - Fn::Equals:
      - Ref: DomainName
      - ''
Resources:
  RegistryRepository:
    Type: AWS::ECR::Repository
    Properties:
      RepositoryName:
        Fn::Sub: ${AWS::StackName}-registry
      ImageScanningConfiguration:
        ScanOnPush: true
      ImageTagMutability: IMMUTABLE
      EncryptionConfiguration:
        EncryptionType: AES256
      LifecyclePolicy:
        LifecyclePolicyText:
          Fn::ToJsonString:
            rules:
            - rulePriority: 1
              description: Retain the 100 most recent images
              selection:
                tagStatus: any
                countType: imageCountMoreThan
                countNumber: 100
              action:
                type: expire
      Tags:
      - Key: alien.dev/managed-by
        Value: alien
      - Key: alien.dev/stack
        Value:
          Ref: AWS::StackName
      - Key: alien.dev/resource
        Value: registry
      - Key: AlienResourceType
        Value: artifact-registry
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  RegistryPullRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: ${AWS::StackName}-registry-pull
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Effect: Allow
          Principal:
            AWS:
              Ref: ManagingRoleArn
          Action: sts:AssumeRole
      Policies:
      - PolicyName: ecr-pull
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Sid: GetAuthorizationToken
            Effect: Allow
            Action: ecr:GetAuthorizationToken
            Resource: '*'
          - Sid: RepositoryAccess
            Effect: Allow
            Action:
            - ecr:BatchCheckLayerAvailability
            - ecr:BatchGetImage
            - ecr:DescribeImages
            - ecr:DescribeRepositories
            - ecr:GetDownloadUrlForLayer
            - ecr:ListImages
            Resource:
            - Fn::GetAtt:
              - RegistryRepository
              - Arn
            - Fn::Sub: arn:${AWS::Partition}:ecr:${AWS::Region}:${AWS::AccountId}:repository/${AWS::StackName}-registry-*
      Tags:
      - Key: alien.dev/managed-by
        Value: alien
      - Key: alien.dev/stack
        Value:
          Ref: AWS::StackName
      - Key: alien.dev/resource
        Value: registry
      - Key: AlienResourceType
        Value: artifact-registry
    DependsOn:
    - RegistryRepository
  RegistryPushRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: ${AWS::StackName}-registry-push
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Effect: Allow
          Principal:
            AWS:
              Ref: ManagingRoleArn
          Action: sts:AssumeRole
      Policies:
      - PolicyName: ecr-push-pull
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Sid: GetAuthorizationToken
            Effect: Allow
            Action: ecr:GetAuthorizationToken
            Resource: '*'
          - Sid: RepositoryAccess
            Effect: Allow
            Action:
            - ecr:BatchCheckLayerAvailability
            - ecr:BatchGetImage
            - ecr:DescribeImages
            - ecr:DescribeRepositories
            - ecr:GetDownloadUrlForLayer
            - ecr:ListImages
            - ecr:CompleteLayerUpload
            - ecr:CreateRepository
            - ecr:DeleteRepository
            - ecr:InitiateLayerUpload
            - ecr:PutImage
            - ecr:UploadLayerPart
            Resource:
            - Fn::GetAtt:
              - RegistryRepository
              - Arn
            - Fn::Sub: arn:${AWS::Partition}:ecr:${AWS::Region}:${AWS::AccountId}:repository/${AWS::StackName}-registry-*
      Tags:
      - Key: alien.dev/managed-by
        Value: alien
      - Key: alien.dev/stack
        Value:
          Ref: AWS::StackName
      - Key: alien.dev/resource
        Value: registry
      - Key: AlienResourceType
        Value: artifact-registry
    DependsOn:
    - RegistryRepository
Outputs:
  DeploymentSourceKind:
    Value: cloudformation
    Description: Setup source kind.
  DeploymentStackPrefix:
    Value:
      Ref: AWS::StackName
    Description: Physical stack prefix.
  DeploymentPlatform:
    Value: aws
    Description: Target platform.
  DeploymentRegion:
    Value:
      Ref: AWS::Region
    Description: AWS region.
  DeploymentSetupTarget:
    Value: aws
    Description: Setup target.
  DeploymentSetupFingerprint:
    Value: test
    Description: Setup compatibility fingerprint.
  DeploymentSetupFingerprintVersion:
    Value: 1
    Description: Setup fingerprint algorithm version.
  DeploymentManagementConfig:
    Value:
      Fn::ToJsonString:
        platform: aws
        managingRoleArn:
          Ref: ManagingRoleArn
    Description: Manager import ManagementConfig JSON.
  DeploymentStackSettings:
    Value:
      Fn::ToJsonString:
        deploymentModel: push
        updates:
          Ref: UpdatesMode
        telemetry:
          Ref: TelemetryMode
        heartbeats:
          Ref: HeartbeatsMode
        network:
          Ref: AWS::NoValue
        domains:
          Fn::If:
          - HasDomainName
          - customDomains:
              default:
                domain:
                  Ref: DomainName
                certificate:
                  aws:
                    certificateArn:
                      Ref: CertificateArn
          - Ref: AWS::NoValue
    Description: Manager import StackSettings JSON.
  DeploymentResources:
    Value:
      Fn::ToJsonString:
      - id: registry
        type: artifact-registry
        importData:
          accountId:
            Ref: AWS::AccountId
          region:
            Ref: AWS::Region
          registryId:
            Fn::Sub: ${AWS::AccountId}:${AWS::Region}
          registryEndpoint:
            Fn::Sub: ${AWS::AccountId}.dkr.ecr.${AWS::Region}.${AWS::URLSuffix}
          repositoryPrefix:
            Fn::Sub: ${AWS::StackName}-registry
          pullRoleArn:
            Fn::GetAtt:
            - RegistryPullRole
            - Arn
          pushRoleArn:
            Fn::GetAtt:
            - RegistryPushRole
            - Arn
    Description: Manager import resources JSON.

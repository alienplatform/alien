---
source: crates/alien-cloudformation/tests/generator/aws_full_stack_tests.rs
expression: yaml
---
AWSTemplateFormatVersion: 2010-09-09
Description: aws full stack
Transform:
- AWS::LanguageExtensions
Metadata:
  AWS::CloudFormation::Interface:
    ParameterGroups:
    - Label:
        default: Registration
      Parameters:
      - Token
      - ManagingRoleArn
      - ManagingAccountId
    - Label:
        default: Network
      Parameters:
      - NetworkMode
      - VpcCidr
      - AvailabilityZones
      - VpcId
      - PublicSubnetIds
      - PrivateSubnetIds
      - SecurityGroupIds
    - Label:
        default: Custom domain
      Parameters:
      - DomainName
      - HostedZoneId
      - CertificateArn
    - Label:
        default: Operations
      Parameters:
      - UpdatesMode
      - TelemetryMode
      - HeartbeatsMode
    ParameterLabels:
      AvailabilityZones:
        default: Availability zones
      CertificateArn:
        default: Certificate ARN
      DomainName:
        default: Domain name
      HeartbeatsMode:
        default: Heartbeats
      HostedZoneId:
        default: Hosted zone ID
      ManagingAccountId:
        default: Image account ID
      ManagingRoleArn:
        default: Management role ARN
      NetworkMode:
        default: Network
      PrivateSubnetIds:
        default: Private subnet IDs
      PublicSubnetIds:
        default: Public subnet IDs
      SecurityGroupIds:
        default: Security group IDs
      TelemetryMode:
        default: Telemetry
      Token:
        default: Install token
      UpdatesMode:
        default: Updates
      VpcCidr:
        default: VPC CIDR
      VpcId:
        default: VPC ID
Parameters:
  Token:
    Type: String
    Description: Install token from the application setup page.
    NoEcho: true
  ManagingRoleArn:
    Type: String
    Description: ARN of the management identity allowed to assume setup-created roles.
    Default: ''
  ManagingAccountId:
    Type: String
    Description: AWS account ID for the management account that hosts application container images.
    Default: ''
  NetworkMode:
    Type: String
    Description: Choose create-new for a managed VPC, use-existing for your VPC, or use-default for the account default VPC.
    Default: create-new
    AllowedValues:
    - create-new
    - use-existing
    - use-default
  VpcCidr:
    Type: String
    Description: Only used with create-new. CIDR for the new VPC; leave unset for the generated default.
    Default: 10.44.0.0/16
  AvailabilityZones:
    Type: Number
    Description: Only used with create-new. Number of availability zones for the new VPC.
    Default: 2
    AllowedValues:
    - 1
    - 2
    - 3
  VpcId:
    Type: String
    Description: Only used with use-existing. Existing VPC ID.
    Default: ''
  PublicSubnetIds:
    Type: CommaDelimitedList
    Description: Only used with use-existing. Existing public subnet IDs.
    Default: ''
  PrivateSubnetIds:
    Type: CommaDelimitedList
    Description: Only used with use-existing. Existing private subnet IDs.
    Default: ''
  SecurityGroupIds:
    Type: CommaDelimitedList
    Description: Only used with use-existing. Existing security group IDs.
    Default: ''
  DomainName:
    Type: String
    Description: Optional custom domain for public endpoints. Leave unset to expose through the generated load balancer DNS name over HTTP.
    Default: ''
  HostedZoneId:
    Type: String
    Description: Route 53 hosted zone ID for the custom domain. Not needed for the auto-generated domain.
    Default: ''
  CertificateArn:
    Type: String
    Description: ACM certificate ARN for the custom domain. Required when DomainName is set.
    Default: ''
    AllowedPattern: ^$|^arn:aws(-[a-z]+)?:acm:[a-z0-9-]+:[0-9]{12}:certificate/.+$
  UpdatesMode:
    Type: String
    Description: How updates are applied after setup registration.
    Default: approval-required
    AllowedValues:
    - auto
    - approval-required
  TelemetryMode:
    Type: String
    Description: Telemetry collection behavior.
    Default: auto
    AllowedValues:
    - auto
  HeartbeatsMode:
    Type: String
    Description: Heartbeat health-check behavior.
    Default: "on"
    AllowedValues:
    - "off"
    - "on"
Conditions:
  NetworkModeCreate:
    Fn::Equals:
    - Ref: NetworkMode
    - create-new
  NetworkModeUseExisting:
    Fn::Equals:
    - Ref: NetworkMode
    - use-existing
  NetworkUseAz2:
    Fn::Not:
    - Fn::Equals:
      - Ref: AvailabilityZones
      - 1
  NetworkUseAz3:
    Fn::Equals:
    - Ref: AvailabilityZones
    - 3
  NetworkCreateUseAz2:
    Fn::And:
    - Fn::Equals:
      - Ref: NetworkMode
      - create-new
    - Condition: NetworkUseAz2
  NetworkCreateUseAz3:
    Fn::And:
    - Fn::Equals:
      - Ref: NetworkMode
      - create-new
    - Condition: NetworkUseAz3
  HasVpcCidr:
    Fn::Not:
    - Fn::Equals:
      - Ref: VpcCidr
      - ''
  HasDomainName:
    Fn::Not:
    - Fn::Equals:
      - Ref: DomainName
      - ''
Rules:
  CustomDomainCertificate:
    Assertions:
    - Assert:
        Fn::Or:
        - Fn::Equals:
          - Ref: DomainName
          - ''
        - Fn::Not:
          - Fn::Equals:
            - Ref: CertificateArn
            - ''
      AssertDescription: CertificateArn must be set to an AWS ACM certificate ARN when DomainName is set.
Resources:
  DefaultNetworkVpc:
    Type: AWS::EC2::VPC
    Properties:
      CidrBlock:
        Fn::If:
        - HasVpcCidr
        - Ref: VpcCidr
        - 10.42.0.0/16
      EnableDnsSupport: true
      EnableDnsHostnames: true
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkModeCreate
  DefaultNetworkInternetGateway:
    Type: AWS::EC2::InternetGateway
    Properties:
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkModeCreate
  DefaultNetworkVpcGatewayAttachment:
    Type: AWS::EC2::VPCGatewayAttachment
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      InternetGatewayId:
        Ref: DefaultNetworkInternetGateway
    Condition: NetworkModeCreate
  DefaultNetworkPublicSubnet1:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 0
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 0
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      MapPublicIpOnLaunch: true
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkModeCreate
  DefaultNetworkPrivateSubnet1:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 0
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 3
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkModeCreate
  DefaultNetworkPublicSubnet2:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 1
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 1
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      MapPublicIpOnLaunch: true
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkCreateUseAz2
  DefaultNetworkPrivateSubnet2:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 1
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 4
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkCreateUseAz2
  DefaultNetworkPublicSubnet3:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 2
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 2
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      MapPublicIpOnLaunch: true
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkCreateUseAz3
  DefaultNetworkPrivateSubnet3:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 2
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 5
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkCreateUseAz3
  DefaultNetworkPublicRouteTable:
    Type: AWS::EC2::RouteTable
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkModeCreate
  DefaultNetworkPublicDefaultRoute:
    Type: AWS::EC2::Route
    Properties:
      RouteTableId:
        Ref: DefaultNetworkPublicRouteTable
      DestinationCidrBlock: 0.0.0.0/0
      GatewayId:
        Ref: DefaultNetworkInternetGateway
    DependsOn:
    - DefaultNetworkVpcGatewayAttachment
    Condition: NetworkModeCreate
  DefaultNetworkPrivateRouteTable:
    Type: AWS::EC2::RouteTable
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkModeCreate
  DefaultNetworkNatEip:
    Type: AWS::EC2::EIP
    Properties:
      Domain: vpc
    Condition: NetworkModeCreate
  DefaultNetworkNatGateway:
    Type: AWS::EC2::NatGateway
    Properties:
      AllocationId:
        Fn::GetAtt:
        - DefaultNetworkNatEip
        - AllocationId
      SubnetId:
        Ref: DefaultNetworkPublicSubnet1
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkModeCreate
  DefaultNetworkPrivateDefaultRoute:
    Type: AWS::EC2::Route
    Properties:
      RouteTableId:
        Ref: DefaultNetworkPrivateRouteTable
      DestinationCidrBlock: 0.0.0.0/0
      NatGatewayId:
        Ref: DefaultNetworkNatGateway
    DependsOn:
    - DefaultNetworkNatGateway
    Condition: NetworkModeCreate
  DefaultNetworkPublicSubnet1RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPublicSubnet1
      RouteTableId:
        Ref: DefaultNetworkPublicRouteTable
    Condition: NetworkModeCreate
  DefaultNetworkPrivateSubnet1RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPrivateSubnet1
      RouteTableId:
        Ref: DefaultNetworkPrivateRouteTable
    Condition: NetworkModeCreate
  DefaultNetworkPublicSubnet2RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPublicSubnet2
      RouteTableId:
        Ref: DefaultNetworkPublicRouteTable
    Condition: NetworkCreateUseAz2
  DefaultNetworkPrivateSubnet2RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPrivateSubnet2
      RouteTableId:
        Ref: DefaultNetworkPrivateRouteTable
    Condition: NetworkCreateUseAz2
  DefaultNetworkPublicSubnet3RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPublicSubnet3
      RouteTableId:
        Ref: DefaultNetworkPublicRouteTable
    Condition: NetworkCreateUseAz3
  DefaultNetworkPrivateSubnet3RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPrivateSubnet3
      RouteTableId:
        Ref: DefaultNetworkPrivateRouteTable
    Condition: NetworkCreateUseAz3
  DefaultNetworkSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Private workload security group
      VpcId:
        Ref: DefaultNetworkVpc
      SecurityGroupEgress:
      - IpProtocol: '-1'
        CidrIp: 0.0.0.0/0
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: default-network
      - Key: resource-type
        Value: network
    Condition: NetworkModeCreate
  ExecutionSaRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: ${AWS::StackName}-execution-sa
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Effect: Allow
          Principal:
            Service:
            - codebuild.amazonaws.com
            - lambda.amazonaws.com
          Action: sts:AssumeRole
      Policies:
      - PolicyName: deployment-permissions
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Action:
            - s3:GetObject
            - s3:GetObjectAcl
            - s3:GetObjectVersion
            - s3:ListBucket
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:s3:::${AWS::StackName}-*
            - Fn::Sub: arn:${AWS::Partition}:s3:::${AWS::StackName}-*/*
            Sid: ReadS3Objects
          - Action:
            - sqs:ChangeMessageVisibility
            - sqs:DeleteMessage
            - sqs:GetQueueAttributes
            - sqs:GetQueueUrl
            - sqs:SendMessage
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:sqs:${AWS::Region}:${AWS::AccountId}:${AWS::StackName}-*
            Sid: SendSqsMessages
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: execution-sa
      - Key: resource-type
        Value: service-account
  ManagementRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: ${AWS::StackName}-management
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Sid: AllowManagingRole
          Effect: Allow
          Principal:
            AWS:
              Ref: ManagingRoleArn
          Action: sts:AssumeRole
          Condition:
            StringEquals:
              aws:PrincipalArn:
                Ref: ManagingRoleArn
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: management
      - Key: resource-type
        Value: management
  ManagementRoleManagementPolicy1:
    Type: AWS::IAM::ManagedPolicy
    Properties:
      Description: Application management permissions
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Action:
          - lambda:CreateFunction
          Condition:
            StringEquals:
              aws:RequestTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:RequestTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:lambda:${AWS::Region}:${AWS::AccountId}:function:${AWS::StackName}-*
          Sid: CreateLambdaFunctions
        - Action:
          - lambda:AddPermission
          - lambda:CreateAlias
          - lambda:CreateFunctionUrlConfig
          - lambda:DeleteAlias
          - lambda:DeleteFunction
          - lambda:DeleteFunctionConcurrency
          - lambda:DeleteFunctionEventInvokeConfig
          - lambda:DeleteFunctionUrlConfig
          - lambda:GetCodeSigningConfig
          - lambda:GetFunction
          - lambda:GetFunctionConfiguration
          - lambda:GetFunctionEventInvokeConfig
          - lambda:GetFunctionUrlConfig
          - lambda:GetPolicy
          - lambda:ListAliases
          - lambda:ListTags
          - lambda:ListVersionsByFunction
          - lambda:PublishVersion
          - lambda:PutFunctionConcurrency
          - lambda:PutFunctionEventInvokeConfig
          - lambda:RemovePermission
          - lambda:TagResource
          - lambda:UpdateAlias
          - lambda:UpdateCodeSigningConfig
          - lambda:UpdateFunctionCode
          - lambda:UpdateFunctionConfiguration
          Condition:
            StringEquals:
              aws:ResourceTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:ResourceTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:lambda:${AWS::Region}:${AWS::AccountId}:function:${AWS::StackName}-*
          Sid: ManageLambdaFunctions
        - Action:
          - lambda:CreateEventSourceMapping
          - lambda:DeleteEventSourceMapping
          - lambda:GetEventSourceMapping
          - lambda:UpdateEventSourceMapping
          Condition:
            StringLike:
              lambda:FunctionArn:
                Fn::Sub: arn:${AWS::Partition}:lambda:${AWS::Region}:${AWS::AccountId}:function:${AWS::StackName}-*
          Effect: Allow
          Resource:
          - '*'
          Sid: ProvisionEventSourceMappings
        - Action:
          - lambda:ListEventSourceMappings
          Effect: Allow
          Resource:
          - '*'
          Sid: ListEventSourceMappings
        - Action:
          - ec2:DescribeNetworkInterfaces
          - ec2:DescribeSecurityGroups
          - ec2:DescribeSubnets
          - ec2:DescribeVpcs
          Effect: Allow
          Resource:
          - '*'
          Sid: InspectVpcForLambdaNetworking
        - Action:
          - iam:PassRole
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:iam::${AWS::AccountId}:role/${AWS::StackName}-*-sa
          Sid: PassLambdaExecutionRoles
        - Action:
          - iam:GetRolePolicy
          - iam:ListRolePolicies
          - iam:PutRolePolicy
          Condition:
            StringEquals:
              aws:ResourceTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:ResourceTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:iam::${AWS::AccountId}:role/${AWS::StackName}-*
          Sid: AttachLambdaRuntimePolicies
        - Action:
          - ecr:GetAuthorizationToken
          Effect: Allow
          Resource:
          - '*'
          Sid: GetEcrLoginToken
        - Action:
          - ecr:BatchGetImage
          - ecr:GetDownloadUrlForLayer
          - ecr:GetRepositoryPolicy
          - ecr:SetRepositoryPolicy
          Effect: Allow
          Resource:
          - Fn::Sub:
            - arn:${AWS::Partition}:ecr:*:${ManagingAccountId}:repository/*
            - ManagingAccountId:
                Fn::Select:
                - 4
                - Fn::Split:
                  - ':'
                  - Ref: ManagingRoleArn
          Sid: ConfigureLambdaImagePullAccess
        - Action:
          - acm:AddTagsToCertificate
          - acm:ImportCertificate
          Condition:
            StringEquals:
              aws:RequestTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:RequestTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:acm:${AWS::Region}:${AWS::AccountId}:certificate/*
          Sid: ImportTlsCertificates
        - Action:
          - acm:AddTagsToCertificate
          - acm:DeleteCertificate
          - acm:DescribeCertificate
          - acm:ImportCertificate
          Condition:
            StringEquals:
              aws:ResourceTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:ResourceTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:acm:${AWS::Region}:${AWS::AccountId}:certificate/*
          Sid: ManageTlsCertificates
        - Action:
          - apigateway:POST
          - apigateway:PUT
          Condition:
            StringEquals:
              aws:RequestTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:RequestTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/apis
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/domainnames
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/tags/*
          Sid: CreateHttpApiEndpoints
        - Action:
          - apigateway:POST
          Condition:
            StringEquals:
              aws:ResourceTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:ResourceTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/apis/*
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/domainnames/*
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/domainnames/*/apimappings
          Sid: CreateHttpApiRoutes
        - Action:
          - apigateway:PUT
          - apigateway:TagResource
          Condition:
            StringEquals:
              aws:RequestTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:RequestTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/apis/*
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/apis/*/stages
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/apis/*/stages/*
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/domainnames/*
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/tags/*
          Sid: TagHttpApiEndpoints
      Roles:
      - Ref: ManagementRole
    DependsOn:
    - ManagementRole
  ManagementRoleManagementPolicy2:
    Type: AWS::IAM::ManagedPolicy
    Properties:
      Description: Application management permissions
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Action:
          - apigateway:DELETE
          - apigateway:GET
          - apigateway:PATCH
          - apigateway:PUT
          Condition:
            StringEquals:
              aws:ResourceTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:ResourceTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/apis/*
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/domainnames/*
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/domainnames/*/apimappings
          - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/domainnames/*/apimappings/*
          Sid: ManageHttpApiEndpoints
        - Action:
          - events:PutRule
          - events:TagResource
          Condition:
            StringEquals:
              aws:RequestTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:RequestTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:events:${AWS::Region}:${AWS::AccountId}:rule/${AWS::StackName}-*
          Sid: CreateEventbridgeSchedules
        - Action:
          - events:DeleteRule
          - events:DescribeRule
          - events:PutTargets
          - events:RemoveTargets
          Condition:
            StringEquals:
              aws:ResourceTag/deployment:
                Fn::Sub: ${AWS::StackName}
              aws:ResourceTag/managed-by: runtime
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:events:${AWS::Region}:${AWS::AccountId}:rule/${AWS::StackName}-*
          Sid: ManageEventbridgeSchedules
        - Action:
          - s3:GetBucketAcl
          - s3:GetBucketLocation
          - s3:GetBucketPolicy
          - s3:GetBucketPublicAccessBlock
          - s3:GetBucketVersioning
          - s3:GetEncryptionConfiguration
          - s3:GetLifecycleConfiguration
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:s3:::${AWS::StackName}-*
          Sid: CheckS3BucketHealth
        - Action:
          - sqs:GetQueueAttributes
          - sqs:ListQueueTags
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:sqs:${AWS::Region}:${AWS::AccountId}:${AWS::StackName}-*
          Sid: CheckSqsQueueHealth
        - Action:
          - dynamodb:DescribeContinuousBackups
          - dynamodb:DescribeTable
          - dynamodb:DescribeTimeToLive
          - dynamodb:ListTables
          - dynamodb:ListTagsOfResource
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:dynamodb:${AWS::Region}:${AWS::AccountId}:table/${AWS::StackName}-*
          Sid: CheckDynamodbTableHealth
        - Action:
          - ssm:DeleteParameter
          - ssm:PutParameter
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:ssm:${AWS::Region}:${AWS::AccountId}:parameter/${AWS::StackName}-*
          Sid: WriteSsmParameters
        - Sid: ReadOwnManagementRole
          Effect: Allow
          Action: iam:GetRole
          Resource:
            Fn::Sub: arn:${AWS::Partition}:iam::${AWS::AccountId}:role/${AWS::StackName}-management
      Roles:
      - Ref: ManagementRole
    DependsOn:
    - ManagementRole
  Assets:
    Type: AWS::S3::Bucket
    Properties:
      BucketName:
        Fn::Join:
        - '-'
        - - Ref: AWS::StackName
          - assets
          - Fn::Select:
            - 0
            - Fn::Split:
              - '-'
              - Fn::Select:
                - 2
                - Fn::Split:
                  - /
                  - Ref: AWS::StackId
      BucketEncryption:
        ServerSideEncryptionConfiguration:
        - ServerSideEncryptionByDefault:
            SSEAlgorithm: AES256
      OwnershipControls:
        Rules:
        - ObjectOwnership: BucketOwnerEnforced
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      VersioningConfiguration:
        Status: Enabled
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: assets
      - Key: resource-type
        Value: storage
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  AssetsBucketPolicy:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket:
        Ref: Assets
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Sid: DenyInsecureTransport
          Effect: Deny
          Principal: '*'
          Action: s3:*
          Resource:
          - Fn::GetAtt:
            - Assets
            - Arn
          - Fn::Sub: arn:${AWS::Partition}:s3:::${Assets}/*
          Condition:
            Bool:
              aws:SecureTransport: 'false'
  AssetsManagementRoleStoragePermission00:
    Type: AWS::IAM::Policy
    Properties:
      PolicyName:
        Fn::Sub: ${AWS::StackName}-assets-storage-0-0
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Action:
          - s3:GetBucketAcl
          - s3:GetBucketLocation
          - s3:GetBucketPolicy
          - s3:GetBucketPublicAccessBlock
          - s3:GetBucketVersioning
          - s3:GetEncryptionConfiguration
          - s3:GetLifecycleConfiguration
          Effect: Allow
          Resource:
          - Fn::GetAtt:
            - Assets
            - Arn
          Sid: CheckS3BucketHealth
      Roles:
      - Ref: ManagementRole
    DependsOn:
    - Assets
    - ManagementRole
  Jobs:
    Type: AWS::SQS::Queue
    Properties:
      SqsManagedSseEnabled: true
      VisibilityTimeout: 1080
      MessageRetentionPeriod: 345600
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: jobs
      - Key: resource-type
        Value: queue
  Metadata:
    Type: AWS::DynamoDB::Table
    Properties:
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: pk
        AttributeType: S
      - AttributeName: sk
        AttributeType: S
      KeySchema:
      - AttributeName: pk
        KeyType: HASH
      - AttributeName: sk
        KeyType: RANGE
      SSESpecification:
        SSEEnabled: true
      TimeToLiveSpecification:
        AttributeName: ttl
        Enabled: true
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: metadata
      - Key: resource-type
        Value: kv
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  SecretsManagementVaultPolicy:
    Type: AWS::IAM::Policy
    Properties:
      PolicyName:
        Fn::Sub: management-secrets-vault-policy
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Action:
          - ssm:DeleteParameter
          - ssm:PutParameter
          Effect: Allow
          Resource:
          - Fn::Sub: arn:${AWS::Partition}:ssm:${AWS::Region}:${AWS::AccountId}:parameter/${AWS::StackName}-secrets-*
          Sid: WriteSsmParameters
      Roles:
      - Ref: ManagementRole
  Mailbox:
    Type: AWS::S3::Bucket
    Properties:
      BucketName:
        Fn::Join:
        - '-'
        - - Ref: AWS::StackName
          - mailbox
          - Fn::Select:
            - 0
            - Fn::Split:
              - '-'
              - Fn::Select:
                - 2
                - Fn::Split:
                  - /
                  - Ref: AWS::StackId
      BucketEncryption:
        ServerSideEncryptionConfiguration:
        - ServerSideEncryptionByDefault:
            SSEAlgorithm: AES256
      OwnershipControls:
        Rules:
        - ObjectOwnership: BucketOwnerEnforced
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: mailbox
      - Key: resource-type
        Value: storage
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  MailboxBucketPolicy:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket:
        Ref: Mailbox
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Sid: DenyInsecureTransport
          Effect: Deny
          Principal: '*'
          Action: s3:*
          Resource:
          - Fn::GetAtt:
            - Mailbox
            - Arn
          - Fn::Sub: arn:${AWS::Partition}:s3:::${Mailbox}/*
          Condition:
            Bool:
              aws:SecureTransport: 'false'
        - Sid: AllowSesInboundDelivery
          Effect: Allow
          Principal:
            Service: ses.amazonaws.com
          Action: s3:PutObject
          Resource:
            Fn::Sub: arn:${AWS::Partition}:s3:::${Mailbox}/*
          Condition:
            StringEquals:
              aws:SourceAccount:
                Ref: AWS::AccountId
  MailboxManagementRoleStoragePermission00:
    Type: AWS::IAM::Policy
    Properties:
      PolicyName:
        Fn::Sub: ${AWS::StackName}-mailbox-storage-0-0
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Action:
          - s3:GetBucketAcl
          - s3:GetBucketLocation
          - s3:GetBucketPolicy
          - s3:GetBucketPublicAccessBlock
          - s3:GetBucketVersioning
          - s3:GetEncryptionConfiguration
          - s3:GetLifecycleConfiguration
          Effect: Allow
          Resource:
          - Fn::GetAtt:
            - Mailbox
            - Arn
          Sid: CheckS3BucketHealth
      Roles:
      - Ref: ManagementRole
    DependsOn:
    - Mailbox
    - ManagementRole
  MailEvents:
    Type: AWS::SQS::Queue
    Properties:
      SqsManagedSseEnabled: true
      VisibilityTimeout: 30
      MessageRetentionPeriod: 345600
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: mail-events
      - Key: resource-type
        Value: queue
  MailerConfigSet:
    Type: AWS::SES::ConfigurationSet
    Properties:
      Name:
        Fn::Sub: ${AWS::StackName}-mailer
  MailerIdentity0:
    Type: AWS::SES::EmailIdentity
    Properties:
      EmailIdentity: mail.example.com
      DkimAttributes:
        SigningEnabled: true
      ConfigurationSetAttributes:
        ConfigurationSetName:
          Ref: MailerConfigSet
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: mailer
      - Key: resource-type
        Value: email
  MailerEventsTopic:
    Type: AWS::SNS::Topic
    Properties:
      TopicName:
        Fn::Sub: ${AWS::StackName}-mailer-email-events
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: mailer
      - Key: resource-type
        Value: email
  MailerEventDestination:
    Type: AWS::SES::ConfigurationSetEventDestination
    Properties:
      ConfigurationSetName:
        Ref: MailerConfigSet
      EventDestination:
        Name:
          Fn::Sub: ${AWS::StackName}-mailer-events
        Enabled: true
        MatchingEventTypes:
        - SEND
        - DELIVERY
        - BOUNCE
        - COMPLAINT
        - DELIVERY_DELAY
        - REJECT
        SnsDestination:
          TopicARN:
            Ref: MailerEventsTopic
  MailerEventsSubscription:
    Type: AWS::SNS::Subscription
    Properties:
      TopicArn:
        Ref: MailerEventsTopic
      Protocol: sqs
      Endpoint:
        Fn::GetAtt:
        - MailEvents
        - Arn
      RawMessageDelivery: true
  MailerEventsQueuePolicy:
    Type: AWS::SQS::QueuePolicy
    Properties:
      Queues:
      - Ref: MailEvents
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Sid: AllowSesEventsTopic
          Effect: Allow
          Principal:
            Service: sns.amazonaws.com
          Action: sqs:SendMessage
          Resource:
            Fn::GetAtt:
            - MailEvents
            - Arn
          Condition:
            ArnEquals:
              aws:SourceArn:
                Ref: MailerEventsTopic
  MailerRuleSet:
    Type: AWS::SES::ReceiptRuleSet
    Properties:
      RuleSetName:
        Fn::Sub: ${AWS::StackName}-mailer
  MailerInboundRule:
    Type: AWS::SES::ReceiptRule
    Properties:
      RuleSetName:
        Ref: MailerRuleSet
      Rule:
        Name:
          Fn::Sub: ${AWS::StackName}-mailer-inbound
        Enabled: true
        ScanEnabled: true
        Actions:
        - S3Action:
            BucketName:
              Ref: Mailbox
    DependsOn:
    - MailboxBucketPolicy
  RegistryRepository:
    Type: AWS::ECR::Repository
    Properties:
      RepositoryName:
        Fn::Sub: ${AWS::StackName}-registry
      ImageScanningConfiguration:
        ScanOnPush: true
      ImageTagMutability: IMMUTABLE
      EncryptionConfiguration:
        EncryptionType: AES256
      LifecyclePolicy:
        LifecyclePolicyText:
          Fn::ToJsonString:
            rules:
            - rulePriority: 1
              description: Retain the 100 most recent images
              selection:
                tagStatus: any
                countType: imageCountMoreThan
                countNumber: 100
              action:
                type: expire
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: registry
      - Key: resource-type
        Value: artifact-registry
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  RegistryPullRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: ${AWS::StackName}-registry-pull
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Effect: Allow
          Principal:
            AWS:
              Fn::GetAtt:
              - ExecutionSaRole
              - Arn
          Action: sts:AssumeRole
      Policies:
      - PolicyName: ecr-pull
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Sid: GetAuthorizationToken
            Effect: Allow
            Action: ecr:GetAuthorizationToken
            Resource: '*'
          - Sid: RepositoryAccess
            Effect: Allow
            Action:
            - ecr:BatchCheckLayerAvailability
            - ecr:BatchGetImage
            - ecr:DescribeImages
            - ecr:DescribeRepositories
            - ecr:GetDownloadUrlForLayer
            - ecr:ListImages
            Resource:
            - Fn::GetAtt:
              - RegistryRepository
              - Arn
            - Fn::Sub: arn:${AWS::Partition}:ecr:${AWS::Region}:${AWS::AccountId}:repository/${AWS::StackName}-registry-*
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: registry
      - Key: resource-type
        Value: artifact-registry
    DependsOn:
    - RegistryRepository
  RegistryPushRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: ${AWS::StackName}-registry-push
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Effect: Allow
          Principal:
            AWS:
              Fn::GetAtt:
              - ExecutionSaRole
              - Arn
          Action: sts:AssumeRole
      Policies:
      - PolicyName: ecr-push-pull
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Sid: GetAuthorizationToken
            Effect: Allow
            Action: ecr:GetAuthorizationToken
            Resource: '*'
          - Sid: RepositoryAccess
            Effect: Allow
            Action:
            - ecr:BatchCheckLayerAvailability
            - ecr:BatchGetImage
            - ecr:DescribeImages
            - ecr:DescribeRepositories
            - ecr:GetDownloadUrlForLayer
            - ecr:ListImages
            - ecr:CompleteLayerUpload
            - ecr:CreateRepository
            - ecr:DeleteRepository
            - ecr:InitiateLayerUpload
            - ecr:PutImage
            - ecr:UploadLayerPart
            Resource:
            - Fn::GetAtt:
              - RegistryRepository
              - Arn
            - Fn::Sub: arn:${AWS::Partition}:ecr:${AWS::Region}:${AWS::AccountId}:repository/${AWS::StackName}-registry-*
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: registry
      - Key: resource-type
        Value: artifact-registry
    DependsOn:
    - RegistryRepository
  BuilderLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName:
        Fn::Sub: /aws/codebuild/${AWS::StackName}-builder
      RetentionInDays: 30
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  Builder:
    Type: AWS::CodeBuild::Project
    Properties:
      Name:
        Fn::Sub: ${AWS::StackName}-builder
      ServiceRole:
        Fn::GetAtt:
        - ExecutionSaRole
        - Arn
      Artifacts:
        Type: NO_ARTIFACTS
      Source:
        Type: NO_SOURCE
        BuildSpec: |
          version: 0.2
          phases:
            build:
              commands:
                - echo "Build project is ready for runtime-provided commands"
      Environment:
        Type: LINUX_CONTAINER
        Image: aws/codebuild/standard:7.0
        ComputeType: BUILD_GENERAL1_MEDIUM
        PrivilegedMode: true
        EnvironmentVariables:
        - Name: PROFILE
          Value: release
          Type: PLAINTEXT
      LogsConfig:
        CloudWatchLogs:
          Status: ENABLED
          GroupName:
            Ref: BuilderLogGroup
      Tags:
      - Key: managed-by
        Value: setup
      - Key: deployment
        Value:
          Ref: AWS::StackName
      - Key: resource
        Value: builder
      - Key: resource-type
        Value: build
    DependsOn:
    - BuilderLogGroup
  DeploymentRegistration:
    Type: AWS::CloudFormation::CustomResource
    Properties:
      ServiceToken: arn:aws:lambda:us-east-1:123456789012:function:setup-registration
      Token:
        Ref: Token
      DeploymentName:
        Ref: AWS::StackName
      ResourcePrefix:
        Ref: AWS::StackName
      SourceKind: cloudformation
      Platform: aws
      Region:
        Ref: AWS::Region
      SetupTarget: aws
      SetupImportFormatVersion: 1
      SetupFingerprint: test
      SetupFingerprintVersion: 1
      ManagementConfig:
        platform: aws
        managingRoleArn:
          Ref: ManagingRoleArn
      StackSettings:
        deploymentModel: push
        updates:
          Ref: UpdatesMode
        telemetry:
          Ref: TelemetryMode
        heartbeats:
          Ref: HeartbeatsMode
        network:
          Fn::If:
          - NetworkModeCreate
          - type: create
            cidr:
              Fn::If:
              - HasVpcCidr
              - Ref: VpcCidr
              - Ref: AWS::NoValue
            availability_zones:
              Ref: AvailabilityZones
          - Fn::If:
            - NetworkModeUseExisting
            - type: byo-vpc-aws
              vpc_id:
                Ref: VpcId
              public_subnet_ids:
                Ref: PublicSubnetIds
              private_subnet_ids:
                Ref: PrivateSubnetIds
              security_group_ids:
                Ref: SecurityGroupIds
            - type: use-default
        domains:
          Fn::If:
          - HasDomainName
          - customDomains:
              default:
                domain:
                  Ref: DomainName
                certificate:
                  aws:
                    certificateArn:
                      Ref: CertificateArn
          - Ref: AWS::NoValue
      Resources:
      - id: default-network
        type: network
        importData:
          Fn::If:
          - NetworkModeCreate
          - vpcId:
              Ref: DefaultNetworkVpc
            cidrBlock:
              Fn::GetAtt:
              - DefaultNetworkVpc
              - CidrBlock
            internetGatewayId:
              Ref: DefaultNetworkInternetGateway
            natGatewayId:
              Ref: DefaultNetworkNatGateway
            eipAllocationId:
              Fn::GetAtt:
              - DefaultNetworkNatEip
              - AllocationId
            publicSubnetIds:
            - Ref: DefaultNetworkPublicSubnet1
            - Fn::If:
              - NetworkCreateUseAz2
              - Ref: DefaultNetworkPublicSubnet2
              - Ref: AWS::NoValue
            - Fn::If:
              - NetworkCreateUseAz3
              - Ref: DefaultNetworkPublicSubnet3
              - Ref: AWS::NoValue
            privateSubnetIds:
            - Ref: DefaultNetworkPrivateSubnet1
            - Fn::If:
              - NetworkCreateUseAz2
              - Ref: DefaultNetworkPrivateSubnet2
              - Ref: AWS::NoValue
            - Fn::If:
              - NetworkCreateUseAz3
              - Ref: DefaultNetworkPrivateSubnet3
              - Ref: AWS::NoValue
            publicRouteTableId:
              Ref: DefaultNetworkPublicRouteTable
            privateRouteTableId:
              Ref: DefaultNetworkPrivateRouteTable
            securityGroupId:
              Fn::GetAtt:
              - DefaultNetworkSecurityGroup
              - GroupId
            availabilityZones:
            - Fn::Select:
              - 0
              - Fn::GetAZs:
                  Ref: AWS::Region
            - Fn::If:
              - NetworkUseAz2
              - Fn::Select:
                - 1
                - Fn::GetAZs:
                    Ref: AWS::Region
              - Ref: AWS::NoValue
            - Fn::If:
              - NetworkUseAz3
              - Fn::Select:
                - 2
                - Fn::GetAZs:
                    Ref: AWS::Region
              - Ref: AWS::NoValue
            isByoVpc: false
          - Fn::If:
            - NetworkModeUseExisting
            - vpcId:
                Ref: VpcId
              publicSubnetIds:
                Ref: PublicSubnetIds
              privateSubnetIds:
                Ref: PrivateSubnetIds
              securityGroupId:
                Fn::Select:
                - 0
                - Ref: SecurityGroupIds
              availabilityZones: []
              isByoVpc: true
            - publicSubnetIds: []
              privateSubnetIds: []
              availabilityZones: []
              isByoVpc: true
      - id: execution-sa
        type: service-account
        importData:
          roleName:
            Ref: ExecutionSaRole
          roleArn:
            Fn::GetAtt:
            - ExecutionSaRole
            - Arn
          stackPermissionsApplied: true
      - id: management
        type: remote-stack-management
        importData:
          roleName:
            Ref: ManagementRole
          roleArn:
            Fn::GetAtt:
            - ManagementRole
            - Arn
          managementPermissionsApplied: true
      - id: assets
        type: storage
        importData:
          bucketName:
            Ref: Assets
          bucketArn:
            Fn::GetAtt:
            - Assets
            - Arn
      - id: jobs
        type: queue
        importData:
          queueName:
            Fn::GetAtt:
            - Jobs
            - QueueName
          queueUrl:
            Ref: Jobs
          queueArn:
            Fn::GetAtt:
            - Jobs
            - Arn
      - id: metadata
        type: kv
        importData:
          tableName:
            Ref: Metadata
          tableArn:
            Fn::GetAtt:
            - Metadata
            - Arn
      - id: secrets
        type: vault
        importData:
          accountId:
            Ref: AWS::AccountId
          region:
            Ref: AWS::Region
          parameterPrefix:
            Fn::Sub: ${AWS::StackName}-secrets
      - id: mailbox
        type: storage
        importData:
          bucketName:
            Ref: Mailbox
          bucketArn:
            Fn::GetAtt:
            - Mailbox
            - Arn
      - id: mail-events
        type: queue
        importData:
          queueName:
            Fn::GetAtt:
            - MailEvents
            - QueueName
          queueUrl:
            Ref: MailEvents
          queueArn:
            Fn::GetAtt:
            - MailEvents
            - Arn
      - id: mailer
        type: email
        importData:
          configurationSet:
            Ref: MailerConfigSet
          domains:
            mail.example.com:
              dkimTokens:
              - name:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenName1
                value:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenValue1
              - name:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenName2
                value:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenValue2
              - name:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenName3
                value:
                  Fn::GetAtt:
                  - MailerIdentity0
                  - DkimDNSTokenValue3
          ruleSetName:
            Ref: MailerRuleSet
      - id: registry
        type: artifact-registry
        importData:
          accountId:
            Ref: AWS::AccountId
          region:
            Ref: AWS::Region
          registryId:
            Fn::Sub: ${AWS::AccountId}:${AWS::Region}
          registryEndpoint:
            Fn::Sub: ${AWS::AccountId}.dkr.ecr.${AWS::Region}.${AWS::URLSuffix}
          repositoryPrefix:
            Fn::Sub: ${AWS::StackName}-registry
          pullRoleArn:
            Fn::GetAtt:
            - RegistryPullRole
            - Arn
          pushRoleArn:
            Fn::GetAtt:
            - RegistryPushRole
            - Arn
      - id: builder
        type: build
        importData:
          projectName:
            Ref: Builder
          projectArn:
            Fn::GetAtt:
            - Builder
            - Arn
          buildEnvVars:
            PROFILE: release
    DependsOn:
    - ExecutionSaRole
    - ManagementRole
    - ManagementRoleManagementPolicy1
    - ManagementRoleManagementPolicy2
    - Assets
    - AssetsBucketPolicy
    - AssetsManagementRoleStoragePermission00
    - Jobs
    - Metadata
    - SecretsManagementVaultPolicy
    - Mailbox
    - MailboxBucketPolicy
    - MailboxManagementRoleStoragePermission00
    - MailEvents
    - MailerConfigSet
    - MailerIdentity0
    - MailerEventsTopic
    - MailerEventDestination
    - MailerEventsSubscription
    - MailerEventsQueuePolicy
    - MailerRuleSet
    - MailerInboundRule
    - RegistryRepository
    - RegistryPullRole
    - RegistryPushRole
    - BuilderLogGroup
    - Builder
Outputs:
  DeploymentSourceKind:
    Value: cloudformation
    Description: Setup source kind.
  DeploymentId:
    Value:
      Fn::GetAtt:
      - DeploymentRegistration
      - DeploymentId
    Description: Registered deployment ID.
  DeploymentResourcePrefix:
    Value:
      Ref: AWS::StackName
    Description: Stable physical resource prefix.
  DeploymentPlatform:
    Value: aws
    Description: Target platform.
  DeploymentRegion:
    Value:
      Ref: AWS::Region
    Description: AWS region.
  DeploymentSetupTarget:
    Value: aws
    Description: Setup target.
  DeploymentSetupFingerprint:
    Value: test
    Description: Setup compatibility fingerprint.
  DeploymentSetupImportFormatVersion:
    Value: 1
    Description: Setup registration payload format version.
  DeploymentSetupFingerprintVersion:
    Value: 1
    Description: Setup fingerprint algorithm version.
  DeploymentManagementConfig:
    Value:
      Fn::ToJsonString:
        platform: aws
        managingRoleArn:
          Ref: ManagingRoleArn

              - Ref: AWS::NoValue
            publicRouteTableId:
              Ref: DefaultNetworkPublicRouteTable
            privateRouteTableId:
              Ref: DefaultNetworkPrivateRouteTable
            securityGroupId:
              Fn::GetAtt:
              - DefaultNetworkSecurityGroup
              - GroupId
            availabilityZones:
            - Fn::Select:

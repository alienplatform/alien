---
source: crates/alien-cloudformation/tests/generator/aws_full_stack_tests.rs
expression: yaml
---
AWSTemplateFormatVersion: 2010-09-09
Description: aws full stack
Transform:
- AWS::LanguageExtensions
Metadata:
  AWS::CloudFormation::Interface:
    ParameterGroups:
    - Label:
        default: Registration
      Parameters:
      - DeploymentGroupToken
      - ManagingRoleArn
      - ManagingAccountId
    - Label:
        default: Network
      Parameters:
      - VpcCidr
      - AvailabilityZones
    - Label:
        default: Domains
      Parameters:
      - DomainName
      - HostedZoneId
      - CertificateArn
    - Label:
        default: Operations
      Parameters:
      - UpdatesMode
      - TelemetryMode
      - HeartbeatsMode
    ParameterLabels:
      AvailabilityZones:
        default: Availability zones
      CertificateArn:
        default: Certificate ARN
      DeploymentGroupToken:
        default: Deployment group token
      DomainName:
        default: Domain name
      HeartbeatsMode:
        default: Heartbeats
      HostedZoneId:
        default: Hosted zone ID
      ManagingAccountId:
        default: Manager AWS account ID
      ManagingRoleArn:
        default: Manager role ARN
      TelemetryMode:
        default: Telemetry
      UpdatesMode:
        default: Updates
      VpcCidr:
        default: VPC CIDR
Parameters:
  DeploymentGroupToken:
    Type: String
    Description: Deployment-group token used when registering the resolved stack import.
    NoEcho: true
  ManagingRoleArn:
    Type: String
    Description: AWS IAM role ARN for the manager identity allowed to assume generated management roles.
  ManagingAccountId:
    Type: String
    Description: AWS account ID hosting the manager. Referenced by stack-side IAM policies that scope cross-account ECR pulls. Empty disables those grants.
    Default: ''
  VpcCidr:
    Type: String
    Description: CIDR for created VPCs. Empty uses the generated default.
    Default: 10.44.0.0/16
  AvailabilityZones:
    Type: Number
    Description: Number of availability zones to use when creating a VPC.
    Default: 2
    AllowedValues:
    - 1
    - 2
    - 3
  DomainName:
    Type: String
    Description: Optional domain name for public endpoints. Empty disables custom domains.
  HostedZoneId:
    Type: String
    Description: Optional Route 53 hosted zone ID for the domain.
  CertificateArn:
    Type: String
    Description: Optional ACM certificate ARN for the domain.
  UpdatesMode:
    Type: String
    Description: How updates are applied after import.
    Default: approval-required
    AllowedValues:
    - auto
    - approval-required
  TelemetryMode:
    Type: String
    Description: Telemetry collection behavior.
    Default: auto
    AllowedValues:
    - "off"
    - auto
    - approval-required
  HeartbeatsMode:
    Type: String
    Description: Heartbeat health-check behavior.
    Default: "on"
    AllowedValues:
    - "off"
    - "on"
Conditions:
  NetworkCreateUseAz2:
    Fn::Not:
    - Fn::Equals:
      - Ref: AvailabilityZones
      - 1
  NetworkCreateUseAz3:
    Fn::Equals:
    - Ref: AvailabilityZones
    - 3
  HasVpcCidr:
    Fn::Not:
    - Fn::Equals:
      - Ref: VpcCidr
      - ''
  HasDomainName:
    Fn::Not:
    - Fn::Equals:
      - Ref: DomainName
      - ''
Resources:
  DefaultNetworkVpc:
    Type: AWS::EC2::VPC
    Properties:
      CidrBlock:
        Fn::If:
        - HasVpcCidr
        - Ref: VpcCidr
        - 10.42.0.0/16
      EnableDnsSupport: true
      EnableDnsHostnames: true
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
  DefaultNetworkInternetGateway:
    Type: AWS::EC2::InternetGateway
    Properties:
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
  DefaultNetworkVpcGatewayAttachment:
    Type: AWS::EC2::VPCGatewayAttachment
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      InternetGatewayId:
        Ref: DefaultNetworkInternetGateway
  DefaultNetworkPublicSubnet1:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 0
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 0
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      MapPublicIpOnLaunch: true
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
  DefaultNetworkPrivateSubnet1:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 0
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 3
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
  DefaultNetworkPublicSubnet2:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 1
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 1
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      MapPublicIpOnLaunch: true
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
    Condition: NetworkCreateUseAz2
  DefaultNetworkPrivateSubnet2:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 1
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 4
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
    Condition: NetworkCreateUseAz2
  DefaultNetworkPublicSubnet3:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 2
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 2
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      MapPublicIpOnLaunch: true
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
    Condition: NetworkCreateUseAz3
  DefaultNetworkPrivateSubnet3:
    Type: AWS::EC2::Subnet
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      AvailabilityZone:
        Fn::Select:
        - 2
        - Fn::GetAZs:
            Ref: AWS::Region
      CidrBlock:
        Fn::Select:
        - 5
        - Fn::Cidr:
          - Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          - 6
          - 8
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
    Condition: NetworkCreateUseAz3
  DefaultNetworkPublicRouteTable:
    Type: AWS::EC2::RouteTable
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
  DefaultNetworkPublicDefaultRoute:
    Type: AWS::EC2::Route
    Properties:
      RouteTableId:
        Ref: DefaultNetworkPublicRouteTable
      DestinationCidrBlock: 0.0.0.0/0
      GatewayId:
        Ref: DefaultNetworkInternetGateway
    DependsOn:
    - DefaultNetworkVpcGatewayAttachment
  DefaultNetworkPrivateRouteTable:
    Type: AWS::EC2::RouteTable
    Properties:
      VpcId:
        Ref: DefaultNetworkVpc
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
  DefaultNetworkNatEip:
    Type: AWS::EC2::EIP
    Properties:
      Domain: vpc
  DefaultNetworkNatGateway:
    Type: AWS::EC2::NatGateway
    Properties:
      AllocationId:
        Fn::GetAtt:
        - DefaultNetworkNatEip
        - AllocationId
      SubnetId:
        Ref: DefaultNetworkPublicSubnet1
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
  DefaultNetworkPrivateDefaultRoute:
    Type: AWS::EC2::Route
    Properties:
      RouteTableId:
        Ref: DefaultNetworkPrivateRouteTable
      DestinationCidrBlock: 0.0.0.0/0
      NatGatewayId:
        Ref: DefaultNetworkNatGateway
    DependsOn:
    - DefaultNetworkNatGateway
  DefaultNetworkPublicSubnet1RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPublicSubnet1
      RouteTableId:
        Ref: DefaultNetworkPublicRouteTable
  DefaultNetworkPrivateSubnet1RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPrivateSubnet1
      RouteTableId:
        Ref: DefaultNetworkPrivateRouteTable
  DefaultNetworkPublicSubnet2RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPublicSubnet2
      RouteTableId:
        Ref: DefaultNetworkPublicRouteTable
    Condition: NetworkCreateUseAz2
  DefaultNetworkPrivateSubnet2RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPrivateSubnet2
      RouteTableId:
        Ref: DefaultNetworkPrivateRouteTable
    Condition: NetworkCreateUseAz2
  DefaultNetworkPublicSubnet3RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPublicSubnet3
      RouteTableId:
        Ref: DefaultNetworkPublicRouteTable
    Condition: NetworkCreateUseAz3
  DefaultNetworkPrivateSubnet3RouteTableAssociation:
    Type: AWS::EC2::SubnetRouteTableAssociation
    Properties:
      SubnetId:
        Ref: DefaultNetworkPrivateSubnet3
      RouteTableId:
        Ref: DefaultNetworkPrivateRouteTable
    Condition: NetworkCreateUseAz3
  DefaultNetworkSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Private workload security group
      VpcId:
        Ref: DefaultNetworkVpc
      SecurityGroupEgress:
      - IpProtocol: '-1'
        CidrIp: 0.0.0.0/0
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: default-network
      - Key: AlienResourceType
        Value: network
  ExecutionSaRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: ${AWS::StackName}-execution-sa
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Effect: Allow
          Principal:
            Service:
            - codebuild.amazonaws.com
            - lambda.amazonaws.com
          Action: sts:AssumeRole
      Policies:
      - PolicyName: alien-managed-policy
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Action:
            - s3:GetObject
            - s3:GetObjectAcl
            - s3:GetObjectVersion
            - s3:ListBucket
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:s3:::${AWS::StackName}-*
            - Fn::Sub: arn:${AWS::Partition}:s3:::${AWS::StackName}-*/*
            Sid: StorageDataRead
          - Action:
            - sqs:ChangeMessageVisibility
            - sqs:DeleteMessage
            - sqs:GetQueueAttributes
            - sqs:GetQueueUrl
            - sqs:SendMessage
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:sqs:${AWS::Region}:${AWS::AccountId}:${AWS::StackName}-*
            Sid: QueueDataWrite
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: execution-sa
      - Key: AlienResourceType
        Value: service-account
  ManagementRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: ${AWS::StackName}-management
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Sid: AllowManagingRole
          Effect: Allow
          Principal:
            AWS:
              Ref: ManagingRoleArn
          Action: sts:AssumeRole
          Condition:
            StringEquals:
              aws:PrincipalArn:
                Ref: ManagingRoleArn
      Policies:
      - PolicyName: alien-management-policy
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Action:
            - lambda:CreateAlias
            - lambda:DeleteAlias
            - lambda:DeleteFunctionConcurrency
            - lambda:DeleteFunctionEventInvokeConfig
            - lambda:GetCodeSigningConfig
            - lambda:GetEventSourceMapping
            - lambda:GetFunction
            - lambda:GetFunctionConfiguration
            - lambda:GetFunctionEventInvokeConfig
            - lambda:GetFunctionUrlConfig
            - lambda:GetPolicy
            - lambda:ListAliases
            - lambda:ListEventSourceMappings
            - lambda:ListTags
            - lambda:ListVersionsByFunction
            - lambda:PublishVersion
            - lambda:PutFunctionConcurrency
            - lambda:PutFunctionEventInvokeConfig
            - lambda:UpdateAlias
            - lambda:UpdateEventSourceMapping
            - lambda:UpdateFunctionCode
            - lambda:UpdateFunctionConfiguration
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:lambda:${AWS::Region}:${AWS::AccountId}:function:${AWS::StackName}-*
            Sid: FunctionManagement1
          - Action:
            - iam:PassRole
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:iam::${AWS::AccountId}:role/${AWS::StackName}-*-sa
            Sid: FunctionManagement2
          - Action:
            - ecr:GetAuthorizationToken
            Effect: Allow
            Resource:
            - '*'
            Sid: FunctionManagement3
          - Action:
            - ecr:BatchGetImage
            - ecr:GetDownloadUrlForLayer
            Effect: Allow
            Resource:
            - Fn::Sub:
              - arn:${AWS::Partition}:ecr:*:${ManagingAccountId}:repository/*
              - ManagingAccountId:
                  Fn::Select:
                  - 4
                  - Fn::Split:
                    - ':'
                    - Ref: ManagingRoleArn
            Sid: FunctionManagement4
          - Action:
            - acm:DeleteCertificate
            - acm:DescribeCertificate
            - acm:ImportCertificate
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:acm:${AWS::Region}:${AWS::AccountId}:certificate/*
            Sid: FunctionManagement5
          - Action:
            - apigateway:POST
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/apis
            - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/apis/*
            - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/domainnames
            Sid: FunctionManagement6
          - Action:
            - apigateway:DELETE
            - apigateway:GET
            - apigateway:PATCH
            - apigateway:PUT
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/apis/*
            - Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}::/domainnames/*
            Sid: FunctionManagement7
          - Action:
            - s3:GetBucketAcl
            - s3:GetBucketLocation
            - s3:GetBucketPolicy
            - s3:GetBucketPublicAccessBlock
            - s3:GetBucketVersioning
            - s3:GetEncryptionConfiguration
            - s3:GetLifecycleConfiguration
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:s3:::${AWS::StackName}-*
            Sid: StorageHeartbeat
          - Action:
            - sqs:GetQueueAttributes
            - sqs:ListQueueTags
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:sqs:${AWS::Region}:${AWS::AccountId}:${AWS::StackName}-*
            Sid: QueueHeartbeat
          - Action:
            - dynamodb:DescribeContinuousBackups
            - dynamodb:DescribeTable
            - dynamodb:DescribeTimeToLive
            - dynamodb:ListTables
            - dynamodb:ListTagsOfResource
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:dynamodb:${AWS::Region}:${AWS::AccountId}:table/${AWS::StackName}-*
            Sid: KvHeartbeat
          - Action:
            - ssm:DeleteParameter
            - ssm:PutParameter
            Effect: Allow
            Resource:
            - Fn::Sub: arn:${AWS::Partition}:ssm:${AWS::Region}:${AWS::AccountId}:parameter/${AWS::StackName}-*
            Sid: VaultDataWrite
          - Sid: ReadOwnManagementRole
            Effect: Allow
            Action: iam:GetRole
            Resource:
              Fn::Sub: arn:${AWS::Partition}:iam::${AWS::AccountId}:role/${AWS::StackName}-management
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: management
      - Key: AlienResourceType
        Value: remote-stack-management
  Assets:
    Type: AWS::S3::Bucket
    Properties:
      BucketName:
        Fn::Sub: ${AWS::StackName}-assets
      BucketEncryption:
        ServerSideEncryptionConfiguration:
        - ServerSideEncryptionByDefault:
            SSEAlgorithm: AES256
      OwnershipControls:
        Rules:
        - ObjectOwnership: BucketOwnerEnforced
      PublicAccessBlockConfiguration:
        BlockPublicAcls: true
        BlockPublicPolicy: true
        IgnorePublicAcls: true
        RestrictPublicBuckets: true
      NotificationConfiguration:
        LambdaConfigurations:
        - Event: s3:ObjectCreated:*
          Function:
            Fn::GetAtt:
            - PublicApi
            - Arn
      VersioningConfiguration:
        Status: Enabled
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: assets
      - Key: AlienResourceType
        Value: storage
    DependsOn:
    - PublicApiStoragePermissionassets
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  AssetsBucketPolicy:
    Type: AWS::S3::BucketPolicy
    Properties:
      Bucket:
        Ref: Assets
      PolicyDocument:
        Version: 2012-10-17
        Statement:
        - Sid: DenyInsecureTransport
          Effect: Deny
          Principal: '*'
          Action: s3:*
          Resource:
          - Fn::GetAtt:
            - Assets
            - Arn
          - Fn::Sub: arn:${AWS::Partition}:s3:::${Assets}/*
          Condition:
            Bool:
              aws:SecureTransport: 'false'
  Jobs:
    Type: AWS::SQS::Queue
    Properties:
      SqsManagedSseEnabled: true
      VisibilityTimeout: 1080
      MessageRetentionPeriod: 345600
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: jobs
      - Key: AlienResourceType
        Value: queue
  Metadata:
    Type: AWS::DynamoDB::Table
    Properties:
      BillingMode: PAY_PER_REQUEST
      AttributeDefinitions:
      - AttributeName: pk
        AttributeType: S
      - AttributeName: sk
        AttributeType: S
      KeySchema:
      - AttributeName: pk
        KeyType: HASH
      - AttributeName: sk
        KeyType: RANGE
      SSESpecification:
        SSEEnabled: true
      TimeToLiveSpecification:
        AttributeName: ttl
        Enabled: true
      PointInTimeRecoverySpecification:
        PointInTimeRecoveryEnabled: true
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: metadata
      - Key: AlienResourceType
        Value: kv
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  RegistryRepository:
    Type: AWS::ECR::Repository
    Properties:
      RepositoryName:
        Fn::Sub: ${AWS::StackName}-registry
      ImageScanningConfiguration:
        ScanOnPush: true
      ImageTagMutability: IMMUTABLE
      EncryptionConfiguration:
        EncryptionType: AES256
      LifecyclePolicy:
        LifecyclePolicyText:
          Fn::ToJsonString:
            rules:
            - rulePriority: 1
              description: Retain the 100 most recent images
              selection:
                tagStatus: any
                countType: imageCountMoreThan
                countNumber: 100
              action:
                type: expire
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: registry
      - Key: AlienResourceType
        Value: artifact-registry
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  RegistryPullRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: ${AWS::StackName}-registry-pull
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Effect: Allow
          Principal:
            AWS:
              Fn::GetAtt:
              - ExecutionSaRole
              - Arn
          Action: sts:AssumeRole
      Policies:
      - PolicyName: ecr-pull
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Sid: GetAuthorizationToken
            Effect: Allow
            Action: ecr:GetAuthorizationToken
            Resource: '*'
          - Sid: RepositoryAccess
            Effect: Allow
            Action:
            - ecr:BatchCheckLayerAvailability
            - ecr:BatchGetImage
            - ecr:DescribeImages
            - ecr:DescribeRepositories
            - ecr:GetDownloadUrlForLayer
            - ecr:ListImages
            Resource:
              Fn::GetAtt:
              - RegistryRepository
              - Arn
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: registry
      - Key: AlienResourceType
        Value: artifact-registry
    DependsOn:
    - RegistryRepository
  RegistryPushRole:
    Type: AWS::IAM::Role
    Properties:
      RoleName:
        Fn::Sub: ${AWS::StackName}-registry-push
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Effect: Allow
          Principal:
            AWS:
              Fn::GetAtt:
              - ExecutionSaRole
              - Arn
          Action: sts:AssumeRole
      Policies:
      - PolicyName: ecr-push-pull
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Sid: GetAuthorizationToken
            Effect: Allow
            Action: ecr:GetAuthorizationToken
            Resource: '*'
          - Sid: RepositoryAccess
            Effect: Allow
            Action:
            - ecr:BatchCheckLayerAvailability
            - ecr:BatchGetImage
            - ecr:DescribeImages
            - ecr:DescribeRepositories
            - ecr:GetDownloadUrlForLayer
            - ecr:ListImages
            - ecr:CompleteLayerUpload
            - ecr:InitiateLayerUpload
            - ecr:PutImage
            - ecr:UploadLayerPart
            Resource:
              Fn::GetAtt:
              - RegistryRepository
              - Arn
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: registry
      - Key: AlienResourceType
        Value: artifact-registry
    DependsOn:
    - RegistryRepository
  BuilderLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName:
        Fn::Sub: /aws/codebuild/${AWS::StackName}-builder
      RetentionInDays: 30
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  Builder:
    Type: AWS::CodeBuild::Project
    Properties:
      Name:
        Fn::Sub: ${AWS::StackName}-builder
      ServiceRole:
        Fn::GetAtt:
        - ExecutionSaRole
        - Arn
      Artifacts:
        Type: NO_ARTIFACTS
      Source:
        Type: NO_SOURCE
        BuildSpec: |
          version: 0.2
          phases:
            build:
              commands:
                - echo "Build project is ready for runtime-provided commands"
      Environment:
        Type: LINUX_CONTAINER
        Image: aws/codebuild/standard:7.0
        ComputeType: BUILD_GENERAL1_MEDIUM
        PrivilegedMode: true
        EnvironmentVariables:
        - Name: PROFILE
          Value: release
          Type: PLAINTEXT
      LogsConfig:
        CloudWatchLogs:
          Status: ENABLED
          GroupName:
            Ref: BuilderLogGroup
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: builder
      - Key: AlienResourceType
        Value: build
    DependsOn:
    - BuilderLogGroup
  PublicApiLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName:
        Fn::Sub: /aws/lambda/${AWS::StackName}-public-api
      RetentionInDays: 30
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  PublicApi:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName:
        Fn::Sub: ${AWS::StackName}-public-api
      PackageType: Image
      Code:
        ImageUri: 123456789012.dkr.ecr.us-east-1.amazonaws.com/app/api:1.2.3
      Role:
        Fn::GetAtt:
        - ExecutionSaRole
        - Arn
      MemorySize: 512
      Timeout: 60
      Environment:
        Variables:
          ALIEN_ASSETS_BINDING:
            Fn::ToJsonString:
              service: s3
              bucketName:
                Fn::Sub: ${AWS::StackName}-assets
          ALIEN_CURRENT_FUNCTION_BINDING_NAME: public-api
          ALIEN_DEPLOYMENT_TYPE: aws
          ALIEN_LAMBDA_MODE: buffered
          ALIEN_METADATA_BINDING:
            Fn::ToJsonString:
              service: dynamodb
              tableName:
                Ref: Metadata
              region:
                Ref: AWS::Region
          ALIEN_RUNTIME_SEND_OTLP: 'true'
          ALIEN_SECRETS_BINDING:
            Fn::ToJsonString:
              service: parameter-store
              vaultPrefix:
                Fn::Sub: ${AWS::StackName}-secrets
          ALIEN_TRANSPORT: lambda
          AWS_ACCOUNT_ID:
            Ref: AWS::AccountId
          RUST_LOG: info
      VpcConfig:
        SubnetIds:
        - Ref: DefaultNetworkPrivateSubnet1
        - Fn::If:
          - NetworkCreateUseAz2
          - Ref: DefaultNetworkPrivateSubnet2
          - Ref: AWS::NoValue
        - Fn::If:
          - NetworkCreateUseAz3
          - Ref: DefaultNetworkPrivateSubnet3
          - Ref: AWS::NoValue
        SecurityGroupIds:
        - Ref: DefaultNetworkSecurityGroup
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: public-api
      - Key: AlienResourceType
        Value: function
    DependsOn:
    - PublicApiLogGroup
  PublicApiStoragePermissionassets:
    Type: AWS::Lambda::Permission
    Properties:
      Action: lambda:InvokeFunction
      FunctionName:
        Ref: PublicApi
      Principal: s3.amazonaws.com
      SourceAccount:
        Ref: AWS::AccountId
  PublicApiApi:
    Type: AWS::ApiGatewayV2::Api
    Properties:
      Name:
        Fn::Sub: ${AWS::StackName}-PublicApi
      ProtocolType: HTTP
      DisableExecuteApiEndpoint: false
  PublicApiIntegration:
    Type: AWS::ApiGatewayV2::Integration
    Properties:
      ApiId:
        Ref: PublicApiApi
      IntegrationType: AWS_PROXY
      IntegrationMethod: POST
      IntegrationUri:
        Fn::Sub: arn:${AWS::Partition}:apigateway:${AWS::Region}:lambda:path/2015-03-31/functions/${PublicApi.Arn}/invocations
      PayloadFormatVersion: '2.0'
  PublicApiRoute:
    Type: AWS::ApiGatewayV2::Route
    Properties:
      ApiId:
        Ref: PublicApiApi
      RouteKey: ANY /{proxy+}
      Target:
        Fn::Sub: integrations/${PublicApiIntegration}
  PublicApiStage:
    Type: AWS::ApiGatewayV2::Stage
    Properties:
      ApiId:
        Ref: PublicApiApi
      StageName: $default
      AutoDeploy: true
  PublicApiApiPermission:
    Type: AWS::Lambda::Permission
    Properties:
      Action: lambda:InvokeFunction
      FunctionName:
        Ref: PublicApi
      Principal: apigateway.amazonaws.com
      SourceArn:
        Fn::Sub: arn:${AWS::Partition}:execute-api:${AWS::Region}:${AWS::AccountId}:${PublicApiApi}/*/*
  WorkerLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName:
        Fn::Sub: /aws/lambda/${AWS::StackName}-worker
      RetentionInDays: 30
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  Worker:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName:
        Fn::Sub: ${AWS::StackName}-worker
      PackageType: Image
      Code:
        ImageUri: 123456789012.dkr.ecr.us-east-1.amazonaws.com/app/worker:1.2.3
      Role:
        Fn::GetAtt:
        - ExecutionSaRole
        - Arn
      MemorySize: 256
      Timeout: 180
      Environment:
        Variables:
          ALIEN_CURRENT_FUNCTION_BINDING_NAME: worker
          ALIEN_DEPLOYMENT_TYPE: aws
          ALIEN_LAMBDA_MODE: buffered
          ALIEN_RUNTIME_SEND_OTLP: 'true'
          ALIEN_TRANSPORT: lambda
          AWS_ACCOUNT_ID:
            Ref: AWS::AccountId
      VpcConfig:
        SubnetIds:
        - Ref: DefaultNetworkPrivateSubnet1
        - Fn::If:
          - NetworkCreateUseAz2
          - Ref: DefaultNetworkPrivateSubnet2
          - Ref: AWS::NoValue
        - Fn::If:
          - NetworkCreateUseAz3
          - Ref: DefaultNetworkPrivateSubnet3
          - Ref: AWS::NoValue
        SecurityGroupIds:
        - Ref: DefaultNetworkSecurityGroup
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: full-aws
      - Key: AlienResourceId
        Value: worker
      - Key: AlienResourceType
        Value: function
    DependsOn:
    - WorkerLogGroup
  WorkerQueueTrigger0:
    Type: AWS::Lambda::EventSourceMapping
    Properties:
      BatchSize: 1
      Enabled: true
      EventSourceArn:
        Fn::GetAtt:
        - Jobs
        - Arn
      FunctionName:
        Ref: Worker
  WorkerScheduleTrigger0:
    Type: AWS::Events::Rule
    Properties:
      ScheduleExpression: rate(5 minutes)
      State: ENABLED
      Targets:
      - Id: WorkerTarget0
        Arn:
          Fn::GetAtt:
          - Worker
          - Arn
  WorkerSchedulePermission0:
    Type: AWS::Lambda::Permission
    Properties:
      Action: lambda:InvokeFunction
      FunctionName:
        Ref: Worker
      Principal: events.amazonaws.com
      SourceArn:
        Fn::GetAtt:
        - WorkerScheduleTrigger0
        - Arn
  AlienStackImport:
    Type: AWS::CloudFormation::CustomResource
    Properties:
      ServiceToken: arn:aws:lambda:us-east-1:123456789012:function:alien-import
      DeploymentGroupToken:
        Ref: DeploymentGroupToken
      DeploymentName:
        Ref: AWS::StackName
      SourceKind: cloudformation
      Platform: aws
      Region:
        Ref: AWS::Region
      ManagementConfig:
        platform: aws
        managingRoleArn:
          Ref: ManagingRoleArn
      StackSettings:
        deploymentModel: push
        updates:
          Ref: UpdatesMode
        telemetry:
          Ref: TelemetryMode
        heartbeats:
          Ref: HeartbeatsMode
        network:
          type: create
          cidr:
            Fn::If:
            - HasVpcCidr
            - Ref: VpcCidr
            - Ref: AWS::NoValue
          availabilityZones:
            Ref: AvailabilityZones
        domains:
          Fn::If:
          - HasDomainName
          - customDomains:
              default:
                domain:
                  Ref: DomainName
                certificate:
                  aws:
                    certificateArn:
                      Ref: CertificateArn
          - Ref: AWS::NoValue
      Resources:
      - id: default-network
        type: network
        importData:
          vpcId:
            Ref: DefaultNetworkVpc
          cidrBlock:
            Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          internetGatewayId:
            Ref: DefaultNetworkInternetGateway
          natGatewayId:
            Ref: DefaultNetworkNatGateway
          eipAllocationId:
            Fn::GetAtt:
            - DefaultNetworkNatEip
            - AllocationId
          publicSubnetIds:
          - Ref: DefaultNetworkPublicSubnet1
          - Fn::If:
            - NetworkCreateUseAz2
            - Ref: DefaultNetworkPublicSubnet2
            - Ref: AWS::NoValue
          - Fn::If:
            - NetworkCreateUseAz3
            - Ref: DefaultNetworkPublicSubnet3
            - Ref: AWS::NoValue
          privateSubnetIds:
          - Ref: DefaultNetworkPrivateSubnet1
          - Fn::If:
            - NetworkCreateUseAz2
            - Ref: DefaultNetworkPrivateSubnet2
            - Ref: AWS::NoValue
          - Fn::If:
            - NetworkCreateUseAz3
            - Ref: DefaultNetworkPrivateSubnet3
            - Ref: AWS::NoValue
          publicRouteTableId:
            Ref: DefaultNetworkPublicRouteTable
          privateRouteTableId:
            Ref: DefaultNetworkPrivateRouteTable
          securityGroupId:
            Ref: DefaultNetworkSecurityGroup
          availabilityZones:
          - Fn::Select:
            - 0
            - Fn::GetAZs:
                Ref: AWS::Region
          - Fn::If:
            - NetworkCreateUseAz2
            - Fn::Select:
              - 1
              - Fn::GetAZs:
                  Ref: AWS::Region
            - Ref: AWS::NoValue
          - Fn::If:
            - NetworkCreateUseAz3
            - Fn::Select:
              - 2
              - Fn::GetAZs:
                  Ref: AWS::Region
            - Ref: AWS::NoValue
          isByoVpc: false
      - id: execution-sa
        type: service-account
        importData:
          roleName:
            Ref: ExecutionSaRole
          roleArn:
            Fn::GetAtt:
            - ExecutionSaRole
            - Arn
          stackPermissionsApplied: true
      - id: management
        type: remote-stack-management
        importData:
          roleName:
            Ref: ManagementRole
          roleArn:
            Fn::GetAtt:
            - ManagementRole
            - Arn
          managementPermissionsApplied: true
      - id: assets
        type: storage
        importData:
          bucketName:
            Ref: Assets
          bucketArn:
            Fn::GetAtt:
            - Assets
            - Arn
      - id: jobs
        type: queue
        importData:
          queueName:
            Fn::GetAtt:
            - Jobs
            - QueueName
          queueUrl:
            Ref: Jobs
          queueArn:
            Fn::GetAtt:
            - Jobs
            - Arn
      - id: metadata
        type: kv
        importData:
          tableName:
            Ref: Metadata
          tableArn:
            Fn::GetAtt:
            - Metadata
            - Arn
      - id: secrets
        type: vault
        importData:
          accountId:
            Ref: AWS::AccountId
          region:
            Ref: AWS::Region
          parameterPrefix:
            Fn::Sub: ${AWS::StackName}-secrets
      - id: registry
        type: artifact-registry
        importData:
          accountId:
            Ref: AWS::AccountId
          region:
            Ref: AWS::Region
          registryId:
            Fn::Sub: ${AWS::AccountId}:${AWS::Region}
          registryEndpoint:
            Fn::Sub: ${AWS::AccountId}.dkr.ecr.${AWS::Region}.${AWS::URLSuffix}
          repositoryPrefix:
            Fn::Sub: ${AWS::StackName}-registry
          pullRoleArn:
            Fn::GetAtt:
            - RegistryPullRole
            - Arn
          pushRoleArn:
            Fn::GetAtt:
            - RegistryPushRole
            - Arn
      - id: builder
        type: build
        importData:
          projectName:
            Ref: Builder
          projectArn:
            Fn::GetAtt:
            - Builder
            - Arn
          buildEnvVars:
            PROFILE: release
      - id: public-api
        type: function
        importData:
          functionName:
            Ref: PublicApi
          functionArn:
            Fn::GetAtt:
            - PublicApi
            - Arn
          eventSourceMappings: []
          eventbridgeRuleNames: []
          s3PermissionStatementIds:
          - PublicApiStoragePermissionassets
          eventbridgePermissionStatementIds: []
          url:
            Fn::Sub: https://${PublicApiApi}.execute-api.${AWS::Region}.${AWS::URLSuffix}
          apiId:
            Ref: PublicApiApi
          integrationId:
            Ref: PublicApiIntegration
          routeId:
            Ref: PublicApiRoute
          stageName: $default
      - id: worker
        type: function
        importData:
          functionName:
            Ref: Worker
          functionArn:
            Fn::GetAtt:
            - Worker
            - Arn
          eventSourceMappings:
          - Ref: WorkerQueueTrigger0
          eventbridgeRuleNames:
          - Ref: WorkerScheduleTrigger0
          s3PermissionStatementIds: []
          eventbridgePermissionStatementIds:
          - WorkerScheduleInvoke0
    DependsOn:
    - DefaultNetworkVpc
    - DefaultNetworkInternetGateway
    - DefaultNetworkVpcGatewayAttachment
    - DefaultNetworkPublicSubnet1
    - DefaultNetworkPrivateSubnet1
    - DefaultNetworkPublicRouteTable
    - DefaultNetworkPublicDefaultRoute
    - DefaultNetworkPrivateRouteTable
    - DefaultNetworkNatEip
    - DefaultNetworkNatGateway
    - DefaultNetworkPrivateDefaultRoute
    - DefaultNetworkPublicSubnet1RouteTableAssociation
    - DefaultNetworkPrivateSubnet1RouteTableAssociation
    - DefaultNetworkSecurityGroup
    - ExecutionSaRole
    - ManagementRole
    - Assets
    - AssetsBucketPolicy
    - Jobs
    - Metadata
    - RegistryRepository
    - RegistryPullRole
    - RegistryPushRole
    - BuilderLogGroup
    - Builder
    - PublicApiLogGroup
    - PublicApi
    - PublicApiStoragePermissionassets
    - PublicApiApi
    - PublicApiIntegration
    - PublicApiRoute
    - PublicApiStage
    - PublicApiApiPermission
    - WorkerLogGroup
    - Worker
    - WorkerQueueTrigger0
    - WorkerScheduleTrigger0
    - WorkerSchedulePermission0
Outputs:
  AlienSourceKind:
    Value: cloudformation
    Description: Distribution source kind.
  AlienPlatform:
    Value: aws
    Description: Target platform.
  AlienRegion:
    Value:
      Ref: AWS::Region
    Description: AWS region.
  AlienManagementConfig:
    Value:
      Fn::ToJsonString:
        platform: aws
        managingRoleArn:
          Ref: ManagingRoleArn
    Description: Manager import ManagementConfig JSON.
  AlienStackSettings:
    Value:
      Fn::ToJsonString:
        deploymentModel: push
        updates:
          Ref: UpdatesMode
        telemetry:
          Ref: TelemetryMode
        heartbeats:
          Ref: HeartbeatsMode
        network:
          type: create
          cidr:
            Fn::If:
            - HasVpcCidr
            - Ref: VpcCidr
            - Ref: AWS::NoValue
          availabilityZones:
            Ref: AvailabilityZones
        domains:
          Fn::If:
          - HasDomainName
          - customDomains:
              default:
                domain:
                  Ref: DomainName
                certificate:
                  aws:
                    certificateArn:
                      Ref: CertificateArn
          - Ref: AWS::NoValue
    Description: Manager import StackSettings JSON.
  AlienResources0:
    Value:
      Fn::ToJsonString:
      - id: default-network
        type: network
        importData:
          vpcId:
            Ref: DefaultNetworkVpc
          cidrBlock:
            Fn::GetAtt:
            - DefaultNetworkVpc
            - CidrBlock
          internetGatewayId:
            Ref: DefaultNetworkInternetGateway
          natGatewayId:
            Ref: DefaultNetworkNatGateway
          eipAllocationId:
            Fn::GetAtt:
            - DefaultNetworkNatEip
            - AllocationId
          publicSubnetIds:
          - Ref: DefaultNetworkPublicSubnet1
          - Fn::If:
            - NetworkCreateUseAz2
            - Ref: DefaultNetworkPublicSubnet2
            - Ref: AWS::NoValue
          - Fn::If:
            - NetworkCreateUseAz3
            - Ref: DefaultNetworkPublicSubnet3
            - Ref: AWS::NoValue
          privateSubnetIds:
          - Ref: DefaultNetworkPrivateSubnet1
          - Fn::If:
            - NetworkCreateUseAz2
            - Ref: DefaultNetworkPrivateSubnet2
            - Ref: AWS::NoValue
          - Fn::If:
            - NetworkCreateUseAz3
            - Ref: DefaultNetworkPrivateSubnet3
            - Ref: AWS::NoValue
          publicRouteTableId:
            Ref: DefaultNetworkPublicRouteTable
          privateRouteTableId:
            Ref: DefaultNetworkPrivateRouteTable
          securityGroupId:
            Ref: DefaultNetworkSecurityGroup
          availabilityZones:
          - Fn::Select:
            - 0
            - Fn::GetAZs:
                Ref: AWS::Region
          - Fn::If:
            - NetworkCreateUseAz2
            - Fn::Select:
              - 1
              - Fn::GetAZs:
                  Ref: AWS::Region
            - Ref: AWS::NoValue
          - Fn::If:
            - NetworkCreateUseAz3
            - Fn::Select:
              - 2
              - Fn::GetAZs:
                  Ref: AWS::Region
            - Ref: AWS::NoValue
          isByoVpc: false
      - id: execution-sa
        type: service-account
        importData:
          roleName:
            Ref: ExecutionSaRole
          roleArn:
            Fn::GetAtt:
            - ExecutionSaRole
            - Arn
          stackPermissionsApplied: true
      - id: management
        type: remote-stack-management
        importData:
          roleName:
            Ref: ManagementRole
          roleArn:
            Fn::GetAtt:
            - ManagementRole
            - Arn
          managementPermissionsApplied: true
      - id: assets
        type: storage
        importData:
          bucketName:
            Ref: Assets
          bucketArn:
            Fn::GetAtt:
            - Assets
            - Arn
      - id: jobs
        type: queue
        importData:
          queueName:
            Fn::GetAtt:
            - Jobs
            - QueueName
          queueUrl:
            Ref: Jobs
          queueArn:
            Fn::GetAtt:
            - Jobs
            - Arn
      - id: metadata
        type: kv
        importData:
          tableName:
            Ref: Metadata
          tableArn:
            Fn::GetAtt:
            - Metadata
            - Arn
      - id: secrets
        type: vault
        importData:
          accountId:
            Ref: AWS::AccountId
          region:
            Ref: AWS::Region
          parameterPrefix:
            Fn::Sub: ${AWS::StackName}-secrets
      - id: registry
        type: artifact-registry
        importData:
          accountId:
            Ref: AWS::AccountId
          region:
            Ref: AWS::Region
          registryId:
            Fn::Sub: ${AWS::AccountId}:${AWS::Region}
          registryEndpoint:
            Fn::Sub: ${AWS::AccountId}.dkr.ecr.${AWS::Region}.${AWS::URLSuffix}
          repositoryPrefix:
            Fn::Sub: ${AWS::StackName}-registry
          pullRoleArn:
            Fn::GetAtt:
            - RegistryPullRole
            - Arn
          pushRoleArn:
            Fn::GetAtt:
            - RegistryPushRole
            - Arn
      - id: builder
        type: build
        importData:
          projectName:
            Ref: Builder
          projectArn:
            Fn::GetAtt:
            - Builder
            - Arn
          buildEnvVars:
            PROFILE: release
      - id: public-api
        type: function
        importData:
          functionName:
            Ref: PublicApi
          functionArn:
            Fn::GetAtt:
            - PublicApi
            - Arn
          eventSourceMappings: []
          eventbridgeRuleNames: []
          s3PermissionStatementIds:
          - PublicApiStoragePermissionassets
          eventbridgePermissionStatementIds: []
          url:
            Fn::Sub: https://${PublicApiApi}.execute-api.${AWS::Region}.${AWS::URLSuffix}
          apiId:
            Ref: PublicApiApi
          integrationId:
            Ref: PublicApiIntegration
          routeId:
            Ref: PublicApiRoute
          stageName: $default
    Description: Manager import resources JSON chunk. Reassemble chunks in numeric suffix order.
  AlienResources1:
    Value:
      Fn::ToJsonString:
      - id: worker
        type: function
        importData:
          functionName:
            Ref: Worker
          functionArn:
            Fn::GetAtt:
            - Worker
            - Arn
          eventSourceMappings:
          - Ref: WorkerQueueTrigger0
          eventbridgeRuleNames:
          - Ref: WorkerScheduleTrigger0
          s3PermissionStatementIds: []
          eventbridgePermissionStatementIds:
          - WorkerScheduleInvoke0
    Description: Manager import resources JSON chunk. Reassemble chunks in numeric suffix order.

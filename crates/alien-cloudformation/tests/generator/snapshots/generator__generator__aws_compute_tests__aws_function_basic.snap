---
source: crates/alien-cloudformation/tests/generator/aws_compute_tests.rs
expression: yaml
---
AWSTemplateFormatVersion: 2010-09-09
Description: aws_function_basic
Transform:
- AWS::LanguageExtensions
Metadata:
  AWS::CloudFormation::Interface:
    ParameterGroups:
    - Label:
        default: Registration
      Parameters:
      - DeploymentGroupToken
      - ManagingRoleArn
      - ManagingAccountId
    - Label:
        default: Domains
      Parameters:
      - DomainName
      - HostedZoneId
      - CertificateArn
    - Label:
        default: Operations
      Parameters:
      - UpdatesMode
      - TelemetryMode
      - HeartbeatsMode
    ParameterLabels:
      CertificateArn:
        default: Certificate ARN
      DeploymentGroupToken:
        default: Deployment group token
      DomainName:
        default: Domain name
      HeartbeatsMode:
        default: Heartbeats
      HostedZoneId:
        default: Hosted zone ID
      ManagingAccountId:
        default: Manager AWS account ID
      ManagingRoleArn:
        default: Manager role ARN
      TelemetryMode:
        default: Telemetry
      UpdatesMode:
        default: Updates
Parameters:
  DeploymentGroupToken:
    Type: String
    Description: Deployment-group token used when registering the resolved stack import.
    NoEcho: true
  ManagingRoleArn:
    Type: String
    Description: AWS IAM role ARN for the manager identity allowed to assume generated management roles.
  ManagingAccountId:
    Type: String
    Description: AWS account ID hosting the manager. Referenced by stack-side IAM policies that scope cross-account ECR pulls. Empty disables those grants.
    Default: ''
  DomainName:
    Type: String
    Description: Optional domain name for public endpoints. Empty disables custom domains.
  HostedZoneId:
    Type: String
    Description: Optional Route 53 hosted zone ID for the domain.
  CertificateArn:
    Type: String
    Description: Optional ACM certificate ARN for the domain.
  UpdatesMode:
    Type: String
    Description: How updates are applied after import.
    Default: auto
    AllowedValues:
    - auto
    - approval-required
  TelemetryMode:
    Type: String
    Description: Telemetry collection behavior.
    Default: auto
    AllowedValues:
    - "off"
    - auto
    - approval-required
  HeartbeatsMode:
    Type: String
    Description: Heartbeat health-check behavior.
    Default: "on"
    AllowedValues:
    - "off"
    - "on"
Conditions:
  HasDomainName:
    Fn::Not:
    - Fn::Equals:
      - Ref: DomainName
      - ''
Resources:
  ApiRole:
    Type: AWS::IAM::Role
    Properties:
      AssumeRolePolicyDocument:
        Version: 2012-10-17
        Statement:
        - Effect: Allow
          Principal:
            Service: lambda.amazonaws.com
          Action: sts:AssumeRole
      Policies:
      - PolicyName: alien-managed-policy
        PolicyDocument:
          Version: 2012-10-17
          Statement:
          - Sid: WriteLogs
            Effect: Allow
            Action:
            - logs:CreateLogGroup
            - logs:CreateLogStream
            - logs:PutLogEvents
            Resource: '*'
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: acme-fn
      - Key: AlienResourceId
        Value: api
      - Key: AlienResourceType
        Value: function
  ApiLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName:
        Fn::Sub: /aws/lambda/${AWS::StackName}-api
      RetentionInDays: 30
    DeletionPolicy: Retain
    UpdateReplacePolicy: Retain
  Api:
    Type: AWS::Lambda::Function
    Properties:
      FunctionName:
        Fn::Sub: ${AWS::StackName}-api
      PackageType: Image
      Code:
        ImageUri: 123456789012.dkr.ecr.us-east-1.amazonaws.com/app:1
      Role:
        Fn::GetAtt:
        - ApiRole
        - Arn
      MemorySize: 256
      Timeout: 30
      Environment:
        Variables:
          ALIEN_CURRENT_FUNCTION_BINDING_NAME: api
          ALIEN_DEPLOYMENT_TYPE: aws
          ALIEN_LAMBDA_MODE: buffered
          ALIEN_RUNTIME_SEND_OTLP: 'true'
          ALIEN_TRANSPORT: lambda
          AWS_ACCOUNT_ID:
            Ref: AWS::AccountId
      Tags:
      - Key: ManagedBy
        Value: alien.dev
      - Key: AlienStackId
        Value: acme-fn
      - Key: AlienResourceId
        Value: api
      - Key: AlienResourceType
        Value: function
    DependsOn:
    - ApiLogGroup
    - ApiRole
Outputs:
  DeploymentSourceKind:
    Value: cloudformation
    Description: Distribution source kind.
  DeploymentStackPrefix:
    Value:
      Ref: AWS::StackName
    Description: Physical stack prefix.
  DeploymentPlatform:
    Value: aws
    Description: Target platform.
  DeploymentRegion:
    Value:
      Ref: AWS::Region
    Description: AWS region.
  DeploymentManagementConfig:
    Value:
      Fn::ToJsonString:
        platform: aws
        managingRoleArn:
          Ref: ManagingRoleArn
    Description: Manager import ManagementConfig JSON.
  DeploymentStackSettings:
    Value:
      Fn::ToJsonString:
        deploymentModel: push
        updates:
          Ref: UpdatesMode
        telemetry:
          Ref: TelemetryMode
        heartbeats:
          Ref: HeartbeatsMode
        network:
          Ref: AWS::NoValue
        domains:
          Fn::If:
          - HasDomainName
          - customDomains:
              default:
                domain:
                  Ref: DomainName
                certificate:
                  aws:
                    certificateArn:
                      Ref: CertificateArn
          - Ref: AWS::NoValue
    Description: Manager import StackSettings JSON.
  DeploymentResources:
    Value:
      Fn::ToJsonString:
      - id: api
        type: function
        importData:
          functionName:
            Ref: Api
          functionArn:
            Fn::GetAtt:
            - Api
            - Arn
          eventSourceMappings: []
          eventbridgeRuleNames: []
          s3PermissionStatementIds: []
          eventbridgePermissionStatementIds: []
    Description: Manager import resources JSON.

{
  "name": "@alienplatform/bindings",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "npm run build",
    "test": "vitest run --passWithNoTests",
    "test:ts": "tsc --noEmit",
    "generate": "./scripts/generate-proto.sh",
    "format-and-lint": "biome check .",
    "format-and-lint:fix": "biome check . --write"
  },
  "keywords": ["alien", "bindings", "grpc", "sdk"],
  "author": "",
  "license": "ISC",
  "description": "TypeScript SDK for Alien bindings - gRPC client for Storage, KV, Queue, Vault, and more",
  "repository": {
    "type": "git",
    "url": "https://github.com/alienplatform/alien.git",
    "directory": "packages/bindings"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@alienplatform/typescript-config": "workspace:^",
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^24.0.15",
    "ts-proto": "^2.7.0",
    "tsdown": "^0.13.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "dependencies": {
    "@alienplatform/core": "workspace:^",
    "@bufbuild/protobuf": "^2.5.3",
    "@grpc/grpc-js": "^1.13.4",
    "long": "^5.3.2",
    "nice-grpc": "^2.1.11",
    "nice-grpc-common": "^2.0.2",
    "protobufjs": "^7.5.3",
    "ts-pattern": "^5.7.1",
    "zod": "4.3.2"
  }
}

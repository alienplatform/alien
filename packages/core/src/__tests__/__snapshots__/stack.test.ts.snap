exports[`Build resource configuration > creates a build with all configuration options 1`] = `
Resource {
  "config": {
    "computeType": "large",
    "environment": {
      "BUILD_TARGET": "release",
      "CUSTOM_VAR": "test-value",
      "NODE_ENV": "production",
    },
    "id": "comprehensive-build",
    "links": [
      {
        "id": "test-registry",
        "type": "artifact-registry",
      },
      {
        "id": "test-storage",
        "type": "storage",
      },
    ],
    "permissions": "builder",
    "type": "build",
  },
}
`;


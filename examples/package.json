{
  "name": "@alienplatform/examples-workspace",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "test": "pnpm run test:projects",
    "test:projects": "pnpm -C minimal-cloud-agent test && pnpm -C github-agent/packages/remote-agent test",
    "test:projects:all": "pnpm -C endpoint-agent test && pnpm -C minimal-cloud-agent test && pnpm -C github-agent/packages/remote-agent test",
    "test:remote-agent": "pnpm -C github-agent/packages/remote-agent test"
  },
  "pnpm": {
    "overrides": {
      "@alienplatform/platform-api": "file:../client-sdks/platform/typescript",
      "@alienplatform/core": "file:../packages/core",
      "@alienplatform/commands-client": "file:../packages/commands-client",
      "@alienplatform/bindings": "file:../packages/bindings",
      "@alienplatform/testing": "file:../packages/testing"
    }
  }
}

          "404": {
            "description": "Deployment group not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/v1/deployment-groups/{id}/tokens": {
      "post": {
        "tags": [
          "deployment-groups"
        ],
        "operationId": "create_deployment_group_token",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Deployment group ID",
